<Window x:Class="Hud.App.Views.GainAnalysisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="APH - Ganancia"
        Height="720"
        Width="1380"
        MinHeight="560"
        MinWidth="1120"
        Background="{DynamicResource Brush.AppShell}"
        WindowStartupLocation="Manual">

  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="GainModeButton" TargetType="Button" BasedOn="{StaticResource CardButton}">
      <Setter Property="MinWidth" Value="128"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="Margin" Value="0,0,8,0"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="GainMetricCard" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="12"/>
      <Setter Property="Margin" Value="0,0,10,0"/>
    </Style>

    <Style x:Key="InsightCard" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource Brush.Inset}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="7"/>
      <Setter Property="Padding" Value="10"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>
  </Window.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="1.1*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="1*"/>
    </Grid.RowDefinitions>

    <Border Style="{StaticResource ProjectPanelBorder}" Padding="16" Margin="0,0,0,12">
      <StackPanel HorizontalAlignment="Center">
        <TextBlock Text="GANANCIA" FontSize="25" FontWeight="Bold" HorizontalAlignment="Center"/>
        <TextBlock x:Name="SummaryText" Foreground="{DynamicResource Brush.TextDim}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
      </StackPanel>
    </Border>

    <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,12">
      <Border Style="{StaticResource GainMetricCard}">
        <StackPanel>
          <TextBlock Text="GANANCIA TOTAL" Style="{StaticResource SectionEyebrow}"/>
          <TextBlock x:Name="TotalText" FontSize="20" FontWeight="Bold"/>
        </StackPanel>
      </Border>
      <Border Style="{StaticResource GainMetricCard}">
        <StackPanel>
          <TextBlock Text="MEDIA POR MANO" Style="{StaticResource SectionEyebrow}"/>
          <TextBlock x:Name="AverageText" FontSize="20" FontWeight="Bold"/>
        </StackPanel>
      </Border>
      <Border Style="{StaticResource GainMetricCard}">
        <StackPanel>
          <TextBlock Text="MEJOR CORTE" Style="{StaticResource SectionEyebrow}"/>
          <TextBlock x:Name="BestText" FontSize="18" FontWeight="Bold"/>
        </StackPanel>
      </Border>
      <Border Style="{StaticResource GainMetricCard}" Margin="0">
        <StackPanel>
          <TextBlock Text="PEOR CORTE" Style="{StaticResource SectionEyebrow}"/>
          <TextBlock x:Name="WorstText" FontSize="18" FontWeight="Bold"/>
        </StackPanel>
      </Border>
    </UniformGrid>

    <Border Grid.Row="2"
            Style="{StaticResource ProjectPanelBorder}"
            Padding="12"
            Margin="0,0,0,12">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel Margin="0,0,0,8">
          <TextBlock Text="EVOLUCION ACUMULADA EN BB" Style="{StaticResource SectionEyebrow}" DockPanel.Dock="Left"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock Text="Linea acumulada mano por mano  " Foreground="{DynamicResource Brush.TextDim}" FontSize="12"/>
            <TextBlock x:Name="CurveTotalText" Foreground="{DynamicResource Brush.Text}" FontWeight="Bold"/>
          </StackPanel>
        </DockPanel>
        <Canvas x:Name="CurveCanvas"
                Grid.Row="1"
                MinHeight="190"
                ClipToBounds="True"
                Background="#05090D"
                SizeChanged="CurveCanvas_SizeChanged"/>
      </Grid>
    </Border>

    <Border Grid.Row="3" Style="{StaticResource ProjectPanelBorder}" Padding="10" Margin="0,0,0,12">
      <DockPanel LastChildFill="False">
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
          <Button x:Name="StreetModeButton" Content="Por calle" Tag="Street" Style="{StaticResource GainModeButton}" Click="ModeButton_Click"/>
          <Button x:Name="PositionModeButton" Content="Por posicion" Tag="Position" Style="{StaticResource GainModeButton}" Click="ModeButton_Click"/>
          <Button x:Name="ActionModeButton" Content="Por accion" Tag="Action" Style="{StaticResource GainModeButton}" Click="ModeButton_Click"/>
          <Button x:Name="BluffModeButton" Content="Por bluff" Tag="Bluff" Style="{StaticResource GainModeButton}" Click="ModeButton_Click"/>
        </StackPanel>
        <TextBlock x:Name="ModeDescriptionText"
                   DockPanel.Dock="Right"
                   Foreground="{DynamicResource Brush.TextDim}"
                   MaxWidth="520"
                   VerticalAlignment="Center"/>
      </DockPanel>
    </Border>

    <Border Grid.Row="4" Style="{StaticResource ProjectPanelBorder}" Padding="12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="2*"/>
          <ColumnDefinition Width="14"/>
          <ColumnDefinition Width="0.95*"/>
        </Grid.ColumnDefinitions>

        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <DockPanel Margin="0,0,0,8">
            <TextBlock x:Name="BarsTitleText" Text="GANANCIA POR CALLE" Style="{StaticResource SectionEyebrow}" DockPanel.Dock="Left"/>
            <TextBlock Text="Cada barra muestra total; pasa el mouse para media y manos" Foreground="{DynamicResource Brush.TextDim}" FontSize="12" HorizontalAlignment="Right"/>
          </DockPanel>
          <Canvas x:Name="BarsCanvas"
                  Grid.Row="1"
                  MinHeight="180"
                  ClipToBounds="True"
                  Background="#05090D"
                  SizeChanged="BarsCanvas_SizeChanged"/>
        </Grid>

        <Border Grid.Column="2"
                Background="{DynamicResource Brush.Card}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="InsightTitleText" Text="LECTURA" Style="{StaticResource SectionEyebrow}"/>
            <TextBlock x:Name="InsightBodyText"
                       Grid.Row="1"
                       Foreground="{DynamicResource Brush.TextDim}"
                       FontSize="12"
                       Margin="0,6,0,10"/>
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
              <ItemsControl x:Name="InsightList">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Style="{StaticResource InsightCard}">
                      <StackPanel>
                        <DockPanel>
                          <TextBlock Text="{Binding Label}" FontWeight="Bold" FontSize="13" DockPanel.Dock="Left"/>
                          <TextBlock Text="{Binding Result}" Foreground="{Binding ResultBrush}" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource Brush.TextDim}" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding Explanation}" Foreground="{DynamicResource Brush.Text}" FontSize="12" Margin="0,5,0,0"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>
