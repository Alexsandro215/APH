<Window x:Class="Hud.App.Views.HeroProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Hud.App.Views"
        Title="{DynamicResource Common.HeroProfileTitle}"
        Height="860"
        Width="1480"
        MinHeight="720"
        MinWidth="1180"
        Background="{StaticResource Brush.Bg}"
        WindowStartupLocation="CenterOwner">

  <Window.Resources>
    <views:StatToBrushConverter x:Key="StatToBrush"/>
    <views:StatTextBrushConverter x:Key="StatTextBrush"/>

    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="PanelBorder" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource Brush.Card}"/>
      <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="14"/>
    </Style>

    <Style TargetType="DataGrid">
      <Setter Property="Background" Value="#101720"/>
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
      <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
      <Setter Property="GridLinesVisibility" Value="Horizontal"/>
      <Setter Property="HorizontalGridLinesBrush" Value="#223244"/>
      <Setter Property="RowBackground" Value="#101720"/>
      <Setter Property="AlternatingRowBackground" Value="#141C26"/>
      <Setter Property="HeadersVisibility" Value="Column"/>
      <Setter Property="CanUserAddRows" Value="False"/>
      <Setter Property="CanUserDeleteRows" Value="False"/>
      <Setter Property="CanUserResizeRows" Value="False"/>
      <Setter Property="IsReadOnly" Value="True"/>
      <Setter Property="AutoGenerateColumns" Value="False"/>
      <Setter Property="ColumnHeaderHeight" Value="28"/>
      <Setter Property="RowHeight" Value="24"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="#E9EEF3"/>
      <Setter Property="Foreground" Value="Black"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Padding" Value="6,4"/>
      <Setter Property="TextElement.FontSize" Value="12"/>
      <Setter Property="TextElement.FontWeight" Value="Bold"/>
      <Setter Property="TextElement.Foreground" Value="Black"/>
    </Style>

    <Style TargetType="DataGridCell">
      <Setter Property="BorderBrush" Value="#223244"/>
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
      <Setter Property="Padding" Value="6,2"/>
    </Style>

    <Style x:Key="NoWrapCellText" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
      <Setter Property="TextWrapping" Value="NoWrap"/>
      <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
  </Window.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,12" Padding="18">
      <DockPanel>
        <Button DockPanel.Dock="Right"
                Width="38"
                Height="38"
                Margin="12,0,0,0"
                Padding="0"
                FontSize="20"
                FontWeight="Bold"
                Foreground="Black"
                Content="?"
                Click="BtnDictionary_Click"
                ToolTip="Abrir diccionario de tags y colores"/>
        <Border Width="58" Height="58" CornerRadius="12" Background="#11261A" BorderBrush="#214E38" BorderThickness="1" Margin="0,0,16,0">
          <Viewbox Stretch="Uniform">
            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource Brush.Accent}" FontWeight="Bold"/>
          </Viewbox>
        </Border>
        <StackPanel>
          <TextBlock Text="{Binding HeroTitle}" FontSize="26" FontWeight="Bold"/>
          <TextBlock Text="{Binding Summary}" Foreground="{StaticResource Brush.TextDim}" Margin="0,5,0,0"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <UniformGrid Columns="5">
          <StackPanel Margin="8">
            <TextBlock Text="{DynamicResource Common.Hands}" Foreground="{StaticResource Brush.TextDim}"/>
            <TextBlock Text="{Binding HandsLabel}" FontSize="22" FontWeight="Bold"/>
          </StackPanel>
          <StackPanel Margin="8">
            <TextBlock Text="{DynamicResource Common.TotalResult}" Foreground="{StaticResource Brush.TextDim}"/>
            <TextBlock Text="{Binding TotalBbLabel}" FontSize="22" FontWeight="Bold" Foreground="{Binding TotalBbBrush}"/>
          </StackPanel>
          <StackPanel Margin="8">
            <TextBlock Text="BB/100" Foreground="{StaticResource Brush.TextDim}"/>
            <TextBlock Text="{Binding BbPer100Label}" FontSize="22" FontWeight="Bold" Foreground="{Binding TotalBbBrush}"/>
          </StackPanel>
          <StackPanel Margin="8">
            <TextBlock Text="Mejor posicion" Foreground="{StaticResource Brush.TextDim}"/>
            <TextBlock Text="{Binding BestPositionLabel}" FontSize="22" FontWeight="Bold"/>
          </StackPanel>
          <StackPanel Margin="8">
            <TextBlock Text="{DynamicResource Common.WorstPosition}" Foreground="{StaticResource Brush.TextDim}"/>
            <TextBlock Text="{Binding WorstPositionLabel}" FontSize="22" FontWeight="Bold" Foreground="#FF6B7A"/>
          </StackPanel>
        </UniformGrid>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding Tags}" Margin="4,10,4,0">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Background="{Binding Background}"
                      BorderBrush="{Binding Border}"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="8,4"
                      Margin="4"
                      ToolTip="{Binding Description}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <ContentControl Content="{Binding CardChips}"
                                  ContentTemplate="{StaticResource CardChipListTemplate}"
                                  Margin="0,0,5,0"/>
                  <TextBlock Text="{Binding Text}" Foreground="{Binding Foreground}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </Border>

    <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
      <StackPanel>
        <TextBlock Text="GLOBAL STATS" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
        <ItemsControl ItemsSource="{Binding StatMetrics}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <UniformGrid Columns="10"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border BorderBrush="#223244" BorderThickness="1" Margin="1">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="30"/>
                  </Grid.RowDefinitions>
                  <TextBlock Text="{Binding Label}" Background="#E9EEF3" Foreground="Black" FontWeight="Bold" TextAlignment="Center" Padding="4,2"/>
                  <TextBlock Grid.Row="1" Text="{Binding DisplayValue}" TextAlignment="Center" FontWeight="SemiBold" Padding="4,6"
                             Foreground="{Binding Hands, Converter={StaticResource StatTextBrush}}">
                    <TextBlock.Background>
                      <MultiBinding Converter="{StaticResource StatToBrush}">
                        <Binding Path="Value"/>
                        <Binding Path="Hands"/>
                        <Binding Path="Stake"/>
                        <Binding Path="Key"/>
                      </MultiBinding>
                    </TextBlock.Background>
                  </TextBlock>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>

    <Grid Grid.Row="3">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1.1*"/>
        <ColumnDefinition Width="1.1*"/>
        <ColumnDefinition Width="1*"/>
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="1.05*"/>
        <RowDefinition Height="1*"/>
      </Grid.RowDefinitions>

      <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,8">
        <DockPanel>
          <TextBlock Text="GANANCIA Y JUEGO POR POSICION" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,8"/>
          <DataGrid ItemsSource="{Binding PositionRows}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Pos" Binding="{Binding Position}" Width="50" ElementStyle="{StaticResource NoWrapCellText}"/>
              <DataGridTextColumn Header="{DynamicResource Common.Hands}" Binding="{Binding Hands}" Width="58" ElementStyle="{StaticResource NoWrapCellText}"/>
              <DataGridTextColumn Header="VPIP" Binding="{Binding VpipLabel}" Width="58" ElementStyle="{StaticResource NoWrapCellText}"/>
              <DataGridTextColumn Header="PFR" Binding="{Binding PfrLabel}" Width="56" ElementStyle="{StaticResource NoWrapCellText}"/>
              <DataGridTextColumn Header="3Bet" Binding="{Binding ThreeBetLabel}" Width="56" ElementStyle="{StaticResource NoWrapCellText}"/>
              <DataGridTemplateColumn Header="BB" Width="76">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <TextBlock Text="{Binding TotalBbTrendIcon}" Foreground="{Binding TotalBbTrendBrush}" FontWeight="Bold" Margin="0,0,4,0"/>
                      <TextBlock Text="{Binding TotalBbLabel}" Style="{StaticResource NoWrapCellText}"/>
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTemplateColumn Header="BB/100" Width="70">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <TextBlock Text="{Binding BbPer100TrendIcon}" Foreground="{Binding BbPer100TrendBrush}" FontWeight="Bold" Margin="0,0,4,0"/>
                      <TextBlock Text="{Binding BbPer100Label}" Style="{StaticResource NoWrapCellText}"/>
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="{DynamicResource Common.WorstHand}" Binding="{Binding WorstHand}" Width="*" ElementStyle="{StaticResource NoWrapCellText}"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <Border Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="8,0,8,8">
        <DockPanel>
          <TextBlock Text="TOP 10 COMBOS QUE MAS JUEGA" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,8"/>
          <DataGrid ItemsSource="{Binding TopCombos}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="{DynamicResource Common.Cards}" Binding="{Binding Combo}" Width="58" ElementStyle="{StaticResource NoWrapCellText}"/>
              <DataGridTextColumn Header="Veces" Binding="{Binding Count}" Width="52" ElementStyle="{StaticResource NoWrapCellText}"/>
              <DataGridTextColumn Header="Uso" Binding="{Binding UsageLabel}" Width="58" ElementStyle="{StaticResource NoWrapCellText}"/>
              <DataGridTextColumn Header="VPIP" Binding="{Binding VpipLabel}" Width="58" ElementStyle="{StaticResource NoWrapCellText}"/>
              <DataGridTextColumn Header="PFR" Binding="{Binding PfrLabel}" Width="56" ElementStyle="{StaticResource NoWrapCellText}"/>
              <DataGridTemplateColumn Header="{DynamicResource Common.Average}" Width="72">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <TextBlock Text="{Binding AverageBbTrendIcon}" Foreground="{Binding AverageBbTrendBrush}" FontWeight="Bold" Margin="0,0,4,0"/>
                      <TextBlock Text="{Binding AverageBbLabel}" Style="{StaticResource NoWrapCellText}"/>
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTemplateColumn Header="BB" Width="72">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <TextBlock Text="{Binding TotalBbTrendIcon}" Foreground="{Binding TotalBbTrendBrush}" FontWeight="Bold" Margin="0,0,4,0"/>
                      <TextBlock Text="{Binding TotalBbLabel}" Style="{StaticResource NoWrapCellText}"/>
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Pos" Binding="{Binding CommonPosition}" Width="*" ElementStyle="{StaticResource NoWrapCellText}"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Margin="8,0,0,8">
        <DockPanel>
          <TextBlock Text="{DynamicResource Common.EvByAction}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,8"/>
          <DataGrid ItemsSource="{Binding ActionRows}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="{DynamicResource Common.Action}" Binding="{Binding Action}" Width="82" ElementStyle="{StaticResource NoWrapCellText}"/>
              <DataGridTextColumn Header="{DynamicResource Common.Hands}" Binding="{Binding Count}" Width="62" ElementStyle="{StaticResource NoWrapCellText}"/>
              <DataGridTemplateColumn Header="BB" Width="80">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <TextBlock Text="{Binding TotalBbTrendIcon}" Foreground="{Binding TotalBbTrendBrush}" FontWeight="Bold" Margin="0,0,4,0"/>
                      <TextBlock Text="{Binding TotalBbLabel}" Style="{StaticResource NoWrapCellText}"/>
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTemplateColumn Header="{DynamicResource Common.Average}" Width="76">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <TextBlock Text="{Binding AverageBbTrendIcon}" Foreground="{Binding AverageBbTrendBrush}" FontWeight="Bold" Margin="0,0,4,0"/>
                      <TextBlock Text="{Binding AverageBbLabel}" Style="{StaticResource NoWrapCellText}"/>
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="{DynamicResource Common.WorstHand}" Binding="{Binding WorstHand}" Width="*" ElementStyle="{StaticResource NoWrapCellText}"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Margin="0,8,8,0">
        <DockPanel>
          <TextBlock Text="{DynamicResource Common.BestHands}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,8"/>
          <DataGrid ItemsSource="{Binding BestHands}" MouseLeftButtonUp="HandGrid_MouseLeftButtonUp">
            <DataGrid.Columns>
              <DataGridTextColumn Header="#" Binding="{Binding HandNumber}" Width="44" ElementStyle="{StaticResource NoWrapCellText}"/>
              <DataGridTemplateColumn Header="Cartas" Width="62">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <ContentControl Content="{Binding CardChips}" ContentTemplate="{StaticResource CardChipListTemplate}"/>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Combo" Binding="{Binding Combo}" Width="58" ElementStyle="{StaticResource NoWrapCellText}"/>
              <DataGridTextColumn Header="Pos" Binding="{Binding Position}" Width="50" ElementStyle="{StaticResource NoWrapCellText}"/>
              <DataGridTextColumn Header="{DynamicResource Common.Action}" Binding="{Binding Action}" Width="70" ElementStyle="{StaticResource NoWrapCellText}"/>
              <DataGridTemplateColumn Header="BB" Width="74">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <TextBlock Text="{Binding NetBbTrendIcon}" Foreground="{Binding NetBbTrendBrush}" FontWeight="Bold" Margin="0,0,4,0"/>
                      <TextBlock Text="{Binding NetBbLabel}" Style="{StaticResource NoWrapCellText}"/>
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="{DynamicResource Grid.Table}" Binding="{Binding TableName}" Width="*" ElementStyle="{StaticResource NoWrapCellText}"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="8,8,8,0">
        <DockPanel>
          <TextBlock Text="{DynamicResource Common.WorstHands}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,8"/>
          <DataGrid ItemsSource="{Binding WorstHands}" MouseLeftButtonUp="HandGrid_MouseLeftButtonUp">
            <DataGrid.Columns>
              <DataGridTextColumn Header="#" Binding="{Binding HandNumber}" Width="44" ElementStyle="{StaticResource NoWrapCellText}"/>
              <DataGridTemplateColumn Header="Cartas" Width="62">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <ContentControl Content="{Binding CardChips}" ContentTemplate="{StaticResource CardChipListTemplate}"/>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Combo" Binding="{Binding Combo}" Width="58" ElementStyle="{StaticResource NoWrapCellText}"/>
              <DataGridTextColumn Header="Pos" Binding="{Binding Position}" Width="50" ElementStyle="{StaticResource NoWrapCellText}"/>
              <DataGridTextColumn Header="{DynamicResource Common.Action}" Binding="{Binding Action}" Width="70" ElementStyle="{StaticResource NoWrapCellText}"/>
              <DataGridTemplateColumn Header="BB" Width="74">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <TextBlock Text="{Binding NetBbTrendIcon}" Foreground="{Binding NetBbTrendBrush}" FontWeight="Bold" Margin="0,0,4,0"/>
                      <TextBlock Text="{Binding NetBbLabel}" Style="{StaticResource NoWrapCellText}"/>
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="{DynamicResource Grid.Table}" Binding="{Binding TableName}" Width="*" ElementStyle="{StaticResource NoWrapCellText}"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource PanelBorder}" Margin="8,8,0,0">
        <DockPanel>
          <TextBlock Text="{DynamicResource Common.QuickRead}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,8"/>
          <ItemsControl ItemsSource="{Binding Notes}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="#101720" BorderBrush="#223244" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                  <TextBlock Text="{Binding}" Foreground="{StaticResource Brush.Text}"/>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </DockPanel>
      </Border>
    </Grid>
  </Grid>
</Window>




