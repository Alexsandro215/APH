<Window x:Class="Hud.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Settings.Title}"
        Height="720"
        Width="880"
        MinHeight="640"
        MinWidth="760"
        WindowStartupLocation="CenterOwner">

  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style x:Key="SectionCard" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="18"/>
      <Setter Property="Margin" Value="0,0,0,14"/>
    </Style>
    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextDim}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Margin" Value="0,0,0,5"/>
    </Style>
    <Style x:Key="SettingsCombo" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
      <Setter Property="MinHeight" Value="34"/>
      <Setter Property="Foreground" Value="{DynamicResource Brush.SurfaceText}"/>
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
      <Setter Property="Padding" Value="8,4"/>
    </Style>
    <Style x:Key="GhostButton" BasedOn="{StaticResource Btn.Primary}" TargetType="Button">
      <Setter Property="Background" Value="{DynamicResource Brush.Inset}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
    </Style>
  </Window.Resources>

  <Grid Background="{DynamicResource Brush.AppShell}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="{DynamicResource Brush.Panel}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,0,0,1"
            Padding="22">
      <DockPanel>
        <Border DockPanel.Dock="Left"
                Width="58"
                Height="58"
                CornerRadius="29"
                Background="{DynamicResource Brush.Negative}"
                BorderBrush="{DynamicResource Brush.Surface}"
                BorderThickness="2"
                Margin="0,0,16,0">
          <TextBlock Text="&#x2660;"
                     FontFamily="Segoe UI Symbol"
                     Foreground="White"
                     FontSize="34"
                     FontWeight="Black"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="{DynamicResource Settings.Header}"
                     FontSize="28"
                     FontWeight="Black"/>
          <TextBlock Text="{DynamicResource Settings.Subtitle}"
                     Foreground="{DynamicResource Brush.TextDim}"
                     Margin="0,4,0,0"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="22">
      <StackPanel>
        <Border Style="{StaticResource SectionCard}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1*"/>
              <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Margin="0,0,12,0">
              <TextBlock Text="{DynamicResource Settings.Language}"
                         FontSize="19"
                         FontWeight="Bold"/>
              <TextBlock Text="{DynamicResource Settings.LanguageDesc}"
                         Foreground="{DynamicResource Brush.TextDim}"
                         Margin="0,4,0,12"/>
              <TextBlock Text="{DynamicResource Settings.LanguageLabel}" Style="{StaticResource FieldLabel}"/>
              <ComboBox x:Name="LanguageCombo"
                        Style="{StaticResource SettingsCombo}"/>
            </StackPanel>
          </Grid>
        </Border>

        <Border Style="{StaticResource SectionCard}">
          <StackPanel>
            <TextBlock Text="{DynamicResource Settings.PalettePreview}"
                       FontSize="19"
                       FontWeight="Bold"/>
            <TextBlock Text="{DynamicResource Settings.PalettePreviewDesc}"
                       Foreground="{DynamicResource Brush.TextDim}"
                       Margin="0,4,0,12"/>
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,5,0,0">
              <ItemsControl x:Name="PalettePreviewList">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Click="BtnPalette_Click" Tag="{Binding Key}" Margin="0,0,12,0" Padding="0" Background="Transparent" BorderThickness="0">
                      <Button.Template>
                        <ControlTemplate TargetType="Button">
                          <Border Background="{Binding CardBrush}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="8"
                                  Padding="16"
                                  Width="200"
                                  x:Name="CardBorder">
                            <VisualStateManager.VisualStateGroups>
                              <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="MouseOver">
                                  <Storyboard>
                                    <ColorAnimation Storyboard.TargetName="CardBorder" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="{Binding AccentBrush.Color}" Duration="0:0:0.2"/>
                                  </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                  <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="CardBorder" Storyboard.TargetProperty="Opacity" To="0.8" Duration="0:0:0.1"/>
                                  </Storyboard>
                                </VisualState>
                              </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border.Style>
                              <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="{Binding BorderBrush}"/>
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </Border.Style>
                            <StackPanel>
                              <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource Brush.Text}"/>
                              <TextBlock Text="{Binding Description}" Foreground="{DynamicResource Brush.TextDim}" FontSize="12" Margin="0,6,0,14" Height="34" TextWrapping="Wrap"/>
                              <StackPanel Orientation="Horizontal">
                                <Border Width="24" Height="24" CornerRadius="6" Background="{Binding AccentBrush}" Margin="0,0,6,0"/>
                                <Border Width="24" Height="24" CornerRadius="6" Background="{Binding SecondaryBrush}" Margin="0,0,6,0"/>
                                <Border Width="24" Height="24" CornerRadius="6" Background="{Binding DangerBrush}" Margin="0,0,6,0"/>
                                <Border Width="24" Height="24" CornerRadius="6" Background="{Binding GoldBrush}"/>
                              </StackPanel>
                            </StackPanel>
                          </Border>
                        </ControlTemplate>
                      </Button.Template>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionCard}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1*"/>
              <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Margin="0,0,12,0">
              <TextBlock Text="Seguridad de reportes"
                         FontSize="19"
                         FontWeight="Bold"/>
              <TextBlock Text="Guarda una contrasena codificada para proteger informes futuros."
                         Foreground="{DynamicResource Brush.TextDim}"
                         Margin="0,4,0,12"/>
              <CheckBox x:Name="ProtectReportsCheck"
                        Margin="0,0,0,10"
                        Click="ProtectReportsCheck_Click">
                <TextBlock Text="Aplicar contrasena a reportes futuros"
                           Foreground="{DynamicResource Brush.Text}"/>
              </CheckBox>
              <TextBlock Text="Contrasena actual" Style="{StaticResource FieldLabel}"/>
              <PasswordBox x:Name="OldPasswordBox"
                           Height="32"
                           Margin="0,0,0,8"/>
              <TextBlock Text="Nueva contrasena" Style="{StaticResource FieldLabel}"/>
              <PasswordBox x:Name="NewPasswordBox"
                           Height="32"
                           Margin="0,0,0,8"/>
              <TextBlock Text="Confirmar nueva contrasena" Style="{StaticResource FieldLabel}"/>
              <PasswordBox x:Name="ConfirmPasswordBox"
                           Height="32"
                           Margin="0,0,0,10"/>
              <Button Content="Guardar contrasena"
                      Style="{StaticResource Btn.Primary}"
                      Width="160"
                      HorizontalAlignment="Left"
                      Click="BtnSaveReportPassword_Click"/>
              <TextBlock x:Name="ReportPasswordStatus"
                         Foreground="{DynamicResource Brush.TextDim}"
                         Margin="0,8,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="12,0,0,0">
              <TextBlock Text="Ubicacion de reportes"
                         FontSize="19"
                         FontWeight="Bold"/>
              <TextBlock Text="La app guarda y carga las sesiones desde esta carpeta."
                         Foreground="{DynamicResource Brush.TextDim}"
                         Margin="0,4,0,12"/>
              <TextBlock Text="Carpeta de reportes" Style="{StaticResource FieldLabel}"/>
              <TextBox x:Name="ReportsFolderText"
                       Height="34"
                       IsReadOnly="True"
                       Background="{DynamicResource Brush.Surface}"
                       Foreground="{DynamicResource Brush.SurfaceText}"
                       BorderThickness="0"
                       Padding="10,6"
                       Margin="0,0,0,10"/>
              <Button Style="{StaticResource Btn.Primary}"
                      Width="132"
                      Height="38"
                      HorizontalAlignment="Left"
                      Click="BtnPickReportsFolder_Click">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" Margin="0,0,7,0"/>
                  <TextBlock Text="Buscar"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </Grid>
        </Border>

        <Border Style="{StaticResource SectionCard}">
          <StackPanel>
            <TextBlock Text="{DynamicResource Settings.Sync}"
                       FontSize="19"
                       FontWeight="Bold"/>
            <TextBlock Text="{DynamicResource Settings.SyncDesc}"
                       Foreground="{DynamicResource Brush.TextDim}"
                       Margin="0,4,0,14"/>
            <UniformGrid Columns="3">
              <Button Style="{StaticResource GhostButton}" Height="58" Margin="0,0,10,0" IsEnabled="False">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                  <TextBlock Text="&#xE753;" FontFamily="Segoe MDL2 Assets" FontSize="18" Margin="0,0,8,0"/>
                  <StackPanel>
                    <TextBlock Text="{DynamicResource Settings.Cloud}" FontWeight="Bold"/>
                    <TextBlock Text="{DynamicResource Settings.Soon}" Foreground="{DynamicResource Brush.TextDim}" FontSize="12"/>
                  </StackPanel>
                </StackPanel>
              </Button>
              <Button Style="{StaticResource GhostButton}" Height="58" Margin="0,0,10,0" IsEnabled="False">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                  <TextBlock Text="G" FontWeight="Black" FontSize="20" Margin="0,0,8,0"/>
                  <StackPanel>
                    <TextBlock Text="{DynamicResource Settings.Google}" FontWeight="Bold"/>
                    <TextBlock Text="{DynamicResource Settings.Soon}" Foreground="{DynamicResource Brush.TextDim}" FontSize="12"/>
                  </StackPanel>
                </StackPanel>
              </Button>
              <Button Style="{StaticResource GhostButton}" Height="58" IsEnabled="False">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                  <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" FontSize="18" Margin="0,0,8,0"/>
                  <StackPanel>
                    <TextBlock Text="{DynamicResource Settings.Email}" FontWeight="Bold"/>
                    <TextBlock Text="{DynamicResource Settings.Soon}" Foreground="{DynamicResource Brush.TextDim}" FontSize="12"/>
                  </StackPanel>
                </StackPanel>
              </Button>
            </UniformGrid>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2"
            Background="{DynamicResource Brush.Panel}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,1,0,0"
            Padding="18">
      <DockPanel>
        <TextBlock x:Name="StatusText"
                   Text="{DynamicResource Settings.Status}"
                   Foreground="{DynamicResource Brush.TextDim}"
                   VerticalAlignment="Center"/>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <Button Content="{DynamicResource Settings.Cancel}"
                  Style="{StaticResource GhostButton}"
                  Width="110"
                  Margin="0,0,10,0"
                  Click="BtnCancel_Click"/>
          <Button Content="{DynamicResource Settings.Save}"
                  Style="{StaticResource Btn.Primary}"
                  Width="130"
                  Click="BtnSave_Click"/>
        </StackPanel>
      </DockPanel>
    </Border>
  </Grid>
</Window>



