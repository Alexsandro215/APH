<Window x:Class="Hud.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Settings.Title}"
        Height="720"
        Width="880"
        MinHeight="640"
        MinWidth="760"
        WindowStartupLocation="CenterOwner">

  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style x:Key="SectionCard" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource Brush.Card}"/>
      <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="18"/>
      <Setter Property="Margin" Value="0,0,0,14"/>
    </Style>
    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource Brush.TextDim}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Margin" Value="0,0,0,5"/>
    </Style>
    <Style x:Key="SettingsCombo" TargetType="ComboBox">
      <Setter Property="MinHeight" Value="34"/>
      <Setter Property="Foreground" Value="{DynamicResource Brush.SurfaceText}"/>
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
      <Setter Property="Padding" Value="8,4"/>
    </Style>
    <Style x:Key="GhostButton" BasedOn="{StaticResource Btn.Primary}" TargetType="Button">
      <Setter Property="Background" Value="#101820"/>
      <Setter Property="BorderBrush" Value="#324357"/>
    </Style>
  </Window.Resources>

  <Grid Background="{StaticResource Brush.Bg}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="{StaticResource Brush.Panel}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="0,0,0,1"
            Padding="22">
      <DockPanel>
        <Border DockPanel.Dock="Left"
                Width="58"
                Height="58"
                CornerRadius="29"
                Background="{DynamicResource Brush.Negative}"
                BorderBrush="{DynamicResource Brush.Surface}"
                BorderThickness="2"
                Margin="0,0,16,0">
          <TextBlock Text="&#x2660;"
                     FontFamily="Segoe UI Symbol"
                     Foreground="White"
                     FontSize="34"
                     FontWeight="Black"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="{DynamicResource Settings.Header}"
                     FontSize="28"
                     FontWeight="Black"/>
          <TextBlock Text="{DynamicResource Settings.Subtitle}"
                     Foreground="{StaticResource Brush.TextDim}"
                     Margin="0,4,0,0"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="22">
      <StackPanel>
        <Border Style="{StaticResource SectionCard}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="{DynamicResource Settings.PokerStars}"
                         FontSize="19"
                         FontWeight="Bold"/>
              <TextBlock Text="{DynamicResource Settings.PokerStarsDesc}"
                         Foreground="{StaticResource Brush.TextDim}"
                         Margin="0,4,0,12"/>
              <TextBlock Text="{DynamicResource Settings.FolderLabel}" Style="{StaticResource FieldLabel}"/>
              <TextBox x:Name="PokerStarsFolderText"
                       Height="34"
                       IsReadOnly="True"
                       Background="{DynamicResource Brush.Surface}"
                       Foreground="{DynamicResource Brush.SurfaceText}"
                       BorderThickness="0"
                       Padding="10,6"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Style="{StaticResource Btn.Primary}"
                    Width="132"
                    Height="38"
                    Margin="14,74,0,0"
                    VerticalAlignment="Top"
                    Click="BtnPickPokerStarsFolder_Click">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" Margin="0,0,7,0"/>
                    <TextBlock Text="{DynamicResource Settings.Search}"/>
              </StackPanel>
            </Button>
          </Grid>
        </Border>

        <Border Style="{StaticResource SectionCard}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1*"/>
              <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Margin="0,0,12,0">
              <TextBlock Text="{DynamicResource Settings.Language}"
                         FontSize="19"
                         FontWeight="Bold"/>
              <TextBlock Text="{DynamicResource Settings.LanguageDesc}"
                         Foreground="{StaticResource Brush.TextDim}"
                         Margin="0,4,0,12"/>
              <TextBlock Text="{DynamicResource Settings.LanguageLabel}" Style="{StaticResource FieldLabel}"/>
              <ComboBox x:Name="LanguageCombo"
                        Style="{StaticResource SettingsCombo}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="12,0,0,0">
              <TextBlock Text="{DynamicResource Settings.Palette}"
                         FontSize="19"
                         FontWeight="Bold"/>
              <TextBlock Text="{DynamicResource Settings.PaletteDesc}"
                         Foreground="{StaticResource Brush.TextDim}"
                         Margin="0,4,0,12"/>
              <TextBlock Text="{DynamicResource Settings.PaletteLabel}" Style="{StaticResource FieldLabel}"/>
              <ComboBox x:Name="PaletteCombo"
                        Style="{StaticResource SettingsCombo}"
                        DisplayMemberPath="Name"
                        SelectionChanged="PaletteCombo_SelectionChanged"/>
            </StackPanel>
          </Grid>
        </Border>

        <Border Style="{StaticResource SectionCard}">
          <StackPanel>
            <TextBlock Text="{DynamicResource Settings.PalettePreview}"
                       FontSize="19"
                       FontWeight="Bold"/>
            <TextBlock Text="{DynamicResource Settings.PalettePreviewDesc}"
                       Foreground="{StaticResource Brush.TextDim}"
                       Margin="0,4,0,12"/>
            <ItemsControl x:Name="PalettePreviewList">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <UniformGrid Columns="4"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{Binding CardBrush}"
                          BorderBrush="{Binding BorderBrush}"
                          BorderThickness="1"
                          CornerRadius="8"
                          Padding="12"
                          Margin="0,0,10,0">
                    <StackPanel>
                      <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                      <TextBlock Text="{Binding Description}" Foreground="{StaticResource Brush.TextDim}" FontSize="12" Margin="0,4,0,10"/>
                      <StackPanel Orientation="Horizontal">
                        <Border Width="22" Height="22" CornerRadius="4" Background="{Binding AccentBrush}" Margin="0,0,5,0"/>
                        <Border Width="22" Height="22" CornerRadius="4" Background="{Binding SecondaryBrush}" Margin="0,0,5,0"/>
                        <Border Width="22" Height="22" CornerRadius="4" Background="{Binding DangerBrush}" Margin="0,0,5,0"/>
                        <Border Width="22" Height="22" CornerRadius="4" Background="{Binding GoldBrush}"/>
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionCard}">
          <StackPanel>
            <TextBlock Text="{DynamicResource Settings.Sync}"
                       FontSize="19"
                       FontWeight="Bold"/>
            <TextBlock Text="{DynamicResource Settings.SyncDesc}"
                       Foreground="{StaticResource Brush.TextDim}"
                       Margin="0,4,0,14"/>
            <UniformGrid Columns="3">
              <Button Style="{StaticResource GhostButton}" Height="58" Margin="0,0,10,0" IsEnabled="False">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                  <TextBlock Text="&#xE753;" FontFamily="Segoe MDL2 Assets" FontSize="18" Margin="0,0,8,0"/>
                  <StackPanel>
                    <TextBlock Text="{DynamicResource Settings.Cloud}" FontWeight="Bold"/>
                    <TextBlock Text="{DynamicResource Settings.Soon}" Foreground="{StaticResource Brush.TextDim}" FontSize="12"/>
                  </StackPanel>
                </StackPanel>
              </Button>
              <Button Style="{StaticResource GhostButton}" Height="58" Margin="0,0,10,0" IsEnabled="False">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                  <TextBlock Text="G" FontWeight="Black" FontSize="20" Margin="0,0,8,0"/>
                  <StackPanel>
                    <TextBlock Text="{DynamicResource Settings.Google}" FontWeight="Bold"/>
                    <TextBlock Text="{DynamicResource Settings.Soon}" Foreground="{StaticResource Brush.TextDim}" FontSize="12"/>
                  </StackPanel>
                </StackPanel>
              </Button>
              <Button Style="{StaticResource GhostButton}" Height="58" IsEnabled="False">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                  <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" FontSize="18" Margin="0,0,8,0"/>
                  <StackPanel>
                    <TextBlock Text="{DynamicResource Settings.Email}" FontWeight="Bold"/>
                    <TextBlock Text="{DynamicResource Settings.Soon}" Foreground="{StaticResource Brush.TextDim}" FontSize="12"/>
                  </StackPanel>
                </StackPanel>
              </Button>
            </UniformGrid>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2"
            Background="{StaticResource Brush.Panel}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="0,1,0,0"
            Padding="18">
      <DockPanel>
        <TextBlock x:Name="StatusText"
                   Text="{DynamicResource Settings.Status}"
                   Foreground="{StaticResource Brush.TextDim}"
                   VerticalAlignment="Center"/>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <Button Content="{DynamicResource Settings.Cancel}"
                  Style="{StaticResource GhostButton}"
                  Width="110"
                  Margin="0,0,10,0"
                  Click="BtnCancel_Click"/>
          <Button Content="{DynamicResource Settings.Save}"
                  Style="{StaticResource Btn.Primary}"
                  Width="130"
                  Click="BtnSave_Click"/>
        </StackPanel>
      </DockPanel>
    </Border>
  </Grid>
</Window>



