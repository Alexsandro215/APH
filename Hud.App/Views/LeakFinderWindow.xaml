<Window x:Class="Hud.App.Views.LeakFinderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="APH - Detector de leaks"
        Height="860"
        Width="1420"
        MinHeight="720"
        MinWidth="1180"
        Background="{StaticResource Brush.Bg}"
        WindowStartupLocation="CenterOwner">

  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style TargetType="DataGrid">
      <Setter Property="Background" Value="#101720"/>
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
      <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
      <Setter Property="GridLinesVisibility" Value="Horizontal"/>
      <Setter Property="HorizontalGridLinesBrush" Value="#223244"/>
      <Setter Property="RowBackground" Value="#101720"/>
      <Setter Property="AlternatingRowBackground" Value="#141C26"/>
      <Setter Property="HeadersVisibility" Value="Column"/>
      <Setter Property="CanUserAddRows" Value="False"/>
      <Setter Property="CanUserDeleteRows" Value="False"/>
      <Setter Property="CanUserResizeRows" Value="False"/>
      <Setter Property="IsReadOnly" Value="True"/>
      <Setter Property="AutoGenerateColumns" Value="False"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="#E9EEF3"/>
      <Setter Property="Foreground" Value="Black"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Padding" Value="6,4"/>
    </Style>

    <Style TargetType="DataGridCell">
      <Setter Property="BorderBrush" Value="#223244"/>
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
      <Setter Property="Padding" Value="6,2"/>
    </Style>

    <Style x:Key="PanelBorder" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource Brush.Card}"/>
      <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="14"/>
    </Style>

    <DataTemplate x:Key="TotalBbCellTemplate">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <TextBlock Text="{Binding TotalBbTrendIcon}" Foreground="{Binding TotalBbTrendBrush}" FontWeight="Bold" Margin="0,0,4,0"/>
        <TextBlock Text="{Binding TotalBbLabel}" TextWrapping="NoWrap"/>
      </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="AverageBbCellTemplate">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <TextBlock Text="{Binding AverageBbTrendIcon}" Foreground="{Binding AverageBbTrendBrush}" FontWeight="Bold" Margin="0,0,4,0"/>
        <TextBlock Text="{Binding AverageBbLabel}" TextWrapping="NoWrap"/>
      </StackPanel>
    </DataTemplate>
  </Window.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="260"/>
    </Grid.RowDefinitions>

    <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,12" Padding="18">
      <StackPanel HorizontalAlignment="Center">
        <TextBlock Text="DETECTOR DE LEAKS" FontSize="26" FontWeight="Bold" TextAlignment="Center"/>
        <TextBlock Text="{Binding Summary}" Foreground="{StaticResource Brush.TextDim}" Margin="0,6,0,0" TextAlignment="Center"/>
      </StackPanel>
    </Border>

    <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
      <UniformGrid Columns="5">
        <StackPanel Margin="8">
          <TextBlock Text="Mesas cargadas" Foreground="{StaticResource Brush.TextDim}"/>
          <TextBlock Text="{Binding TableCount}" FontSize="23" FontWeight="Bold"/>
        </StackPanel>
        <StackPanel Margin="8">
          <TextBlock Text="Manos analizadas" Foreground="{StaticResource Brush.TextDim}"/>
          <TextBlock Text="{Binding HeroHands}" FontSize="23" FontWeight="Bold"/>
        </StackPanel>
        <StackPanel Margin="8">
          <TextBlock Text="Resultado total" Foreground="{StaticResource Brush.TextDim}"/>
          <TextBlock Text="{Binding TotalBbLabel}" FontSize="23" FontWeight="Bold" Foreground="{Binding TotalBbBrush}"/>
        </StackPanel>
        <StackPanel Margin="8">
          <TextBlock Text="Mayor fuga" Foreground="{StaticResource Brush.TextDim}"/>
          <TextBlock Text="{Binding BiggestLeakLabel}" FontSize="23" FontWeight="Bold" Foreground="#FF6B7A"/>
        </StackPanel>
        <StackPanel Margin="8">
          <TextBlock Text="Manos criticas" Foreground="{StaticResource Brush.TextDim}"/>
          <TextBlock Text="{Binding CriticalHands}" FontSize="23" FontWeight="Bold"/>
        </StackPanel>
      </UniformGrid>
    </Border>

    <Grid Grid.Row="2" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1.05*"/>
        <ColumnDefinition Width="1.05*"/>
        <ColumnDefinition Width="1.1*"/>
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,8">
        <DockPanel>
          <TextBlock Text="PERDIDAS POR POSICION" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,8"/>
          <DataGrid ItemsSource="{Binding PositionLeaks}" MouseDoubleClick="LeakGrid_MouseDoubleClick">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Pos" Binding="{Binding Key}" Width="60"/>
              <DataGridTextColumn Header="Manos" Binding="{Binding Count}" Width="70"/>
              <DataGridTemplateColumn Header="BB" CellTemplate="{StaticResource TotalBbCellTemplate}" Width="80"/>
              <DataGridTemplateColumn Header="Media" CellTemplate="{StaticResource AverageBbCellTemplate}" Width="80"/>
              <DataGridTextColumn Header="Peor mano" Binding="{Binding WorstCombo}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <Border Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="8,0,8,8">
        <DockPanel>
          <TextBlock Text="EV REAL POR ACCION" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,8"/>
          <DataGrid ItemsSource="{Binding ActionLeaks}" MouseDoubleClick="LeakGrid_MouseDoubleClick">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Accion" Binding="{Binding Key}" Width="90"/>
              <DataGridTextColumn Header="Manos" Binding="{Binding Count}" Width="70"/>
              <DataGridTemplateColumn Header="BB" CellTemplate="{StaticResource TotalBbCellTemplate}" Width="80"/>
              <DataGridTemplateColumn Header="Media" CellTemplate="{StaticResource AverageBbCellTemplate}" Width="80"/>
              <DataGridTextColumn Header="Peor spot" Binding="{Binding WorstCombo}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Margin="8,0,0,8">
        <DockPanel>
          <TextBlock Text="TIPO DE BOTE" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,8"/>
          <DataGrid ItemsSource="{Binding PotLeaks}" MouseDoubleClick="LeakGrid_MouseDoubleClick">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Bote" Binding="{Binding Key}" Width="*"/>
              <DataGridTextColumn Header="Manos" Binding="{Binding Count}" Width="70"/>
              <DataGridTemplateColumn Header="BB" CellTemplate="{StaticResource TotalBbCellTemplate}" Width="80"/>
              <DataGridTemplateColumn Header="Media" CellTemplate="{StaticResource AverageBbCellTemplate}" Width="80"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Margin="0,8,8,0">
        <DockPanel>
          <TextBlock Text="MANOS PROBLEMATICAS" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,8"/>
          <DataGrid ItemsSource="{Binding ComboLeaks}" MouseDoubleClick="LeakGrid_MouseDoubleClick">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Mano" Binding="{Binding Key}" Width="70"/>
              <DataGridTextColumn Header="Manos" Binding="{Binding Count}" Width="70"/>
              <DataGridTemplateColumn Header="BB" CellTemplate="{StaticResource TotalBbCellTemplate}" Width="80"/>
              <DataGridTemplateColumn Header="Media" CellTemplate="{StaticResource AverageBbCellTemplate}" Width="80"/>
              <DataGridTextColumn Header="Accion" Binding="{Binding WorstAction}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="8,8,8,0">
        <DockPanel>
          <TextBlock Text="BOARD TEXTURE" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,8"/>
          <DataGrid ItemsSource="{Binding BoardLeaks}" MouseDoubleClick="LeakGrid_MouseDoubleClick">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Textura" Binding="{Binding Key}" Width="*"/>
              <DataGridTextColumn Header="Manos" Binding="{Binding Count}" Width="70"/>
              <DataGridTemplateColumn Header="BB" CellTemplate="{StaticResource TotalBbCellTemplate}" Width="80"/>
              <DataGridTemplateColumn Header="Media" CellTemplate="{StaticResource AverageBbCellTemplate}" Width="80"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource PanelBorder}" Margin="8,8,0,0">
        <DockPanel>
          <TextBlock Text="COMPARAR SESIONES" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,8"/>
          <DataGrid ItemsSource="{Binding SessionLeaks}" MouseDoubleClick="LeakGrid_MouseDoubleClick">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Fecha" Binding="{Binding Key}" Width="110"/>
              <DataGridTextColumn Header="Mesas" Binding="{Binding Count}" Width="70"/>
              <DataGridTemplateColumn Header="BB" CellTemplate="{StaticResource TotalBbCellTemplate}" Width="80"/>
              <DataGridTemplateColumn Header="Media" CellTemplate="{StaticResource AverageBbCellTemplate}" Width="80"/>
              <DataGridTextColumn Header="Nota" Binding="{Binding WorstCombo}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>
    </Grid>

    <Border Grid.Row="3" Style="{StaticResource PanelBorder}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,10">
          <Button Content="Ver todo"
                  DockPanel.Dock="Right"
                  Width="120"
                  Height="34"
                  FontWeight="Bold"
                  Foreground="Black"
                  Click="BtnViewAllReview_Click"/>
          <StackPanel>
            <TextBlock Text="MANOS PARA REVISAR" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="{Binding ReviewSummary}" Foreground="{StaticResource Brush.TextDim}" Margin="0,4,0,0"/>
          </StackPanel>
        </DockPanel>

        <UniformGrid Grid.Row="1" Columns="4">
          <Border Background="#101720" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="6">
            <StackPanel>
              <TextBlock Text="Peor mano" Foreground="{StaticResource Brush.TextDim}"/>
              <TextBlock Text="{Binding WorstReviewHandLabel}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
            </StackPanel>
          </Border>
          <Border Background="#101720" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="6">
            <StackPanel>
              <TextBlock Text="Accion mas cara" Foreground="{StaticResource Brush.TextDim}"/>
              <TextBlock Text="{Binding WorstReviewActionLabel}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
            </StackPanel>
          </Border>
          <Border Background="#101720" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="6">
            <StackPanel>
              <TextBlock Text="Bote mas caro" Foreground="{StaticResource Brush.TextDim}"/>
              <TextBlock Text="{Binding WorstReviewPotLabel}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
            </StackPanel>
          </Border>
          <Border Background="#101720" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="6">
            <StackPanel>
              <TextBlock Text="Muestra" Foreground="{StaticResource Brush.TextDim}"/>
              <TextBlock Text="{Binding ReviewCountLabel}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
            </StackPanel>
          </Border>
        </UniformGrid>
      </Grid>
    </Border>
  </Grid>
</Window>
