<Window x:Class="Hud.App.Views.LeakFinderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Common.LeakFinderTitle}"
        Height="860"
        Width="1420"
        MinHeight="720"
        MinWidth="1180"
        Background="{DynamicResource Brush.Bg}"
        WindowStartupLocation="CenterOwner">

  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style TargetType="DataGrid">
      <Setter Property="Background" Value="{DynamicResource Brush.Inset}"/>
      <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
      <Setter Property="GridLinesVisibility" Value="Horizontal"/>
      <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Brush.Border}"/>
      <Setter Property="RowBackground" Value="{DynamicResource Brush.Inset}"/>
      <Setter Property="AlternatingRowBackground" Value="{DynamicResource Brush.Card}"/>
      <Setter Property="HeadersVisibility" Value="Column"/>
      <Setter Property="CanUserAddRows" Value="False"/>
      <Setter Property="CanUserDeleteRows" Value="False"/>
      <Setter Property="CanUserResizeRows" Value="False"/>
      <Setter Property="IsReadOnly" Value="True"/>
      <Setter Property="AutoGenerateColumns" Value="False"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="{DynamicResource Brush.Header}"/>
      <Setter Property="Foreground" Value="{StaticResource FgLight}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Padding" Value="6,4"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.HeaderBorder}"/>
      <Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>

    <Style TargetType="DataGridCell">
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
      <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
      <Setter Property="Padding" Value="6,2"/>
    </Style>

    <Style x:Key="PanelBorder" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="14"/>
    </Style>

    <DataTemplate x:Key="TotalBbCellTemplate">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <TextBlock Text="{Binding TotalBbTrendIcon}" Foreground="{Binding TotalBbTrendBrush}" FontWeight="Bold" Margin="0,0,4,0"/>
        <TextBlock Text="{Binding TotalBbLabel}" TextWrapping="NoWrap"/>
      </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="AverageBbCellTemplate">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <TextBlock Text="{Binding AverageBbTrendIcon}" Foreground="{Binding AverageBbTrendBrush}" FontWeight="Bold" Margin="0,0,4,0"/>
        <TextBlock Text="{Binding AverageBbLabel}" TextWrapping="NoWrap"/>
      </StackPanel>
    </DataTemplate>
  </Window.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="260"/>
    </Grid.RowDefinitions>

    <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,12" Padding="18">
      <StackPanel HorizontalAlignment="Center">
        <TextBlock Text="DETECTOR DE LEAKS" FontSize="26" FontWeight="Bold" TextAlignment="Center"/>
        <TextBlock Text="{Binding Summary}" Foreground="{DynamicResource Brush.TextDim}" Margin="0,6,0,0" TextAlignment="Center"/>
      </StackPanel>
    </Border>

    <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
      <UniformGrid Columns="5">
        <StackPanel Margin="8">
          <TextBlock Text="{DynamicResource Common.LoadedTables}" Foreground="{DynamicResource Brush.TextDim}"/>
          <TextBlock Text="{Binding TableCount}" FontSize="23" FontWeight="Bold"/>
        </StackPanel>
        <StackPanel Margin="8">
          <TextBlock Text="{DynamicResource Common.AnalyzedHands}" Foreground="{DynamicResource Brush.TextDim}"/>
          <TextBlock Text="{Binding HeroHands}" FontSize="23" FontWeight="Bold"/>
        </StackPanel>
        <StackPanel Margin="8">
          <TextBlock Text="{DynamicResource Common.TotalResult}" Foreground="{DynamicResource Brush.TextDim}"/>
          <TextBlock Text="{Binding TotalBbLabel}" FontSize="23" FontWeight="Bold" Foreground="{Binding TotalBbBrush}"/>
        </StackPanel>
        <StackPanel Margin="8">
          <TextBlock Text="{DynamicResource Common.BiggestLeak}" Foreground="{DynamicResource Brush.TextDim}"/>
          <TextBlock Text="{Binding BiggestLeakLabel}" FontSize="23" FontWeight="Bold" Foreground="{DynamicResource Brush.Negative}"/>
        </StackPanel>
        <StackPanel Margin="8">
          <TextBlock Text="{DynamicResource Common.CriticalHands}" Foreground="{DynamicResource Brush.TextDim}"/>
          <TextBlock Text="{Binding CriticalHands}" FontSize="23" FontWeight="Bold"/>
        </StackPanel>
      </UniformGrid>
    </Border>

    <Grid Grid.Row="2" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1.05*"/>
        <ColumnDefinition Width="1.05*"/>
        <ColumnDefinition Width="1.1*"/>
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,8">
        <DockPanel>
          <TextBlock Text="{DynamicResource Common.PositionLosses}" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,8"/>
          <DataGrid ItemsSource="{Binding PositionLeaks}" MouseDoubleClick="LeakGrid_MouseDoubleClick">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Pos" Binding="{Binding Key}" Width="60"/>
              <DataGridTextColumn Header="{DynamicResource Common.Hands}" Binding="{Binding Count}" Width="70"/>
              <DataGridTemplateColumn Header="BB" CellTemplate="{StaticResource TotalBbCellTemplate}" Width="80"/>
              <DataGridTemplateColumn Header="{DynamicResource Common.Average}" CellTemplate="{StaticResource AverageBbCellTemplate}" Width="80"/>
              <DataGridTextColumn Header="{DynamicResource Common.WorstHand}" Binding="{Binding WorstCombo}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <Border Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="8,0,8,8">
        <DockPanel>
          <TextBlock Text="{DynamicResource Common.RealEvByAction}" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,8"/>
          <DataGrid ItemsSource="{Binding ActionLeaks}" MouseDoubleClick="LeakGrid_MouseDoubleClick">
            <DataGrid.Columns>
              <DataGridTextColumn Header="{DynamicResource Common.Action}" Binding="{Binding Key}" Width="90"/>
              <DataGridTextColumn Header="{DynamicResource Common.Hands}" Binding="{Binding Count}" Width="70"/>
              <DataGridTemplateColumn Header="BB" CellTemplate="{StaticResource TotalBbCellTemplate}" Width="80"/>
              <DataGridTemplateColumn Header="{DynamicResource Common.Average}" CellTemplate="{StaticResource AverageBbCellTemplate}" Width="80"/>
              <DataGridTextColumn Header="{DynamicResource Common.WorstSpot}" Binding="{Binding WorstCombo}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Margin="8,0,0,8">
        <DockPanel>
          <TextBlock Text="{DynamicResource Common.PotType}" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,8"/>
          <DataGrid ItemsSource="{Binding PotLeaks}" MouseDoubleClick="LeakGrid_MouseDoubleClick">
            <DataGrid.Columns>
              <DataGridTextColumn Header="{DynamicResource Common.Pot}" Binding="{Binding Key}" Width="*"/>
              <DataGridTextColumn Header="{DynamicResource Common.Hands}" Binding="{Binding Count}" Width="70"/>
              <DataGridTemplateColumn Header="BB" CellTemplate="{StaticResource TotalBbCellTemplate}" Width="80"/>
              <DataGridTemplateColumn Header="{DynamicResource Common.Average}" CellTemplate="{StaticResource AverageBbCellTemplate}" Width="80"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Margin="0,8,8,0">
        <DockPanel>
          <TextBlock Text="{DynamicResource Common.ProblemHands}" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,8"/>
          <DataGrid ItemsSource="{Binding ComboLeaks}" MouseDoubleClick="LeakGrid_MouseDoubleClick">
            <DataGrid.Columns>
              <DataGridTextColumn Header="{DynamicResource Common.Cards}" Binding="{Binding Key}" Width="70"/>
              <DataGridTextColumn Header="{DynamicResource Common.Hands}" Binding="{Binding Count}" Width="70"/>
              <DataGridTemplateColumn Header="BB" CellTemplate="{StaticResource TotalBbCellTemplate}" Width="80"/>
              <DataGridTemplateColumn Header="{DynamicResource Common.Average}" CellTemplate="{StaticResource AverageBbCellTemplate}" Width="80"/>
              <DataGridTextColumn Header="{DynamicResource Common.Action}" Binding="{Binding WorstAction}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="8,8,8,0">
        <DockPanel>
          <TextBlock Text="{DynamicResource Common.BoardTexture}" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,8"/>
          <DataGrid ItemsSource="{Binding BoardLeaks}" MouseDoubleClick="LeakGrid_MouseDoubleClick">
            <DataGrid.Columns>
              <DataGridTextColumn Header="{DynamicResource Common.Texture}" Binding="{Binding Key}" Width="*"/>
              <DataGridTextColumn Header="{DynamicResource Common.Hands}" Binding="{Binding Count}" Width="70"/>
              <DataGridTemplateColumn Header="BB" CellTemplate="{StaticResource TotalBbCellTemplate}" Width="80"/>
              <DataGridTemplateColumn Header="{DynamicResource Common.Average}" CellTemplate="{StaticResource AverageBbCellTemplate}" Width="80"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource PanelBorder}" Margin="8,8,0,0">
        <DockPanel>
          <TextBlock Text="{DynamicResource Common.CompareSessions}" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,8"/>
          <DataGrid ItemsSource="{Binding SessionLeaks}" MouseDoubleClick="LeakGrid_MouseDoubleClick">
            <DataGrid.Columns>
              <DataGridTextColumn Header="{DynamicResource Grid.Date}" Binding="{Binding Key}" Width="110"/>
              <DataGridTextColumn Header="{DynamicResource Grid.Table}" Binding="{Binding Count}" Width="70"/>
              <DataGridTemplateColumn Header="BB" CellTemplate="{StaticResource TotalBbCellTemplate}" Width="80"/>
              <DataGridTemplateColumn Header="{DynamicResource Common.Average}" CellTemplate="{StaticResource AverageBbCellTemplate}" Width="80"/>
              <DataGridTextColumn Header="{DynamicResource Common.Note}" Binding="{Binding WorstCombo}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>
    </Grid>

    <Border Grid.Row="3" Style="{StaticResource PanelBorder}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,10">
          <Button Content="{DynamicResource Common.ViewAll}"
                  DockPanel.Dock="Right"
                  Width="120"
                  Height="34"
                  FontWeight="Bold"
                  Foreground="{DynamicResource Brush.SurfaceText}"
                  Click="BtnViewAllReview_Click"/>
          <StackPanel>
            <TextBlock Text="{DynamicResource Common.ReviewHands}" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="{Binding ReviewSummary}" Foreground="{DynamicResource Brush.TextDim}" Margin="0,4,0,0"/>
          </StackPanel>
        </DockPanel>

        <UniformGrid Grid.Row="1" Columns="4">
          <Border Background="{DynamicResource Brush.Inset}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="6">
            <StackPanel>
              <TextBlock Text="{DynamicResource Common.WorstHand}" Foreground="{DynamicResource Brush.TextDim}"/>
              <TextBlock Text="{Binding WorstReviewHandLabel}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
            </StackPanel>
          </Border>
          <Border Background="{DynamicResource Brush.Inset}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="6">
            <StackPanel>
              <TextBlock Text="{DynamicResource Common.MostExpensiveAction}" Foreground="{DynamicResource Brush.TextDim}"/>
              <TextBlock Text="{Binding WorstReviewActionLabel}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
            </StackPanel>
          </Border>
          <Border Background="{DynamicResource Brush.Inset}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="6">
            <StackPanel>
              <TextBlock Text="{DynamicResource Common.MostExpensivePot}" Foreground="{DynamicResource Brush.TextDim}"/>
              <TextBlock Text="{Binding WorstReviewPotLabel}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
            </StackPanel>
          </Border>
          <Border Background="{DynamicResource Brush.Inset}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="6">
            <StackPanel>
              <TextBlock Text="{DynamicResource Common.Sample}" Foreground="{DynamicResource Brush.TextDim}"/>
              <TextBlock Text="{Binding ReviewCountLabel}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
            </StackPanel>
          </Border>
        </UniformGrid>
      </Grid>
    </Border>
  </Grid>
</Window>



