<Window x:Class="Hud.App.Views.RealTimeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Hud.App.Views"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        Title="APH — Tiempo real (8)"
        Height="800" Width="680" WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.Bg}">

  <!-- Recurso de escala global -->
  <Window.Resources>
    <system:Double x:Key="GlobalScale">0.80</system:Double>
  </Window.Resources>

  <!-- ✅ Grid raíz para poder tener el ScrollViewer y el Label ScaleProxy como hijos -->
  <Grid>

    <!-- Contenido original dentro del ScrollViewer -->
    <ScrollViewer VerticalScrollBarVisibility="Disabled"
                  HorizontalScrollBarVisibility="Disabled">

      <!-- Envoltura con LayoutTransform; dentro conservamos tu StackPanel original -->
      <Border>
        <Border.LayoutTransform>
          <ScaleTransform x:Name="RootScale"
                          ScaleX="{Binding ElementName=ScaleProxy, Path=Tag}"
                          ScaleY="{Binding ElementName=ScaleProxy, Path=Tag}"/>
        </Border.LayoutTransform>

        <!-- *** CONTENIDO ORIGINAL *** -->
        <StackPanel Margin="16">

          <!-- Toggle modo compacto -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <CheckBox x:Name="ChkCompact" Content="Modo compacto" IsChecked="True" VerticalAlignment="Center"/>
            <TextBlock Text="   " Width="8"/>
            <TextBlock Text="(reduce tamaños y escala para mostrar todo sin desplazamiento)"
                       Foreground="{StaticResource Brush.TextDim}" VerticalAlignment="Center"/>
          </StackPanel>

          <TextBlock Text="Tiempo real — 8 mesas" FontSize="22" FontWeight="Bold" Margin="0,0,0,12"/>
          <TextBlock Text="Pulsa ＋ para seleccionar el .txt de la mesa. Usa ⏹ para detener."
                     Foreground="{StaticResource Brush.TextDim}" Margin="0,0,0,16"/>

          <StackPanel>
            <local:SlotTail Margin="0,0,0,6"/>
            <local:SlotTail Margin="0,0,0,6"/>
            <local:SlotTail Margin="0,0,0,6"/>
            <local:SlotTail Margin="0,0,0,6"/>
            <local:SlotTail Margin="0,0,0,6"/>
            <local:SlotTail Margin="0,0,0,6"/>
            <local:SlotTail Margin="0,0,0,6"/>
            <local:SlotTail Margin="0,0,0,0"/>
          </StackPanel>
        </StackPanel>
        <!-- *** FIN CONTENIDO ORIGINAL *** -->
      </Border>
    </ScrollViewer>

    <!-- ✅ Proxy oculto para alternar la escala desde code-behind -->
    <Label x:Name="ScaleProxy" Visibility="Collapsed" Tag="{StaticResource GlobalScale}"/>
  </Grid>
</Window>
