<Window x:Class="Hud.App.Views.RealTimeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Hud.App.Views"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        Title="{DynamicResource RT.Title}"
        Height="800" Width="680" MinHeight="520" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.AppShell}">

  <Window.Resources>
    <system:Double x:Key="GlobalScale">0.80</system:Double>

    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource Brush.SurfaceText}"/>
    </Style>

    <Style TargetType="CheckBox">
      <Setter Property="Foreground" Value="{DynamicResource Brush.SurfaceText}"/>
    </Style>
  </Window.Resources>

  <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Visible"
                  HorizontalScrollBarVisibility="Disabled">
      <Border>
        <Border.LayoutTransform>
          <ScaleTransform x:Name="RootScale"
                          ScaleX="{Binding ElementName=ScaleProxy, Path=Tag}"
                          ScaleY="{Binding ElementName=ScaleProxy, Path=Tag}"/>
        </Border.LayoutTransform>

        <StackPanel Margin="16">
          <Button HorizontalAlignment="Right"
                  Width="34"
                  Height="34"
                  Padding="0"
                  Content="?"
                  FontSize="18"
                  FontWeight="Bold"
                  Foreground="{DynamicResource Brush.SurfaceText}"
                  Click="BtnDictionary_Click"
                  ToolTip="{DynamicResource RT.HelpTip}"
                  Margin="0,0,0,6"/>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <CheckBox x:Name="ChkCompact" IsChecked="True" VerticalAlignment="Center">
              <TextBlock Text="{DynamicResource RT.Compact}"
                         Foreground="{DynamicResource Brush.SurfaceText}"/>
            </CheckBox>
            <TextBlock Text="   " Width="8"/>
            <TextBlock Text="{DynamicResource RT.CompactDesc}"
                       Foreground="{DynamicResource Brush.TextDim}" VerticalAlignment="Center"/>
          </StackPanel>

          <DockPanel Margin="0,0,0,8">
            <TextBlock Text="{DynamicResource RT.Header}"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{DynamicResource Brush.SurfaceText}"
                       VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
              <Button Content="{DynamicResource RT.FinishSession}"
                      Padding="12,6"
                      Margin="0,0,8,0"
                      Click="BtnFinishSession_Click"/>
              <Button Content="{DynamicResource RT.Detect}"
                      Padding="12,6"
                      Click="BtnDetectTables_Click"/>
            </StackPanel>
          </DockPanel>
          <TextBlock x:Name="DetectionStatusText"
                     Text="{DynamicResource RT.DetectHint}"
                     Foreground="{DynamicResource Brush.TextDim}" Margin="0,0,0,16"/>

          <StackPanel>
            <local:SlotTail x:Name="Slot1" Margin="0,0,0,6"/>
            <local:SlotTail x:Name="Slot2" Margin="0,0,0,6"/>
            <local:SlotTail x:Name="Slot3" Margin="0,0,0,6"/>
            <local:SlotTail x:Name="Slot4" Margin="0,0,0,6"/>
            <local:SlotTail x:Name="Slot5" Margin="0,0,0,6"/>
            <local:SlotTail x:Name="Slot6" Margin="0,0,0,6"/>
            <local:SlotTail x:Name="Slot7" Margin="0,0,0,6"/>
            <local:SlotTail x:Name="Slot8" Margin="0,0,0,0"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </ScrollViewer>

    <Label x:Name="ScaleProxy" Visibility="Collapsed" Tag="{StaticResource GlobalScale}"/>
  </Grid>
</Window>



