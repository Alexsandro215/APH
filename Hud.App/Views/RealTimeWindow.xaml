<Window x:Class="Hud.App.Views.RealTimeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Hud.App.Views"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        Title="APH &#x2014; Tiempo real (8)"
        Height="800" Width="680" WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.Bg}">

  <Window.Resources>
    <system:Double x:Key="GlobalScale">0.80</system:Double>
  </Window.Resources>

  <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Disabled"
                  HorizontalScrollBarVisibility="Disabled">
      <Border>
        <Border.LayoutTransform>
          <ScaleTransform x:Name="RootScale"
                          ScaleX="{Binding ElementName=ScaleProxy, Path=Tag}"
                          ScaleY="{Binding ElementName=ScaleProxy, Path=Tag}"/>
        </Border.LayoutTransform>

        <StackPanel Margin="16">
          <Button HorizontalAlignment="Right"
                  Width="34"
                  Height="34"
                  Padding="0"
                  Content="?"
                  FontSize="18"
                  FontWeight="Bold"
                  Foreground="Black"
                  Click="BtnDictionary_Click"
                  ToolTip="Abrir ayuda de Tiempo real"
                  Margin="0,0,0,6"/>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <CheckBox x:Name="ChkCompact" Content="Modo compacto" IsChecked="True" VerticalAlignment="Center"/>
            <TextBlock Text="   " Width="8"/>
            <TextBlock Text="(reduce tamaños y escala para mostrar todo sin desplazamiento)"
                       Foreground="{StaticResource Brush.TextDim}" VerticalAlignment="Center"/>
          </StackPanel>

          <DockPanel Margin="0,0,0,8">
            <TextBlock Text="Tiempo real &#x2014; 8 mesas"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
            <Button DockPanel.Dock="Right"
                    Content="Detectar mesas"
                    Padding="12,6"
                    Click="BtnDetectTables_Click"/>
          </DockPanel>
          <TextBlock x:Name="DetectionStatusText"
                     Text="Pulsa Detectar mesas para enlazar ventanas PokerStars con sus historiales. Tambien puedes usar + manualmente."
                     Foreground="{StaticResource Brush.TextDim}" Margin="0,0,0,16"/>

          <StackPanel>
            <local:SlotTail x:Name="Slot1" Margin="0,0,0,6"/>
            <local:SlotTail x:Name="Slot2" Margin="0,0,0,6"/>
            <local:SlotTail x:Name="Slot3" Margin="0,0,0,6"/>
            <local:SlotTail x:Name="Slot4" Margin="0,0,0,6"/>
            <local:SlotTail x:Name="Slot5" Margin="0,0,0,6"/>
            <local:SlotTail x:Name="Slot6" Margin="0,0,0,6"/>
            <local:SlotTail x:Name="Slot7" Margin="0,0,0,6"/>
            <local:SlotTail x:Name="Slot8" Margin="0,0,0,0"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </ScrollViewer>

    <Label x:Name="ScaleProxy" Visibility="Collapsed" Tag="{StaticResource GlobalScale}"/>
  </Grid>
</Window>
