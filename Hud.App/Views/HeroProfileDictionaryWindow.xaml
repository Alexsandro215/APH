<Window x:Class="Hud.App.Views.HeroProfileDictionaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Common.ProfileDictionaryTitle}"
        Height="760"
        Width="1180"
        MinHeight="640"
        MinWidth="980"
        Background="{DynamicResource Brush.Bg}"
        WindowStartupLocation="CenterOwner">

  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="PanelBorder" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="14"/>
    </Style>
  </Window.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
      <StackPanel>
        <TextBlock Text="{DynamicResource Common.ProfileDictionaryHeader}" FontSize="24" FontWeight="Bold" TextAlignment="Center"/>
        <TextBlock Text="{DynamicResource Common.DictionarySubtitleProfile}" Foreground="{DynamicResource Brush.TextDim}" Margin="0,4,0,0" TextAlignment="Center"/>
      </StackPanel>
    </Border>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1.15*"/>
        <ColumnDefinition Width="0.85*"/>
      </Grid.ColumnDefinitions>

      <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
        <DockPanel>
          <TextBlock Text="{DynamicResource Common.Tags}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,10"/>
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Tags}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{DynamicResource Brush.Inset}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <Border Background="{Binding Background}" BorderBrush="{Binding Border}" BorderThickness="1" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal">
                          <ContentControl Content="{Binding CardChips}" ContentTemplate="{StaticResource CardChipListTemplate}" Margin="0,0,5,0"/>
                          <TextBlock Text="{Binding Text}" Foreground="{Binding Foreground}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                      </Border>
                      <TextBlock Grid.Column="1" Text="{Binding Description}" Foreground="{DynamicResource Brush.Text}" Margin="12,2,0,0"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <Grid Grid.Column="1" Margin="8,0,0,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
          <StackPanel>
            <TextBlock Text="{DynamicResource Common.MetricColors}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <ItemsControl ItemsSource="{Binding ColorRows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="34"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="24" Height="18" Background="{Binding Brush}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="3"/>
                    <StackPanel Grid.Column="1">
                      <TextBlock Text="{Binding Label}" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}"/>
                      <TextBlock Text="{Binding Description}" Foreground="{DynamicResource Brush.TextDim}" FontSize="12"/>
                    </StackPanel>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelBorder}">
          <DockPanel>
            <TextBlock Text="{DynamicResource Common.StatMeaning}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,10"/>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding MetricRows}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{DynamicResource Brush.Inset}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="6" Padding="9" Margin="0,0,0,8">
                      <StackPanel>
                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}"/>
                        <TextBlock Text="{Binding Description}" Foreground="{DynamicResource Brush.TextDim}" Margin="0,2,0,0"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </DockPanel>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Window>




