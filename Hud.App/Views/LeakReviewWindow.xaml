<Window x:Class="Hud.App.Views.LeakReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Hud.App.Views"
        Title="APH - Analizador de Fugas (Coach)"
        Height="820"
        Width="1420"
        MinHeight="720"
        MinWidth="1180"
        Background="{DynamicResource Brush.Bg}"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <views:PercentToGridLengthConverter x:Key="PercentToGrid"/>
        <views:SeatXConverter x:Key="SeatX"/>
        <views:SeatYConverter x:Key="SeatY"/>
        <views:StatToBrushConverter x:Key="StatToBrush"/>
        <views:StatTextBrushConverter x:Key="StatTextBrush"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextDim}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource FgLight}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="InfoCell" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="HandListItem" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource FgLight}"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Inset}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}"/>
                    <Setter Property="BorderThickness" Value="2,0,0,1"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="ActionVisualPartTemplate">
            <Grid VerticalAlignment="Center">
                <TextBlock Text="{Binding Text}"
                           Foreground="{Binding Foreground}"
                           FontWeight="{Binding FontWeight}"
                           Visibility="{Binding IsText, Converter={StaticResource BoolToVisibility}}"/>
                <ContentControl Content="{Binding CardChips}"
                                ContentTemplate="{StaticResource CardChipListTemplate}"
                                Visibility="{Binding IsCards, Converter={StaticResource BoolToVisibility}}"
                                Margin="1,0"/>
            </Grid>
        </DataTemplate>

        <ItemsPanelTemplate x:Key="InlineSegmentsPanel">
            <StackPanel Orientation="Horizontal"/>
        </ItemsPanelTemplate>

        <DataTemplate x:Key="LargeCardChipListTemplate">
            <ItemsControl ItemsSource="{Binding}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="34" Height="42" Margin="3,0" CornerRadius="5"
                                Background="{Binding Background}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1">
                            <TextBlock Text="{Binding Rank}"
                                       Foreground="{Binding Foreground}"
                                       FontSize="24"
                                       FontWeight="Black"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DataTemplate>

        <DataTemplate x:Key="SeatCardChipListTemplate">
            <ItemsControl ItemsSource="{Binding}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="22" Height="28" Margin="1,0" CornerRadius="4"
                                Background="{Binding Background}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1">
                            <TextBlock Text="{Binding Rank}"
                                       Foreground="{Binding Foreground}"
                                       FontSize="15"
                                       FontWeight="Black"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DataTemplate>

        <DataTemplate x:Key="CompactCardChipListTemplate">
            <ItemsControl ItemsSource="{Binding}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="18" Height="22" Margin="1,0" CornerRadius="3"
                                Background="{Binding Background}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1">
                            <TextBlock Text="{Binding Rank}"
                                       Foreground="{Binding Foreground}"
                                       FontSize="13"
                                       FontWeight="Black"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="280"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <Border Grid.ColumnSpan="2" 
                Background="{DynamicResource Brush.Card}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14"
                Margin="0,0,0,12">
            <DockPanel>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="REVISION DE MANOS CRITICAS" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Summary}" Foreground="{DynamicResource Brush.TextDim}" Margin="0,2,0,0"/>
                </StackPanel>
                
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{DynamicResource Brush.Inset}" Padding="12,6" CornerRadius="6" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="PROGRESO:" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ReviewedCount}" FontWeight="Bold" Foreground="{DynamicResource Brush.Accent}" VerticalAlignment="Center"/>
                            <TextBlock Text="/" FontWeight="Bold" Margin="2,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalCount}" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button Content="MARCAR COMO REVISADA" 
                            Width="180" Height="36" 
                            FontWeight="Bold"
                            Style="{StaticResource {x:Type Button}}"
                            Background="{DynamicResource Brush.Accent}"
                            Foreground="{DynamicResource Brush.SurfaceText}"
                            Click="BtnMarkReviewed_Click"/>
                </StackPanel>

                <!-- Hand Info Integrated in Header -->
                <UniformGrid Columns="5" Margin="40,0" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="MESA" Style="{StaticResource LabelText}"/>
                        <TextBlock Text="{Binding SelectedHand.TableName}" Style="{StaticResource ValueText}" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="POSICION" Style="{StaticResource LabelText}"/>
                        <TextBlock Text="{Binding ResolvedHeroPosition}" Style="{StaticResource ValueText}" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="ACCION" Style="{StaticResource LabelText}"/>
                        <TextBlock Text="{Binding SelectedHand.Action}" Style="{StaticResource ValueText}" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="BOTE" Style="{StaticResource LabelText}"/>
                        <TextBlock Text="{Binding SelectedHand.PotType}" Style="{StaticResource ValueText}" FontSize="14"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="RESULTADO" Style="{StaticResource LabelText}"/>
                        <TextBlock Text="{Binding SelectedHand.NetBbLabel}" FontWeight="Bold" Foreground="{Binding SelectedHand.NetBbTrendBrush}" FontSize="14"/>
                    </StackPanel>
                </UniformGrid>
            </DockPanel>
        </Border>

        <!-- Left Sidebar (Hands List) -->
        <Border Grid.Row="1" Grid.RowSpan="2"
                Background="{DynamicResource Brush.Card}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="0"
                Margin="0,0,12,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="{DynamicResource Brush.Header}" Padding="10" CornerRadius="8,8,0,0">
                    <TextBlock Text="HISTORIAL DE FUGAS" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Border>
                <ListBox x:Name="HandsList"
                         Grid.Row="1"
                         ItemsSource="{Binding Hands}"
                         SelectedItem="{Binding SelectedHand, Mode=TwoWay}"
                         ItemContainerStyle="{StaticResource HandListItem}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="78"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Status Icon -->
                                <TextBlock Text="{Binding ReviewIcon}" 
                                           Foreground="{Binding ReviewBrush}"
                                           FontSize="16" FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           Width="18" TextAlignment="Center"/>

                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Combo}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                        <ContentControl Content="{Binding HeroCards}"
                                                        ContentTemplate="{StaticResource CompactCardChipListTemplate}"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Spot}" Foreground="{DynamicResource Brush.TextDim}" FontSize="11"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding NetBbLabel}" FontWeight="Bold" TextAlignment="Right" Foreground="{Binding NetBbTrendBrush}"/>
                                    <TextBlock Text="{Binding TableName}" FontSize="10" Foreground="{DynamicResource Brush.TextDim}" TextAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Replayer & APH Reference Area -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="430"/>
                </Grid.ColumnDefinitions>

                <!-- Visual Table -->
                <Border Background="{DynamicResource Brush.Card}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="8" Margin="0,0,12,0">
                    <Grid x:Name="ReplayerTableContainer">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Table Canvas (Simulated) -->
                        <Grid Background="Transparent" ClipToBounds="True">
                            <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="980" Height="520" Background="Transparent">
                                    <!-- Table Oval -->
                                    <Ellipse Fill="#1A1A2E" Stroke="{DynamicResource Brush.Border}" StrokeThickness="4" Width="700" Height="300" Canvas.Left="140" Canvas.Top="105"/>

                                    <!-- APH table watermark -->
                                    <StackPanel Canvas.Left="370" Canvas.Top="205" Width="240" Opacity="0.11">
                                        <TextBlock Text="APH"
                                                   Foreground="{DynamicResource Brush.Text}"
                                                   FontSize="74"
                                                   FontWeight="Black"
                                                   TextAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="Analyzer Poker Hands"
                                                   Foreground="{DynamicResource Brush.TextDim}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,-14,0,0"/>
                                    </StackPanel>
                                    
                                    <!-- Board Cards (Center) -->
                                    <StackPanel Orientation="Horizontal" Canvas.Left="395" Canvas.Top="230">
                                        <ContentControl Content="{Binding CurrentStep.BoardCardChips}" ContentTemplate="{StaticResource LargeCardChipListTemplate}"/>
                                    </StackPanel>

                                    <!-- Pot Info (Center Top) -->
                                    <StackPanel Canvas.Left="440" Canvas.Top="165" Width="120">
                                        <TextBlock Text="POT" Foreground="{DynamicResource Brush.TextDim}" FontSize="16" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding CurrentStep.PotSize, StringFormat={}{0:0.##} bb}" Foreground="{StaticResource FgLight}" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Player Avatars (Dynamic) -->
                                    <ItemsControl ItemsSource="{Binding CurrentStep.Players}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding SeatIndex, Converter={StaticResource SeatX}}"/>
                                                <Setter Property="Canvas.Top" Value="{Binding SeatIndex, Converter={StaticResource SeatY}}"/>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Width="135">
                                                    <Border Width="135" MinHeight="72" Padding="10" CornerRadius="12" 
                                                            Background="{DynamicResource Brush.Inset}"
                                                            BorderBrush="{DynamicResource Brush.Accent}"
                                                            BorderThickness="2">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCurrentActor}" Value="False">
                                                                        <Setter Property="BorderThickness" Value="1"/>
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                        <Setter Property="Opacity" Value="0.48"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Position}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource Brush.Accent}"/>
                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding Stack, StringFormat={}{0:0.#} bb}" FontSize="13" Foreground="{DynamicResource Brush.Accent}"/>
                                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                                    <ContentControl Content="{Binding CardChips}"
                                                                                    ContentTemplate="{StaticResource SeatCardChipListTemplate}"
                                                                                    Visibility="{Binding HasVisibleCards, Converter={StaticResource BoolToVisibility}}"/>
                                                                    <ContentControl Content="{Binding HiddenCardChips}"
                                                                                    ContentTemplate="{StaticResource SeatCardChipListTemplate}"
                                                                                    Visibility="{Binding ShowHiddenCards, Converter={StaticResource BoolToVisibility}}"/>
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <Border Width="24" Height="24"
                                                                    CornerRadius="12"
                                                                    Background="#F3E8B5"
                                                                    BorderBrush="#6E5A20"
                                                                    BorderThickness="1"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Top"
                                                                    Visibility="{Binding IsDealerButton, Converter={StaticResource BoolToVisibility}}">
                                                                <TextBlock Text="D"
                                                                           Foreground="#1A1422"
                                                                           FontWeight="Black"
                                                                           FontSize="13"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           TextAlignment="Center"/>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                    
                                                    <!-- Action Bubble -->
                                                    <Border Visibility="{Binding IsCurrentActor, Converter={StaticResource BoolToVisibility}}"
                                                            Background="{DynamicResource Brush.Accent}" CornerRadius="10" Padding="9,5"
                                                            Margin="0,-34,0,0" VerticalAlignment="Top" HorizontalAlignment="Center"
                                                            MaxWidth="260">
                                                        <TextBlock Text="{Binding CurrentAction}" Foreground="White" FontWeight="Bold" FontSize="13" TextWrapping="Wrap"/>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Canvas>
                            </Viewbox>
                        </Grid>

                        <!-- Timeline Navigation -->
                        <Border Grid.Row="1" Background="{DynamicResource Brush.Inset}" Padding="15" CornerRadius="0,0,8,8">
                            <DockPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Prev" Width="48" Height="40" Style="{StaticResource {x:Type Button}}" Margin="0,0,10,0" Click="BtnPrevStep_Click"/>
                                    <Button Content=">" Width="50" Height="40" Style="{StaticResource {x:Type Button}}" Background="{DynamicResource Brush.Accent}" Click="BtnPlay_Click"/>
                                    <Button Content="Next" Width="48" Height="40" Style="{StaticResource {x:Type Button}}" Margin="10,0,0,0" Click="BtnNextStep_Click"/>
                                </StackPanel>
                                <TextBlock Text="{Binding StepLabel}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{DynamicResource Brush.TextDim}"/>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- APH Reference Panel -->
                <Border Grid.Column="1" Background="{DynamicResource Brush.Card}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="15">
                        <TextBlock DockPanel.Dock="Top" Text="APH REFERENCE" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.Accent}" Margin="0,0,0,15"/>
                        
                        <!-- Equity Meter -->
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,25">
                            <TextBlock Text="EQUITY APH %" Style="{StaticResource LabelText}"/>
                            <Grid Height="30" Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{Binding CurrentStep.AphReference.Equity, Converter={StaticResource PercentToGrid}}"/>
                                    <ColumnDefinition Width="{Binding CurrentStep.AphReference.EquityRemainder, Converter={StaticResource PercentToGrid}}"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.ColumnSpan="2" Background="{DynamicResource Brush.Inset}" CornerRadius="15"/>
                                <Border Grid.Column="0" Background="{DynamicResource Brush.Accent}" CornerRadius="15"/>
                                <TextBlock Grid.ColumnSpan="2" Text="{Binding CurrentStep.AphReference.Equity, StringFormat={}{0:0.##}%}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="White"/>
                            </Grid>
                        </StackPanel>

                        <!-- Frequencies -->
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Text="FRECUENCIAS SUGERIDAS" Style="{StaticResource LabelText}" Margin="0,0,0,10"/>
                            <!-- Fold Bar -->
                            <Grid Margin="0,0,0,8" Visibility="{Binding CurrentStep.AphReference.ShowFold, Converter={StaticResource BoolToVisibility}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="46"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="FOLD" Foreground="{DynamicResource Brush.Text}"/>
                                <Grid Grid.Column="1" Height="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding CurrentStep.AphReference.FoldPct, Converter={StaticResource PercentToGrid}}"/>
                                        <ColumnDefinition Width="{Binding CurrentStep.AphReference.FoldRemainder, Converter={StaticResource PercentToGrid}}"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.ColumnSpan="2" Background="{DynamicResource Brush.Inset}" CornerRadius="6"/>
                                    <Border Grid.Column="0" Background="{Binding CurrentStep.AphReference.FoldBrush}" CornerRadius="6"/>
                                </Grid>
                                <TextBlock Grid.Column="2" Text="{Binding CurrentStep.AphReference.FoldLabel}" Foreground="{DynamicResource Brush.Text}" FontWeight="Bold" TextAlignment="Right"/>
                            </Grid>
                            <!-- Check Bar -->
                            <Grid Margin="0,0,0,8" Visibility="{Binding CurrentStep.AphReference.ShowCheck, Converter={StaticResource BoolToVisibility}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="46"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="CHECK" Foreground="{DynamicResource Brush.Text}"/>
                                <Grid Grid.Column="1" Height="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding CurrentStep.AphReference.CheckPct, Converter={StaticResource PercentToGrid}}"/>
                                        <ColumnDefinition Width="{Binding CurrentStep.AphReference.CheckRemainder, Converter={StaticResource PercentToGrid}}"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.ColumnSpan="2" Background="{DynamicResource Brush.Inset}" CornerRadius="6"/>
                                    <Border Grid.Column="0" Background="{Binding CurrentStep.AphReference.CheckBrush}" CornerRadius="6"/>
                                </Grid>
                                <TextBlock Grid.Column="2" Text="{Binding CurrentStep.AphReference.CheckLabel}" Foreground="{DynamicResource Brush.Text}" FontWeight="Bold" TextAlignment="Right"/>
                            </Grid>
                            <!-- Call Bar -->
                            <Grid Margin="0,0,0,8" Visibility="{Binding CurrentStep.AphReference.ShowCall, Converter={StaticResource BoolToVisibility}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="46"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="CALL" Foreground="{DynamicResource Brush.Text}"/>
                                <Grid Grid.Column="1" Height="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding CurrentStep.AphReference.CallPct, Converter={StaticResource PercentToGrid}}"/>
                                        <ColumnDefinition Width="{Binding CurrentStep.AphReference.CallRemainder, Converter={StaticResource PercentToGrid}}"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.ColumnSpan="2" Background="{DynamicResource Brush.Inset}" CornerRadius="6"/>
                                    <Border Grid.Column="0" Background="{Binding CurrentStep.AphReference.CallBrush}" CornerRadius="6"/>
                                </Grid>
                                <TextBlock Grid.Column="2" Text="{Binding CurrentStep.AphReference.CallLabel}" Foreground="{DynamicResource Brush.Text}" FontWeight="Bold" TextAlignment="Right"/>
                            </Grid>
                            <!-- Raise Bar -->
                            <Grid Margin="0,0,0,8" Visibility="{Binding CurrentStep.AphReference.ShowRaise, Converter={StaticResource BoolToVisibility}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="46"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="RAISE" Foreground="{DynamicResource Brush.Text}"/>
                                <Grid Grid.Column="1" Height="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding CurrentStep.AphReference.RaisePct, Converter={StaticResource PercentToGrid}}"/>
                                        <ColumnDefinition Width="{Binding CurrentStep.AphReference.RaiseRemainder, Converter={StaticResource PercentToGrid}}"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.ColumnSpan="2" Background="{DynamicResource Brush.Inset}" CornerRadius="6"/>
                                    <Border Grid.Column="0" Background="{Binding CurrentStep.AphReference.RaiseBrush}" CornerRadius="6"/>
                                </Grid>
                                <TextBlock Grid.Column="2" Text="{Binding CurrentStep.AphReference.RaiseLabel}" Foreground="{DynamicResource Brush.Text}" FontWeight="Bold" TextAlignment="Right"/>
                            </Grid>
                        </StackPanel>

                        <Border DockPanel.Dock="Top" Margin="0,8,0,0" Padding="10" Background="{DynamicResource Brush.Inset}" BorderBrush="{Binding CurrentStep.AphReference.ConcordanceBrush}" BorderThickness="1" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentStep.AphReference.ConcordanceLabel}" Foreground="{Binding CurrentStep.AphReference.ConcordanceBrush}" FontWeight="Bold"/>
                                <TextBlock Foreground="{DynamicResource Brush.TextDim}" FontSize="12" Margin="0,4,0,0">
                                    <Run Text="Eligio: "/>
                                    <Run Text="{Binding CurrentStep.AphReference.ChosenAction}" FontWeight="Bold"/>
                                    <Run Text=" | Sugerida: "/>
                                    <Run Text="{Binding CurrentStep.AphReference.RecommendedAction}" FontWeight="Bold"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border DockPanel.Dock="Top"
                                Margin="0,10,0,0"
                                Padding="10"
                                Background="{DynamicResource Brush.Inset}"
                                BorderBrush="{Binding CurrentStep.AphReference.EquityMarginBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Visibility="{Binding CurrentStep.AphReference.ShowOddsPanel, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel>
                                <TextBlock Text="ODDS / EV"
                                           Foreground="{Binding CurrentStep.AphReference.EquityMarginBrush}"
                                           FontWeight="Bold"
                                           Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding CurrentStep.AphReference.PotOddsLabel}"
                                           Foreground="{DynamicResource Brush.Text}"
                                           FontSize="12"
                                           LineHeight="16"/>
                                <TextBlock Text="{Binding CurrentStep.AphReference.EquityMarginLabel}"
                                           Foreground="{Binding CurrentStep.AphReference.EquityMarginBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           LineHeight="16"/>
                                <TextBlock Text="{Binding CurrentStep.AphReference.CallEvLabel}"
                                           Foreground="{Binding CurrentStep.AphReference.EquityMarginBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           LineHeight="16"/>
                                <TextBlock Text="{Binding CurrentStep.AphReference.RaiseEvLabel}"
                                           Foreground="{Binding CurrentStep.AphReference.EquityMarginBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           LineHeight="16"/>
                                <TextBlock Text="{Binding CurrentStep.AphReference.FoldEquityLabel}"
                                           Foreground="{DynamicResource Brush.Accent}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           LineHeight="16"/>
                                <TextBlock Text="{Binding CurrentStep.AphReference.VillainProfileLabel}"
                                           Foreground="{DynamicResource Brush.Text}"
                                           FontSize="12"
                                           LineHeight="16"/>
                                <TextBlock Text="{Binding CurrentStep.AphReference.VillainExploitLabel}"
                                           Foreground="{DynamicResource Brush.Text}"
                                           FontSize="12"
                                           FontStyle="Italic"
                                           LineHeight="16"/>
                                <TextBlock Text="{Binding CurrentStep.AphReference.SizingLabel}"
                                           Foreground="{DynamicResource Brush.TextDim}"
                                           FontSize="12"
                                           LineHeight="16"/>
                                <TextBlock Text="{Binding CurrentStep.AphReference.SprLabel}"
                                           Foreground="{DynamicResource Brush.TextDim}"
                                           FontSize="12"
                                           LineHeight="16"/>
                                <Border Height="1" Background="{DynamicResource Brush.Border}" Opacity="0.65" Margin="0,7,0,7"/>
                                <TextBlock Text="{Binding CurrentStep.AphReference.OddsInsight}"
                                           Foreground="{DynamicResource Brush.Text}"
                                           FontSize="12"
                                           FontStyle="Italic"
                                           LineHeight="16"/>
                            </StackPanel>
                        </Border>

                        <Border DockPanel.Dock="Top"
                                Margin="0,12,0,0"
                                Padding="10"
                                Background="{DynamicResource Brush.Inset}"
                                BorderBrush="{Binding CurrentStep.AphReference.ShowdownVerdictBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Visibility="{Binding CurrentStep.AphReference.ShowShowdownReview, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel>
                                <TextBlock Text="SHOWDOWN REVIEW"
                                           Foreground="{Binding CurrentStep.AphReference.ShowdownVerdictBrush}"
                                           FontWeight="Bold"
                                           Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding CurrentStep.AphReference.ShowdownVerdict}"
                                           Foreground="{DynamicResource Brush.Text}"
                                           FontSize="12"
                                           LineHeight="17"/>
                                <Border Height="1" Background="{DynamicResource Brush.Border}" Opacity="0.75" Margin="0,8,0,8"/>
                                <TextBlock Text="{Binding CurrentStep.AphReference.HeroHandWinrateLabel}"
                                           Foreground="{DynamicResource Brush.Accent}"
                                           FontWeight="SemiBold"
                                           FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <!-- Strategy Tip -->
                        <Border Margin="0,20,0,0" Padding="12" Background="{DynamicResource Brush.Inset}" CornerRadius="8" VerticalAlignment="Bottom">
                            <TextBlock Text="{Binding CurrentStep.AphReference.StrategyTip}" Foreground="{DynamicResource Brush.Text}" FontSize="13" LineHeight="18" FontStyle="Italic"/>
                        </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- Bottom Actions (Street by Street) -->
        <Border Grid.Row="2" Grid.Column="1"
                Background="{DynamicResource Brush.Card}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="SECUENCIA DE LA MANO:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ContentControl Content="{Binding SelectedHand.HeroCards}" ContentTemplate="{StaticResource CardChipListTemplate}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedHand.HandResultSummary}" FontWeight="Bold" Foreground="{DynamicResource Brush.Accent}"/>
                        <TextBlock Text=" | " FontWeight="Bold" Foreground="{DynamicResource Brush.TextDim}" Margin="5,0"/>
                        <TextBlock Text="{Binding SelectedHand.MadeHand}" FontWeight="Bold" Foreground="{StaticResource FgLight}"/>

                        <StackPanel Orientation="Horizontal" Visibility="{Binding SelectedHand.HasVillainCards, Converter={StaticResource BoolToVisibility}}" Margin="15,0,0,0">
                            <TextBlock Text=" vs " Foreground="{DynamicResource Brush.TextDim}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedHand.VillainName}" FontWeight="Bold" Foreground="{DynamicResource Brush.Accent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ContentControl Content="{Binding SelectedHand.VillainCardChips}" ContentTemplate="{StaticResource CardChipListTemplate}" VerticalAlignment="Center"/>
                            <TextBlock Text=" (" Foreground="{DynamicResource Brush.TextDim}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedHand.VillainCombination}" Foreground="{StaticResource FgLight}" VerticalAlignment="Center"/>
                            <TextBlock Text=")" Foreground="{DynamicResource Brush.TextDim}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource InfoCell}">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <TextBlock Text="PRE-FLOP" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <ScrollViewer Grid.Row="1"><ItemsControl ItemsSource="{Binding PreflopActions}"><ItemsControl.ItemTemplate><DataTemplate><Border Background="{DynamicResource Brush.Inset}" Padding="6,3" Margin="0,0,0,3"><ItemsControl ItemsSource="{Binding VisualParts}" ItemsPanel="{StaticResource InlineSegmentsPanel}" ItemTemplate="{StaticResource ActionVisualPartTemplate}"/></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource InfoCell}">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                                <TextBlock Text="FLOP" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <ContentControl Content="{Binding SelectedHand.FlopCardChips}" ContentTemplate="{StaticResource CardChipListTemplate}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ScrollViewer Grid.Row="1"><ItemsControl ItemsSource="{Binding FlopActions}"><ItemsControl.ItemTemplate><DataTemplate><Border Background="{DynamicResource Brush.Inset}" Padding="6,3" Margin="0,0,0,3"><ItemsControl ItemsSource="{Binding VisualParts}" ItemsPanel="{StaticResource InlineSegmentsPanel}" ItemTemplate="{StaticResource ActionVisualPartTemplate}"/></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer>
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource InfoCell}">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                                <TextBlock Text="TURN" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <ContentControl Content="{Binding SelectedHand.TurnCardChips}" ContentTemplate="{StaticResource CardChipListTemplate}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ScrollViewer Grid.Row="1"><ItemsControl ItemsSource="{Binding TurnActions}"><ItemsControl.ItemTemplate><DataTemplate><Border Background="{DynamicResource Brush.Inset}" Padding="6,3" Margin="0,0,0,3"><ItemsControl ItemsSource="{Binding VisualParts}" ItemsPanel="{StaticResource InlineSegmentsPanel}" ItemTemplate="{StaticResource ActionVisualPartTemplate}"/></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer>
                        </Grid>
                    </Border>
                    <Border Grid.Column="3" Style="{StaticResource InfoCell}" Margin="0">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                                <TextBlock Text="RIVER" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <ContentControl Content="{Binding SelectedHand.RiverCardChips}" ContentTemplate="{StaticResource CardChipListTemplate}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ScrollViewer Grid.Row="1"><ItemsControl ItemsSource="{Binding RiverActions}"><ItemsControl.ItemTemplate><DataTemplate><Border Background="{DynamicResource Brush.Inset}" Padding="6,3" Margin="0,0,0,3"><ItemsControl ItemsSource="{Binding VisualParts}" ItemsPanel="{StaticResource InlineSegmentsPanel}" ItemTemplate="{StaticResource ActionVisualPartTemplate}"/></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

