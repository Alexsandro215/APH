<Window x:Class="Hud.App.Views.DataVillainDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Hud.App.Views"
        Title="APH - Villan Detail"
        Height="880"
        Width="1460"
        MinHeight="720"
        MinWidth="1280"
        Background="{StaticResource Brush.Bg}"
        WindowStartupLocation="CenterOwner">

  <Window.Resources>
    <views:StatToBrushConverter x:Key="StatToBrush"/>
    <views:StatTextBrushConverter x:Key="StatTextBrush"/>

    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="HeaderStyle" TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="#17212C"/>
      <Setter Property="Foreground" Value="{StaticResource FgLight}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Padding" Value="4"/>
      <Setter Property="BorderBrush" Value="#253343"/>
      <Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>

    <Style x:Key="CellText" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource FgLight}"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Padding" Value="4,0"/>
    </Style>

    <Style x:Key="CenterCellText" TargetType="TextBlock" BasedOn="{StaticResource CellText}">
      <Setter Property="TextAlignment" Value="Center"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <Style x:Key="RangeCellButton" TargetType="Button">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="VerticalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Stretch"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="CellButtonBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="#05080C"
                    BorderThickness="1">
              <ContentPresenter HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="CellButtonBorder" Property="BorderBrush" Value="#E7EEF5"/>
                <Setter TargetName="CellButtonBorder" Property="BorderThickness" Value="2"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ProfitToggle" TargetType="CheckBox">
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <DataTemplate x:Key="RangeCellTemplate">
      <Button Style="{StaticResource RangeCellButton}"
              Tag="{Binding}"
              Click="RangeCell_Click">
        <Border BorderBrush="#05080C"
                BorderThickness="1"
                Margin="0">
          <Grid>
          <ItemsControl ItemsSource="{Binding Segments}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{Binding Background}"
                          Width="{Binding Width}"
                          Height="40"
                          BorderBrush="#05080C"
                          BorderThickness="{Binding BorderThickness}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
          </ItemsControl>
          <Border Background="{Binding ProfitOverlayBrush}"
                  Opacity="{Binding ProfitOverlayOpacity}"/>
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock Text="{Binding HandCode}" Foreground="{Binding Foreground}" FontWeight="Bold" FontSize="13" TextAlignment="Center"/>
              <TextBlock Text="{Binding Count}" Foreground="{Binding Foreground}" FontSize="10" TextAlignment="Center"/>
            </StackPanel>
          </Grid>
          <Border.ToolTip>
            <StackPanel>
              <TextBlock Text="{Binding HandCode}" FontWeight="Bold" Foreground="Black"/>
              <TextBlock Text="{Binding Detail}" Foreground="Black"/>
            </StackPanel>
          </Border.ToolTip>
        </Border>
      </Button>
    </DataTemplate>
  </Window.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="10">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <Border Background="{StaticResource Brush.Card}"
              BorderBrush="{StaticResource Brush.Border}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="14"
              Margin="0,0,0,10">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <Button Grid.Row="0"
                  Content="i"
                  Width="34"
                  Height="34"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Top"
                  FontWeight="Bold"
                  Foreground="{StaticResource Brush.Text}"
                  Background="#111A24"
                  BorderBrush="{StaticResource Brush.Border}"
                  Cursor="Help">
            <Button.ToolTip>
              <StackPanel MaxWidth="420">
                <TextBlock Text="Indicadores de etiquetas" Foreground="Black" FontWeight="Bold" Margin="0,0,0,6"/>
                <TextBlock Foreground="Black" TextWrapping="Wrap"
                           Text="Verde: punto explotable o favorable para el heroe. Rojo: alerta o amenaza del villano. Gris: perfil, muestra o lectura neutral."/>
                <TextBlock Foreground="Black" Margin="0,6,0,0" TextWrapping="Wrap"
                           Text="Perfiles: Sin muestra, Fish, Maniac, Loose pasivo, LAG, TAG, Nit, Tight, Pasivo, Regular."/>
                <TextBlock Foreground="Black" Margin="0,6,0,0" TextWrapping="Wrap"
                           Text="Tags: Rival frecuente, Gana/Pierde vs Hero, Juega muchas manos, Agresor, 3Bet alto, CBet, showdown, calling station, roca, amante premium, suited connectors, trampero, all-in equity y lovers por forma de ganar."/>
              </StackPanel>
            </Button.ToolTip>
          </Button>

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="{Binding VillainName}" FontSize="24" FontWeight="Bold" Margin="0,0,12,0"/>
            <ItemsControl ItemsSource="{Binding Tags}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{Binding Background}"
                          BorderBrush="{Binding Border}"
                          BorderThickness="1"
                          CornerRadius="6"
                          Padding="8,3"
                          Margin="0,0,6,6"
                          ToolTip="{Binding Reason}">
                    <TextBlock Text="{Binding Label}" Foreground="{Binding Foreground}" FontWeight="SemiBold" FontSize="12"/>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <TextBlock Grid.Row="1"
                     Text="{Binding Subtitle}"
                     Foreground="{StaticResource Brush.TextDim}"
                     HorizontalAlignment="Center"
                     Margin="0,6,0,0"/>
        </Grid>
      </Border>

      <Grid Grid.Row="1" Margin="0,0,0,10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="1.15*"/>
          <ColumnDefinition Width="0.85*"/>
        </Grid.ColumnDefinitions>

        <Border Background="{StaticResource Brush.Card}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8"
                Margin="0,0,10,0">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="HEROE VS VILLANO" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding ComparisonRows}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeColumns="False"
                      CanUserSortColumns="False"
                      IsReadOnly="True"
                      RowHeaderWidth="0"
                      RowHeight="28"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      Background="{StaticResource BgDark}"
                      RowBackground="{StaticResource BgDark}"
                      AlternatingRowBackground="#151A21"
                      BorderBrush="{StaticResource BorderDark}"
                      Foreground="{StaticResource FgLight}"
                      ColumnHeaderStyle="{StaticResource HeaderStyle}">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Jugador" Binding="{Binding Name}" Width="150" ElementStyle="{StaticResource CellText}"/>
                <DataGridTextColumn Header="#Manos" Binding="{Binding Hands}" Width="70" ElementStyle="{StaticResource CenterCellText}"/>
                <DataGridTemplateColumn Header="VPIP" Width="62">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding VPIPPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1"
                                 Foreground="{Binding Hands, Converter={StaticResource StatTextBrush}}">
                        <TextBlock.Background>
                          <MultiBinding Converter="{StaticResource StatToBrush}">
                            <Binding Path="VPIPPct"/>
                            <Binding Path="Hands"/>
                            <Binding Path="Stake"/>
                            <Binding Source="VPIP"/>
                          </MultiBinding>
                        </TextBlock.Background>
                      </TextBlock>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="PFR" Width="62">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding PFRPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1"
                                 Foreground="{Binding Hands, Converter={StaticResource StatTextBrush}}">
                        <TextBlock.Background>
                          <MultiBinding Converter="{StaticResource StatToBrush}">
                            <Binding Path="PFRPct"/>
                            <Binding Path="Hands"/>
                            <Binding Path="Stake"/>
                            <Binding Source="PFR"/>
                          </MultiBinding>
                        </TextBlock.Background>
                      </TextBlock>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="3Bet" Width="62">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding ThreeBetPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1"
                                 Foreground="{Binding Hands, Converter={StaticResource StatTextBrush}}">
                        <TextBlock.Background>
                          <MultiBinding Converter="{StaticResource StatToBrush}">
                            <Binding Path="ThreeBetPct"/>
                            <Binding Path="Hands"/>
                            <Binding Path="Stake"/>
                            <Binding Source="THREEBET"/>
                          </MultiBinding>
                        </TextBlock.Background>
                      </TextBlock>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="AF" Width="58">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding AF, StringFormat={}{0:0.#}}" TextAlignment="Center" Padding="1"
                                 Foreground="{Binding Hands, Converter={StaticResource StatTextBrush}}">
                        <TextBlock.Background>
                          <MultiBinding Converter="{StaticResource StatToBrush}">
                            <Binding Path="AF"/>
                            <Binding Path="Hands"/>
                            <Binding Path="Stake"/>
                            <Binding Source="AF"/>
                          </MultiBinding>
                        </TextBlock.Background>
                      </TextBlock>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="AFq" Width="62">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding AFqPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1"
                                 Foreground="{Binding Hands, Converter={StaticResource StatTextBrush}}">
                        <TextBlock.Background>
                          <MultiBinding Converter="{StaticResource StatToBrush}">
                            <Binding Path="AFqPct"/>
                            <Binding Path="Hands"/>
                            <Binding Path="Stake"/>
                            <Binding Source="AFQ"/>
                          </MultiBinding>
                        </TextBlock.Background>
                      </TextBlock>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="CBet" Width="62">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding CBetPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1"
                                 Foreground="{Binding Hands, Converter={StaticResource StatTextBrush}}">
                        <TextBlock.Background>
                          <MultiBinding Converter="{StaticResource StatToBrush}">
                            <Binding Path="CBetPct"/>
                            <Binding Path="Hands"/>
                            <Binding Path="Stake"/>
                            <Binding Source="CBF"/>
                          </MultiBinding>
                        </TextBlock.Background>
                      </TextBlock>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="FvCB" Width="62">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding FvCBPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1"
                                 Foreground="{Binding Hands, Converter={StaticResource StatTextBrush}}">
                        <TextBlock.Background>
                          <MultiBinding Converter="{StaticResource StatToBrush}">
                            <Binding Path="FvCBPct"/>
                            <Binding Path="Hands"/>
                            <Binding Path="Stake"/>
                            <Binding Source="FVCBF"/>
                          </MultiBinding>
                        </TextBlock.Background>
                      </TextBlock>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="WTSD" Width="62">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding WTSDPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1"
                                 Foreground="{Binding Hands, Converter={StaticResource StatTextBrush}}">
                        <TextBlock.Background>
                          <MultiBinding Converter="{StaticResource StatToBrush}">
                            <Binding Path="WTSDPct"/>
                            <Binding Path="Hands"/>
                            <Binding Path="Stake"/>
                            <Binding Source="WTSD"/>
                          </MultiBinding>
                        </TextBlock.Background>
                      </TextBlock>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="W$SD" Width="62">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding WSDPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1"
                                 Foreground="{Binding Hands, Converter={StaticResource StatTextBrush}}">
                        <TextBlock.Background>
                          <MultiBinding Converter="{StaticResource StatToBrush}">
                            <Binding Path="WSDPct"/>
                            <Binding Path="Hands"/>
                            <Binding Path="Stake"/>
                            <Binding Source="WSD"/>
                          </MultiBinding>
                        </TextBlock.Background>
                      </TextBlock>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="WWSF" Width="62">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding WWSFPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1"
                                 Foreground="{Binding Hands, Converter={StaticResource StatTextBrush}}">
                        <TextBlock.Background>
                          <MultiBinding Converter="{StaticResource StatToBrush}">
                            <Binding Path="WWSFPct"/>
                            <Binding Path="Hands"/>
                            <Binding Path="Stake"/>
                            <Binding Source="WWSF"/>
                          </MultiBinding>
                        </TextBlock.Background>
                      </TextBlock>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="BB propia" Width="82">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding BbTrendIcon}" FontWeight="Bold" Margin="0,0,4,0" Foreground="{Binding BbBrush}"/>
                        <TextBlock Text="{Binding BbVs}" Foreground="{Binding BbBrush}"/>
                      </StackPanel>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </Border>

        <Border Grid.Column="1"
                Background="{StaticResource Brush.Card}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <DockPanel Margin="0,0,0,8">
              <CheckBox x:Name="SummaryModeToggle"
                        DockPanel.Dock="Right"
                        Content="ALL DATA"
                        Style="{StaticResource ProfitToggle}"
                        Checked="SummaryModeToggle_Changed"
                        Unchecked="SummaryModeToggle_Changed"/>
              <TextBlock Text="{Binding SummaryTitle}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
            </DockPanel>
            <UniformGrid Grid.Row="1" Columns="2" Rows="4">
              <StackPanel Margin="8">
                <TextBlock Text="Mesa reciente" Foreground="{StaticResource Brush.TextDim}"/>
                <TextBlock Text="{Binding RecentTable}" FontSize="20" FontWeight="Bold"/>
              </StackPanel>
              <StackPanel Margin="8">
                <TextBlock Text="{Binding SummaryHandsLabel}" Foreground="{StaticResource Brush.TextDim}"/>
                <TextBlock Text="{Binding SummaryHandsValue}" FontSize="20" FontWeight="Bold"/>
              </StackPanel>
              <StackPanel Margin="8">
                <TextBlock Text="{Binding SummaryKnownLabel}" Foreground="{StaticResource Brush.TextDim}"/>
                <TextBlock Text="{Binding SummaryKnownValue}" FontSize="20" FontWeight="Bold"/>
              </StackPanel>
              <StackPanel Margin="8">
                <TextBlock Text="{Binding SummaryResultLabel}" Foreground="{StaticResource Brush.TextDim}"/>
                <TextBlock Text="{Binding TotalNetBbLabel}" FontSize="20" FontWeight="Bold" Foreground="{Binding TotalNetBrush}"/>
              </StackPanel>
              <StackPanel Margin="8">
                <TextBlock Text="Perfil base" Foreground="{StaticResource Brush.TextDim}"/>
                <TextBlock Text="{Binding Profile}" FontSize="20" FontWeight="Bold"/>
              </StackPanel>
              <StackPanel Margin="8">
                <TextBlock Text="Formato reciente" Foreground="{StaticResource Brush.TextDim}"/>
                <TextBlock Text="{Binding GameFormat}" FontSize="20" FontWeight="Bold"/>
              </StackPanel>
              <StackPanel Margin="8">
                <TextBlock Text="Tipo" Foreground="{StaticResource Brush.TextDim}"/>
                <TextBlock Text="{Binding MoneyType}" FontSize="20" FontWeight="Bold"/>
              </StackPanel>
            </UniformGrid>
          </Grid>
        </Border>
      </Grid>

      <Border Grid.Row="2"
              Background="{StaticResource Brush.Card}"
              BorderBrush="{StaticResource Brush.Border}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="10"
              Margin="0,0,0,10">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="470"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <DockPanel Margin="0,0,0,8">
            <CheckBox x:Name="ProfitColorToggle"
                      DockPanel.Dock="Right"
                      Content="Color por ganancia bb"
                      Style="{StaticResource ProfitToggle}"
                      Margin="12,0,0,0"
                      Checked="ProfitColorToggle_Changed"
                      Unchecked="ProfitColorToggle_Changed"/>
            <TextBlock Text="TABLAS DEL VILLANO (MUESTRA CONOCIDA)" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
          </DockPanel>
          <TabControl Grid.Row="1" Background="{StaticResource Brush.Card}" BorderBrush="{StaticResource Brush.Border}">
            <TabItem Header="PRE-FLOP">
              <ItemsControl ItemsSource="{Binding PreflopCells}" ItemTemplate="{StaticResource RangeCellTemplate}" Margin="8">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="13" Rows="13"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
              </ItemsControl>
            </TabItem>
            <TabItem Header="FLOP">
              <ItemsControl ItemsSource="{Binding FlopCells}" ItemTemplate="{StaticResource RangeCellTemplate}" Margin="8">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="13" Rows="13"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
              </ItemsControl>
            </TabItem>
            <TabItem Header="TURN">
              <ItemsControl ItemsSource="{Binding TurnCells}" ItemTemplate="{StaticResource RangeCellTemplate}" Margin="8">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="13" Rows="13"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
              </ItemsControl>
            </TabItem>
            <TabItem Header="RIVER">
              <ItemsControl ItemsSource="{Binding RiverCells}" ItemTemplate="{StaticResource RangeCellTemplate}" Margin="8">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="13" Rows="13"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
              </ItemsControl>
            </TabItem>
          </TabControl>
          <Border Grid.Row="2"
                  Background="#101720"
                  BorderBrush="{StaticResource Brush.Border}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="12"
                  Margin="0,10,0,0">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.9*"/>
                <ColumnDefinition Width="3*"/>
              </Grid.ColumnDefinitions>

              <StackPanel>
                <TextBlock x:Name="SelectedRangeHandText" Text="Selecciona una celda" FontSize="18" FontWeight="Bold"/>
                <TextBlock x:Name="SelectedRangeStreetText" Text="PRE-FLOP / FLOP / TURN / RIVER" Foreground="{StaticResource Brush.TextDim}" Margin="0,4,0,0"/>
              </StackPanel>

              <ItemsControl x:Name="SelectedRangeActionSummaryList" Grid.Column="1">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel HorizontalAlignment="Right"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{Binding Color}"
                            CornerRadius="5"
                            Padding="12,9"
                            Margin="5,0,0,0"
                            MinWidth="120">
                      <StackPanel>
                        <TextBlock Text="{Binding Label}" Foreground="Black" FontWeight="Bold" TextAlignment="Center"/>
                        <TextBlock Text="{Binding Detail}" Foreground="Black" TextAlignment="Center" FontSize="12"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Grid>
          </Border>
        </Grid>
      </Border>

      <Border Grid.Row="3"
              Background="{StaticResource Brush.Card}"
              BorderBrush="{StaticResource Brush.Border}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="10">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="260"/>
          </Grid.RowDefinitions>

          <TextBlock x:Name="ExactHandsTitle"
                     Text="Selecciona una combinacion para ver manos exactas"
                     FontSize="16"
                     FontWeight="Bold"
                     Margin="0,0,0,8"/>

          <DataGrid x:Name="ExactHandsGrid"
                    Grid.Row="1"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    MouseLeftButtonUp="ExactHandsGrid_MouseLeftButtonUp"
                    RowHeaderWidth="0"
                    HeadersVisibility="Column"
                    RowHeight="26"
                    Background="#101720"
                    RowBackground="#101720"
                    AlternatingRowBackground="#141B24"
                    Foreground="{StaticResource Brush.Text}"
                    BorderBrush="{StaticResource Brush.Border}"
                    ColumnHeaderStyle="{StaticResource HeaderStyle}"
                    GridLinesVisibility="Horizontal"
                    HorizontalGridLinesBrush="#05070A"
                    VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Mesa" Binding="{Binding TableName}" Width="2*" ElementStyle="{StaticResource CellText}"/>
              <DataGridTextColumn Header="Fecha/Hora" Binding="{Binding LastSeenLabel}" Width="1.3*" ElementStyle="{StaticResource CenterCellText}"/>
              <DataGridTextColumn Header="Mano mesa" Binding="{Binding HandNumber}" Width="0.8*" ElementStyle="{StaticResource CenterCellText}"/>
              <DataGridTemplateColumn Header="Mano exacta" Width="1*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <ItemsControl ItemsSource="{Binding ExactCardSegments}" HorizontalAlignment="Center">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding Text}" Foreground="{Binding Foreground}" FontWeight="{Binding FontWeight}"/>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Posicion" Binding="{Binding Position}" Width="0.7*" ElementStyle="{StaticResource CenterCellText}"/>
              <DataGridTemplateColumn Header="Spot" Width="1.35*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <ItemsControl ItemsSource="{Binding SpotSegments}" HorizontalAlignment="Center">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding Text}" Foreground="{Binding Foreground}" FontWeight="{Binding FontWeight}"/>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Accion" Binding="{Binding ActionLabel}" Width="1*" ElementStyle="{StaticResource CenterCellText}"/>
              <DataGridTemplateColumn Header="Resultado" Width="0.9*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                      <TextBlock Text="{Binding NetTrendIcon}" Foreground="{Binding NetTrendBrush}" FontWeight="Bold" Margin="0,0,5,0"/>
                      <TextBlock Text="{Binding NetBbLabel}" Foreground="{StaticResource Brush.Text}"/>
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </Border>
    </Grid>
  </ScrollViewer>
</Window>
