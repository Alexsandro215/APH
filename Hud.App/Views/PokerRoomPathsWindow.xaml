<Window x:Class="Hud.App.Views.PokerRoomPathsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Rooms.Title}"
        Height="620"
        Width="920"
        MinHeight="520"
        MinWidth="780"
        WindowStartupLocation="CenterOwner">

  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style x:Key="RoomPathBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
      <Setter Property="Height" Value="34"/>
      <Setter Property="IsReadOnly" Value="True"/>
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
      <Setter Property="Foreground" Value="{DynamicResource Brush.SurfaceText}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.HeaderBorder}"/>
      <Setter Property="Padding" Value="10,6"/>
    </Style>
  </Window.Resources>

  <Grid Background="{DynamicResource Brush.AppShell}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Style="{StaticResource HeroCard}"
            Margin="22,22,22,12"
            Padding="20">
      <DockPanel>
        <Border DockPanel.Dock="Left"
                Width="54"
                Height="54"
                CornerRadius="13"
                Background="{DynamicResource Brush.AccentSoft}"
                BorderBrush="{DynamicResource Brush.Accent}"
                BorderThickness="1"
                Margin="0,0,16,0">
          <TextBlock Text="&#xE8B7;"
                     FontFamily="Segoe MDL2 Assets"
                     Foreground="{DynamicResource Brush.Accent}"
                     FontSize="28"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="{DynamicResource Rooms.Header}"
                     FontSize="26"
                     FontWeight="Black"/>
          <TextBlock Text="{DynamicResource Rooms.Subtitle}"
                     Foreground="{DynamicResource Brush.TextDim}"
                     Margin="0,4,0,0"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <ScrollViewer Grid.Row="1"
                  Margin="22,0,22,0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <ItemsControl ItemsSource="{Binding Rooms}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource ProjectPanelBorder}"
                    Margin="0,0,0,12"
                    Padding="14">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="190"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,14,0">
                  <TextBlock Text="{Binding Name}"
                             FontSize="18"
                             FontWeight="Bold"
                             Foreground="{DynamicResource Brush.Text}"/>
                  <TextBlock Text="{Binding Description}"
                             Foreground="{DynamicResource Brush.TextDim}"
                             FontSize="12"
                             Margin="0,3,0,0"/>
                </StackPanel>

                <TextBox Grid.Column="1"
                         Text="{Binding Folder, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource RoomPathBox}"
                         VerticalAlignment="Center"/>

                <Button Grid.Column="2"
                        Style="{StaticResource Btn.Primary}"
                        Width="112"
                        Height="36"
                        Margin="12,0,0,0"
                        Click="BtnBrowse_Click">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" Margin="0,0,7,0"/>
                    <TextBlock Text="{DynamicResource Rooms.Browse}"/>
                  </StackPanel>
                </Button>

                <Button Grid.Column="3"
                        Style="{StaticResource Btn.Primary}"
                        Width="112"
                        Height="36"
                        Margin="8,0,0,0"
                        Click="BtnLoad_Click">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" Margin="0,0,7,0"/>
                    <TextBlock Text="{DynamicResource Rooms.Load}"/>
                  </StackPanel>
                </Button>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <Border Grid.Row="2"
            Background="{DynamicResource Brush.Panel}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,1,0,0"
            Padding="18">
      <DockPanel>
        <TextBlock x:Name="StatusText"
                   Text="{DynamicResource Rooms.SavedLocally}"
                   Foreground="{DynamicResource Brush.TextDim}"
                   VerticalAlignment="Center"/>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <Button Content="{DynamicResource Rooms.Close}"
                  Style="{StaticResource Btn.Primary}"
                  Width="110"
                  Click="BtnClose_Click"/>
        </StackPanel>
      </DockPanel>
    </Border>
  </Grid>
</Window>
