<Window x:Class="Hud.App.Views.GlobalAnalysisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Hud.App.Views"
        Title="{DynamicResource Global.Title}"
        Height="555"
        Width="1460"
        MinHeight="430"
        MinWidth="1120"
        Background="{StaticResource Brush.Bg}"
        WindowStartupLocation="CenterOwner">

  <Window.Resources>
    <views:StatToBrushConverter x:Key="StatToBrush"/>
    <views:StatTextBrushConverter x:Key="StatTextBrush"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{Binding Color, Source={StaticResource Brush.Accent}}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{Binding Color, Source={StaticResource Brush.SurfaceText}}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="{Binding Color, Source={StaticResource Brush.SurfaceText}}"/>

    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <DataTemplate x:Key="FilterComboItemTemplate">
      <TextBlock Text="{Binding}" Foreground="{DynamicResource Brush.SurfaceText}"/>
    </DataTemplate>

    <Style x:Key="HeaderStyle" TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="{DynamicResource Brush.Header}"/>
      <Setter Property="Foreground" Value="{StaticResource FgLight}"/>
      <Setter Property="TextElement.Foreground" Value="{StaticResource FgLight}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Padding" Value="3"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.HeaderBorder}"/>
      <Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>

    <Style x:Key="CellText" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource FgLight}"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Padding" Value="4,0"/>
    </Style>

    <Style x:Key="CenterCellText" TargetType="TextBlock" BasedOn="{StaticResource CellText}">
      <Setter Property="TextAlignment" Value="Center"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <Style x:Key="FilterLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource Brush.TextDim}"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Margin" Value="0,0,0,3"/>
    </Style>

    <Style x:Key="FilterTextBox" TargetType="TextBox">
      <Setter Property="Height" Value="28"/>
      <Setter Property="Foreground" Value="{DynamicResource Brush.SurfaceText}"/>
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.HeaderBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="7,3"/>
      <Setter Property="Margin" Value="0"/>
    </Style>

    <Style x:Key="FilterComboBox" TargetType="ComboBox">
      <Setter Property="Height" Value="28"/>
      <Setter Property="Foreground" Value="{DynamicResource Brush.SurfaceText}"/>
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.HeaderBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="7,3"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="ItemTemplate" Value="{StaticResource FilterComboItemTemplate}"/>
    </Style>

    <Style TargetType="ComboBoxItem">
      <Setter Property="Foreground" Value="{DynamicResource Brush.SurfaceText}"/>
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource Brush.SurfaceText}"/>
      <Style.Resources>
        <Style TargetType="TextBlock">
          <Setter Property="Foreground" Value="{DynamicResource Brush.SurfaceText}"/>
        </Style>
      </Style.Resources>
    </Style>
  </Window.Resources>

  <Grid Background="{StaticResource Brush.Bg}" Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Border Background="{StaticResource Brush.Card}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12"
            Margin="0,0,0,10">
      <Grid>
        <StackPanel HorizontalAlignment="Center">
          <TextBlock Text="{DynamicResource Global.Header}"
                     FontSize="22"
                     FontWeight="Bold"
                     TextAlignment="Center"
                     HorizontalAlignment="Center"/>
          <TextBlock x:Name="SummaryText"
                     Foreground="{StaticResource Brush.TextDim}"
                     Margin="0,4,0,0"
                     TextAlignment="Center"/>
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Background="{StaticResource Brush.Card}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10"
            Margin="0,0,0,10">
      <WrapPanel>
        <StackPanel Width="185" Margin="0,0,10,6">
          <TextBlock Text="{DynamicResource Global.Table}" Style="{StaticResource FilterLabel}"/>
          <TextBox x:Name="SearchBox"
                   Style="{StaticResource FilterTextBox}"
                   TextChanged="Filter_Changed"/>
        </StackPanel>

        <StackPanel Width="130" Margin="0,0,10,6">
          <TextBlock Text="{DynamicResource Global.Date}" Style="{StaticResource FilterLabel}"/>
          <ComboBox x:Name="DateFilter"
                    Style="{StaticResource FilterComboBox}"
                    SelectionChanged="Filter_Changed"/>
        </StackPanel>

        <StackPanel Width="130" Margin="0,0,10,6">
          <TextBlock Text="{DynamicResource Global.Blinds}" Style="{StaticResource FilterLabel}"/>
          <ComboBox x:Name="BlindFilter"
                    Style="{StaticResource FilterComboBox}"
                    SelectionChanged="Filter_Changed"/>
        </StackPanel>

        <StackPanel Width="130" Margin="0,0,10,6">
          <TextBlock Text="{DynamicResource Global.Format}" Style="{StaticResource FilterLabel}"/>
          <ComboBox x:Name="FormatFilter"
                    Style="{StaticResource FilterComboBox}"
                    SelectionChanged="Filter_Changed"/>
        </StackPanel>

        <StackPanel Width="135" Margin="0,0,10,6">
          <TextBlock Text="{DynamicResource Global.Result}" Style="{StaticResource FilterLabel}"/>
          <ComboBox x:Name="ResultFilter"
                    Style="{StaticResource FilterComboBox}"
                    SelectionChanged="Filter_Changed"/>
        </StackPanel>

        <StackPanel Width="105" Margin="0,0,10,6">
          <TextBlock Text="{DynamicResource Global.MinHands}" Style="{StaticResource FilterLabel}"/>
          <ComboBox x:Name="HandsFilter"
                    Style="{StaticResource FilterComboBox}"
                    SelectionChanged="Filter_Changed"/>
        </StackPanel>

        <StackPanel Width="105" Margin="0,0,10,6">
          <TextBlock Text="{DynamicResource Global.Type}" Style="{StaticResource FilterLabel}"/>
          <ComboBox x:Name="MoneyTypeFilter"
                    Style="{StaticResource FilterComboBox}"
                    SelectionChanged="Filter_Changed"/>
        </StackPanel>

        <StackPanel Width="180" Margin="0,0,10,6">
          <TextBlock Text="{DynamicResource Global.Sort}" Style="{StaticResource FilterLabel}"/>
          <ComboBox x:Name="SortFilter"
                    Style="{StaticResource FilterComboBox}"
                    SelectionChanged="Filter_Changed"/>
        </StackPanel>
      </WrapPanel>
    </Border>

    <Border Grid.Row="2"
            Background="{StaticResource Brush.Card}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="8">
      <DataGrid ItemsSource="{Binding Tables}"
                x:Name="TablesGrid"
                SelectionMode="Single"
                SelectionUnit="FullRow"
                SelectionChanged="TablesGrid_SelectionChanged"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserReorderColumns="False"
                CanUserResizeColumns="False"
                CanUserResizeRows="False"
                CanUserSortColumns="False"
                IsReadOnly="True"
                RowHeaderWidth="0"
                RowHeight="28"
                HeadersVisibility="Column"
                GridLinesVisibility="None"
                Background="{StaticResource BgDark}"
                RowBackground="{StaticResource BgDark}"
                AlternatingRowBackground="{StaticResource Brush.Panel}"
                BorderBrush="{StaticResource BorderDark}"
                BorderThickness="1"
                Foreground="{StaticResource FgLight}"
                ColumnHeaderStyle="{StaticResource HeaderStyle}"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto">
        <DataGrid.RowStyle>
          <Style TargetType="DataGridRow">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTip" Value="{DynamicResource Global.OpenTableTip}"/>
          </Style>
        </DataGrid.RowStyle>
        <DataGrid.Columns>
          <DataGridTextColumn Header="{DynamicResource Grid.Table}" Binding="{Binding TableName}" Width="190" ElementStyle="{StaticResource CellText}"/>
          <DataGridTextColumn Header="{DynamicResource Grid.Format}" Binding="{Binding GameFormat}" Width="88" ElementStyle="{StaticResource CenterCellText}"/>
          <DataGridTextColumn Header="{DynamicResource Grid.Date}" Binding="{Binding PlayedDate}" Width="92" ElementStyle="{StaticResource CenterCellText}"/>
          <DataGridTextColumn Header="{DynamicResource Grid.Hands}" Binding="{Binding HandsReceived}" Width="72" ElementStyle="{StaticResource CenterCellText}"/>

          <DataGridTemplateColumn Header="VPIP%" Width="72">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding VPIPPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                  <TextBlock.Background>
                    <MultiBinding Converter="{StaticResource StatToBrush}">
                      <Binding Path="VPIPPct"/>
                      <Binding Path="HandsReceived"/>
                      <Binding Path="Stake"/>
                      <Binding Source="VPIP"/>
                    </MultiBinding>
                  </TextBlock.Background>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="PFR%" Width="72">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding PFRPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                  <TextBlock.Background>
                    <MultiBinding Converter="{StaticResource StatToBrush}">
                      <Binding Path="PFRPct"/>
                      <Binding Path="HandsReceived"/>
                      <Binding Path="Stake"/>
                      <Binding Source="PFR"/>
                    </MultiBinding>
                  </TextBlock.Background>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="3Bet%" Width="72">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding ThreeBetPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                  <TextBlock.Background>
                    <MultiBinding Converter="{StaticResource StatToBrush}">
                      <Binding Path="ThreeBetPct"/>
                      <Binding Path="HandsReceived"/>
                      <Binding Path="Stake"/>
                      <Binding Source="THREEBET"/>
                    </MultiBinding>
                  </TextBlock.Background>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="AF" Width="64">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding AF, StringFormat={}{0:0.#}}" TextAlignment="Center" Padding="1" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                  <TextBlock.Background>
                    <MultiBinding Converter="{StaticResource StatToBrush}">
                      <Binding Path="AF"/>
                      <Binding Path="HandsReceived"/>
                      <Binding Path="Stake"/>
                      <Binding Source="AF"/>
                    </MultiBinding>
                  </TextBlock.Background>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="AFq%" Width="72">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding AFqPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                  <TextBlock.Background>
                    <MultiBinding Converter="{StaticResource StatToBrush}">
                      <Binding Path="AFqPct"/>
                      <Binding Path="HandsReceived"/>
                      <Binding Path="Stake"/>
                      <Binding Source="AFQ"/>
                    </MultiBinding>
                  </TextBlock.Background>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="CBet%" Width="72">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding CBetFlopPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                  <TextBlock.Background>
                    <MultiBinding Converter="{StaticResource StatToBrush}">
                      <Binding Path="CBetFlopPct"/>
                      <Binding Path="HandsReceived"/>
                      <Binding Path="Stake"/>
                      <Binding Source="CBF"/>
                    </MultiBinding>
                  </TextBlock.Background>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="FvCB%" Width="76">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding FoldVsCBetFlopPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                  <TextBlock.Background>
                    <MultiBinding Converter="{StaticResource StatToBrush}">
                      <Binding Path="FoldVsCBetFlopPct"/>
                      <Binding Path="HandsReceived"/>
                      <Binding Path="Stake"/>
                      <Binding Source="FVCBF"/>
                    </MultiBinding>
                  </TextBlock.Background>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="WTSD%" Width="72">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding WTSDPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                  <TextBlock.Background>
                    <MultiBinding Converter="{StaticResource StatToBrush}">
                      <Binding Path="WTSDPct"/>
                      <Binding Path="HandsReceived"/>
                      <Binding Path="Stake"/>
                      <Binding Source="WTSD"/>
                    </MultiBinding>
                  </TextBlock.Background>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="W$SD%" Width="72">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding WSDPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                  <TextBlock.Background>
                    <MultiBinding Converter="{StaticResource StatToBrush}">
                      <Binding Path="WSDPct"/>
                      <Binding Path="HandsReceived"/>
                      <Binding Path="Stake"/>
                      <Binding Source="WSD"/>
                    </MultiBinding>
                  </TextBlock.Background>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="WWSF%" Width="72">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding WWSFPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                  <TextBlock.Background>
                    <MultiBinding Converter="{StaticResource StatToBrush}">
                      <Binding Path="WWSFPct"/>
                      <Binding Path="HandsReceived"/>
                      <Binding Path="Stake"/>
                      <Binding Source="WWSF"/>
                    </MultiBinding>
                  </TextBlock.Background>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="{DynamicResource Grid.FinalBb}" Width="94">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                  <TextBlock Text="{Binding TrendIcon}" FontWeight="Bold" Margin="0,0,5,0">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#E24E5B"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsWin}" Value="True">
                            <Setter Property="Foreground" Value="#21C07A"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                  <TextBlock Text="{Binding NetBb, StringFormat={}{0:0.#} bb}" Foreground="{StaticResource FgLight}"/>
                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="{DynamicResource Common.ChipsMoney}" Width="120">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding NetAmountLabel}" FontWeight="SemiBold" TextAlignment="Center">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Foreground" Value="#E24E5B"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsProfitable}" Value="True">
                          <Setter Property="Foreground" Value="#21C07A"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>
  </Grid>
</Window>



