<Window x:Class="Hud.App.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Login.Title}"
        Height="560"
        Width="760"
        MinHeight="520"
        MinWidth="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style x:Key="LoginCard" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="22"/>
    </Style>
  </Window.Resources>

  <Grid Background="{DynamicResource Brush.AppShell}" Margin="0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="{DynamicResource Brush.Panel}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,0,0,1"
            Padding="26">
      <DockPanel>
        <Border DockPanel.Dock="Left"
                Width="60"
                Height="60"
                CornerRadius="14"
                Background="{DynamicResource Brush.Inset}"
                BorderBrush="{DynamicResource Brush.Accent}"
                BorderThickness="1"
                Margin="0,0,16,0">
          <TextBlock Text="&#x2660;"
                     FontFamily="Segoe UI Symbol"
                     Foreground="{DynamicResource Brush.Accent}"
                     FontSize="36"
                     FontWeight="Black"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="{DynamicResource Login.AppName}"
                     FontSize="28"
                     FontWeight="Black"/>
          <TextBlock Text="{DynamicResource Login.Subtitle}"
                     Foreground="{DynamicResource Brush.TextDim}"
                     Margin="0,4,0,0"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <Grid Grid.Row="1" Margin="28">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1*"/>
        <ColumnDefinition Width="1*"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Style="{StaticResource LoginCard}" Margin="0,0,12,0">
        <StackPanel>
          <TextBlock Text="{DynamicResource Login.GoogleStep}"
                     FontSize="21"
                     FontWeight="Bold"/>
          <TextBlock Text="{DynamicResource Login.GoogleDesc}"
                     Foreground="{DynamicResource Brush.TextDim}"
                     Margin="0,6,0,18"/>
          <Button x:Name="GoogleButton"
                  Style="{StaticResource Btn.Primary}"
                  Height="48"
                  Click="GoogleButton_Click">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <TextBlock Text="G" FontWeight="Black" FontSize="20" Margin="0,0,9,0"/>
              <TextBlock Text="{DynamicResource Login.GoogleButton}"/>
            </StackPanel>
          </Button>
          <TextBlock x:Name="GoogleStatusText"
                     Foreground="{DynamicResource Brush.TextDim}"
                     Margin="0,14,0,0"/>
        </StackPanel>
      </Border>

      <Border Grid.Column="1" Style="{StaticResource LoginCard}" Margin="12,0,0,0">
        <StackPanel>
          <TextBlock x:Name="PasswordTitleText"
                     Text="2. Bloqueo local"
                     FontSize="21"
                     FontWeight="Bold"/>
          <TextBlock x:Name="PasswordHelpText"
                     Text="{DynamicResource Login.LocalLockDesc}"
                     Foreground="{DynamicResource Brush.TextDim}"
                     Margin="0,6,0,18"/>

          <TextBlock Text="{DynamicResource Login.Password}" Foreground="{DynamicResource Brush.TextDim}" Margin="0,0,0,5"/>
          <PasswordBox x:Name="PasswordBox"
                       Height="34"
                       IsEnabled="False"
                       KeyDown="PasswordBox_KeyDown"
                       Margin="0,0,0,10"/>

          <StackPanel x:Name="ConfirmPasswordPanel">
            <TextBlock Text="{DynamicResource Login.ConfirmPassword}" Foreground="{DynamicResource Brush.TextDim}" Margin="0,0,0,5"/>
            <PasswordBox x:Name="ConfirmPasswordBox"
                         Height="34"
                         IsEnabled="False"
                         KeyDown="PasswordBox_KeyDown"
                         Margin="0,0,0,10"/>
          </StackPanel>

          <Button x:Name="ContinueButton"
                  Content="Entrar a APH"
                  Style="{StaticResource Btn.Primary}"
                  Height="44"
                  IsEnabled="False"
                  Click="ContinueButton_Click"/>
          <TextBlock x:Name="PasswordStatusText"
                     Foreground="{DynamicResource Brush.TextDim}"
                     Margin="0,14,0,0"/>
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</Window>
