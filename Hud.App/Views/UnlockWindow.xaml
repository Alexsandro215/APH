<Window x:Class="Hud.App.Views.UnlockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Unlock.Title}"
        Height="390"
        Width="520"
        MinHeight="370"
        MinWidth="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
  </Window.Resources>

  <Grid Background="{DynamicResource Brush.AppShell}">
    <Border Background="{DynamicResource Brush.Card}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="28"
            Width="440"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
      <StackPanel>
        <Border Width="66"
                Height="66"
                CornerRadius="16"
                Background="{DynamicResource Brush.Inset}"
                BorderBrush="{DynamicResource Brush.Accent}"
                BorderThickness="1"
                HorizontalAlignment="Center"
                Margin="0,0,0,18">
          <TextBlock Text="&#x2660;"
                     FontFamily="Segoe UI Symbol"
                     Foreground="{DynamicResource Brush.Accent}"
                     FontSize="40"
                     FontWeight="Black"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>

        <TextBlock Text="{DynamicResource Unlock.Title}"
                   FontSize="28"
                   FontWeight="Black"
                   TextAlignment="Center"/>
        <TextBlock Text="{DynamicResource Unlock.Help}"
                   Foreground="{DynamicResource Brush.TextDim}"
                   TextAlignment="Center"
                   Margin="0,6,0,24"/>

        <TextBlock Text="{DynamicResource Login.Password}"
                   Foreground="{DynamicResource Brush.TextDim}"
                   Margin="0,0,0,6"/>
        <PasswordBox x:Name="PasswordInput"
                     Height="38"
                     KeyDown="PasswordInput_KeyDown"
                     Margin="0,0,0,14"/>

        <Button Content="{DynamicResource Unlock.Enter}"
                Style="{StaticResource Btn.Primary}"
                Height="46"
                Click="UnlockButton_Click"/>

        <TextBlock x:Name="StatusText"
                   Foreground="{DynamicResource Brush.TextDim}"
                   TextAlignment="Center"
                   Margin="0,14,0,0"/>
      </StackPanel>
    </Border>
  </Grid>
</Window>
