<Window x:Class="Hud.App.Views.RealTimeDictionaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="APH - Ayuda de Tiempo real"
        Height="720"
        Width="1080"
        MinHeight="620"
        MinWidth="920"
        Background="{StaticResource Brush.Bg}"
        WindowStartupLocation="CenterOwner">

  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="PanelBorder" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource Brush.Card}"/>
      <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="14"/>
    </Style>
  </Window.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
      <StackPanel>
        <TextBlock Text="AYUDA DE TIEMPO REAL" FontSize="24" FontWeight="Bold" TextAlignment="Center"/>
        <TextBlock Text="Controles, colores y metricas usadas mientras las mesas se leen en vivo." Foreground="{StaticResource Brush.TextDim}" Margin="0,4,0,0" TextAlignment="Center"/>
      </StackPanel>
    </Border>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1*"/>
        <ColumnDefinition Width="1*"/>
      </Grid.ColumnDefinitions>

      <Grid Margin="0,0,8,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
          <StackPanel>
            <TextBlock Text="CONTROLES" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <ItemsControl ItemsSource="{Binding ControlRows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="#101720" BorderBrush="#223244" BorderThickness="1" CornerRadius="6" Padding="9" Margin="0,0,0,8">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{StaticResource Brush.Text}"/>
                      <TextBlock Grid.Column="1" Text="{Binding Description}" Foreground="{StaticResource Brush.TextDim}"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelBorder}">
          <DockPanel LastChildFill="True">
            <TextBlock Text="QUE MIDE CADA STAT" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,10"/>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding MetricRows}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="#101720" BorderBrush="#223244" BorderThickness="1" CornerRadius="6" Padding="9" Margin="0,0,0,8">
                      <StackPanel>
                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{StaticResource Brush.Text}"/>
                        <TextBlock Text="{Binding Description}" Foreground="{StaticResource Brush.TextDim}" Margin="0,2,0,0"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </DockPanel>
        </Border>
      </Grid>

      <Grid Grid.Column="1" Margin="8,0,0,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
          <StackPanel>
            <TextBlock Text="COLORES DE METRICAS" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <ItemsControl ItemsSource="{Binding ColorRows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="34"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="24" Height="18" Background="{Binding Brush}" BorderBrush="#506176" BorderThickness="1" CornerRadius="3"/>
                    <StackPanel Grid.Column="1">
                      <TextBlock Text="{Binding Label}" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text}"/>
                      <TextBlock Text="{Binding Description}" Foreground="{StaticResource Brush.TextDim}" FontSize="12"/>
                    </StackPanel>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelBorder}">
          <DockPanel LastChildFill="True">
            <TextBlock Text="LECTURA RAPIDA" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="0,0,0,10"/>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding NoteRows}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="#101720" BorderBrush="#223244" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                      <TextBlock Text="{Binding}" Foreground="{StaticResource Brush.TextDim}"/>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </DockPanel>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Window>
