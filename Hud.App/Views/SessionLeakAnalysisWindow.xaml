<Window x:Class="Hud.App.Views.SessionLeakAnalysisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Análisis de Leak por Sesión"
        Height="720" Width="1180"
        MinHeight="600" MinWidth="900"
        Background="{DynamicResource Brush.AppShell}"
        WindowStartupLocation="CenterOwner">
    
    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
            <Setter Property="RowBackground" Value="{DynamicResource Brush.Card}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource Brush.Panel}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="38"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource Brush.Header}"/>
            <Setter Property="Foreground" Value="{StaticResource FgLight}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.HeaderBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="{DynamicResource Brush.Panel}" 
                BorderBrush="{DynamicResource Brush.Border}" 
                BorderThickness="1" 
                CornerRadius="12" 
                Padding="20" 
                Margin="0,0,0,18">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="ANÁLISIS DE LEAK POR SESIÓN" 
                             FontSize="28" 
                             FontWeight="Black" 
                             Foreground="{DynamicResource Brush.Text}"/>
                    <TextBlock Text="Selecciona una sesión para extraer tus fugas críticas (excluyendo ciegas)." 
                             Foreground="{DynamicResource Brush.TextDim}" 
                             FontSize="14"
                             Margin="0,4,0,0"/>
                </StackPanel>
                <Button Content="Actualizar Lista" 
                        DockPanel.Dock="Right" 
                        Style="{StaticResource Btn.Primary}" 
                        Width="150" 
                        Height="36"
                        VerticalAlignment="Center"
                        Click="BtnRefresh_Click"/>
            </DockPanel>
        </Border>

        <!-- Status Bar -->
        <TextBlock Grid.Row="1" x:Name="StatusText" 
                   Foreground="{DynamicResource Brush.Accent}" 
                   FontWeight="SemiBold"
                   Margin="4,0,0,12"
                   Text="Cargando sesiones..."/>

        <!-- Grid -->
        <DataGrid x:Name="SessionsGrid" Grid.Row="2" 
                  MouseDoubleClick="SessionsGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Sesión" Binding="{Binding Name}" Width="220"/>
                <DataGridTextColumn Header="Fecha" Binding="{Binding Date}" Width="110"/>
                <DataGridTextColumn Header="Hora" Binding="{Binding Time}" Width="90"/>
                <DataGridTextColumn Header="Mesas" Binding="{Binding TableCount}" Width="80"/>
                <DataGridTextColumn Header="Manos" Binding="{Binding HandCount}" Width="90"/>
                <DataGridTextColumn Header="Resultado" Binding="{Binding Result}" Width="180">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="{Binding ResultBrush}"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Stats Promedio" Binding="{Binding AvgStats}" Width="*"/>
                <DataGridTemplateColumn Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="ANALIZAR" 
                                    Click="BtnAnalyze_Click" 
                                    Style="{StaticResource Btn.Primary}" 
                                    Background="{DynamicResource Brush.Accent}" 
                                    Foreground="White" 
                                    FontWeight="Bold" 
                                    Height="28" 
                                    Margin="4"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
