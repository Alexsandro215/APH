<Window x:Class="Hud.App.Views.MisTablasWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Common.MyTablesTitle}"
        Height="760"
        Width="1420"
        MinHeight="620"
        MinWidth="1280"
        Background="{DynamicResource Brush.Bg}"
        WindowStartupLocation="CenterOwner">

  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="StreetButton" TargetType="Button" BasedOn="{StaticResource CardButton}">
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="MinWidth" Value="120"/>
    </Style>

    <Style x:Key="FilterLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextDim}"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Margin" Value="0,0,0,3"/>
    </Style>

    <Style x:Key="FilterCombo" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
      <Setter Property="MinWidth" Value="118"/>
      <Setter Property="Height" Value="28"/>
      <Setter Property="Foreground" Value="{DynamicResource Brush.SurfaceText}"/>
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
      <Setter Property="Margin" Value="0"/>
    </Style>

    <Style x:Key="FilterCalendarDayButton" TargetType="CalendarDayButton">
      <Setter Property="Foreground" Value="Black"/>
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
      <Setter Property="MinWidth" Value="22"/>
      <Setter Property="MinHeight" Value="18"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CalendarDayButton">
            <Border x:Name="DayBorder"
                    Background="{TemplateBinding Background}"
                    CornerRadius="2"
                    Padding="2">
              <TextBlock Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                         Foreground="{DynamicResource Brush.SurfaceText}"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="DayBorder" Property="Background" Value="{DynamicResource Brush.Card}"/>
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="DayBorder" Property="Background" Value="{DynamicResource Brush.Accent}"/>
              </Trigger>
              <Trigger Property="IsInactive" Value="True">
                <Setter TargetName="DayBorder" Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="FilterCalendarButton" TargetType="CalendarButton">
      <Setter Property="Foreground" Value="Black"/>
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CalendarButton">
            <Border x:Name="CalendarButtonBorder"
                    Background="{TemplateBinding Background}"
                    CornerRadius="3"
                    Padding="4">
              <TextBlock Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                         Foreground="{DynamicResource Brush.SurfaceText}"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="CalendarButtonBorder" Property="Background" Value="{DynamicResource Brush.Card}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="FilterCalendar" TargetType="Calendar">
      <Setter Property="Foreground" Value="Black"/>
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
      <Setter Property="CalendarDayButtonStyle" Value="{StaticResource FilterCalendarDayButton}"/>
      <Setter Property="CalendarButtonStyle" Value="{StaticResource FilterCalendarButton}"/>
      <Style.Resources>
        <Style TargetType="Button">
          <Setter Property="Foreground" Value="Black"/>
          <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
          <Setter Property="BorderBrush" Value="Transparent"/>
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="Button">
                <Border x:Name="CalendarHeaderButton"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Padding="4,2">
                  <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    TextElement.Foreground="{DynamicResource Brush.SurfaceText}"
                                    TextElement.FontWeight="SemiBold"/>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="CalendarHeaderButton" Property="Background" Value="{DynamicResource Brush.Card}"/>
                  </Trigger>
                  <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="CalendarHeaderButton" Property="Background" Value="{DynamicResource Brush.Accent}"/>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
        <Style TargetType="TextBlock">
          <Setter Property="Foreground" Value="Black"/>
        </Style>
      </Style.Resources>
    </Style>

    <Style x:Key="FilterDate" TargetType="DatePicker">
      <Setter Property="MinWidth" Value="154"/>
      <Setter Property="Height" Value="28"/>
      <Setter Property="Foreground" Value="Black"/>
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="CalendarStyle" Value="{StaticResource FilterCalendar}"/>
      <Style.Resources>
        <Style TargetType="DatePickerTextBox">
          <Setter Property="Foreground" Value="Black"/>
          <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
        </Style>
        <Style TargetType="Calendar">
          <Setter Property="Foreground" Value="Black"/>
          <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
        </Style>
        <Style TargetType="CalendarItem">
          <Setter Property="Foreground" Value="Black"/>
          <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
        </Style>
        <Style TargetType="CalendarDayButton">
          <Setter Property="Foreground" Value="Black"/>
          <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
          <Setter Property="MinWidth" Value="22"/>
          <Setter Property="MinHeight" Value="18"/>
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="CalendarDayButton">
                <Border x:Name="DayBorder"
                        Background="{TemplateBinding Background}"
                        CornerRadius="2"
                        Padding="2">
                  <TextBlock Text="{TemplateBinding Content}"
                             Foreground="{DynamicResource Brush.SurfaceText}"
                             FontWeight="SemiBold"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="DayBorder" Property="Background" Value="{DynamicResource Brush.Card}"/>
                  </Trigger>
                  <Trigger Property="IsSelected" Value="True">
                    <Setter TargetName="DayBorder" Property="Background" Value="{DynamicResource Brush.Accent}"/>
                  </Trigger>
                  <Trigger Property="IsInactive" Value="True">
                    <Setter TargetName="DayBorder" Property="Opacity" Value="0.55"/>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
        <Style TargetType="CalendarButton">
          <Setter Property="Foreground" Value="Black"/>
          <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="CalendarButton">
                <Border x:Name="CalendarButtonBorder"
                        Background="{TemplateBinding Background}"
                        CornerRadius="3"
                        Padding="4">
                  <TextBlock Text="{TemplateBinding Content}"
                             Foreground="{DynamicResource Brush.SurfaceText}"
                             FontWeight="SemiBold"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="CalendarButtonBorder" Property="Background" Value="{DynamicResource Brush.Card}"/>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </Style.Resources>
    </Style>

    <Style x:Key="ExactHandsHeaderStyle" TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="{DynamicResource Brush.Header}"/>
      <Setter Property="Foreground" Value="{StaticResource FgLight}"/>
      <Setter Property="TextElement.Foreground" Value="{StaticResource FgLight}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Padding" Value="4,2"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="DataGridColumnHeader">
            <Border Background="{DynamicResource Brush.Header}"
                    BorderBrush="{DynamicResource Brush.HeaderBorder}"
                    BorderThickness="0,0,1,1"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"
                                TextElement.Foreground="{StaticResource FgLight}"
                                TextElement.FontWeight="SemiBold"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ExactHandsButton" TargetType="Button">
      <Setter Property="Foreground" Value="{DynamicResource Brush.SurfaceText}"/>
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.HeaderBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="10,6"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                TextElement.Foreground="{DynamicResource Brush.SurfaceText}"
                                TextElement.FontWeight="SemiBold"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Brush.Card}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.65"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ExactFilterChip" TargetType="Button">
      <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
      <Setter Property="Background" Value="{DynamicResource Brush.Inset}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="10,5"/>
      <Setter Property="Margin" Value="0,0,6,6"/>
      <Setter Property="MinWidth" Value="74"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ChipBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="5"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}"
                                TextElement.FontWeight="SemiBold"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ChipBorder" Property="BorderBrush" Value="{DynamicResource Brush.Accent}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="MatrixCellButton" TargetType="Button">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="VerticalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Stretch"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="CellBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1">
              <ContentPresenter HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="CellBorder" Property="BorderBrush" Value="{DynamicResource Brush.Text}"/>
                <Setter TargetName="CellBorder" Property="BorderThickness" Value="2"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Opacity" Value="0.82"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                PanningMode="VerticalOnly">
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="490"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="360"/>
    </Grid.RowDefinitions>

    <Border Background="{DynamicResource Brush.Card}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14"
            Margin="0,0,0,10">
      <StackPanel HorizontalAlignment="Center">
        <TextBlock Text="{DynamicResource Common.MyTablesHeader}"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Background="{DynamicResource Brush.Card}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10"
            Margin="0,0,0,10">
      <DockPanel LastChildFill="True">
        <StackPanel Orientation="Horizontal"
                    DockPanel.Dock="Left"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="0,0,18,0">
          <Button x:Name="BtnPreflop" Style="{StaticResource StreetButton}" Content="PRE-FLOP" Tag="PREFLOP" Click="Street_Click" Margin="0,0,8,0"/>
          <Button x:Name="BtnFlop" Style="{StaticResource StreetButton}" Content="FLOP" Tag="FLOP" Click="Street_Click" Margin="0,0,8,0"/>
          <Button x:Name="BtnTurn" Style="{StaticResource StreetButton}" Content="TURN" Tag="TURN" Click="Street_Click" Margin="0,0,8,0"/>
          <Button x:Name="BtnRiver" Style="{StaticResource StreetButton}" Content="RIVER" Tag="RIVER" Click="Street_Click"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Left"
                    VerticalAlignment="Center"
                    Margin="0,0,18,0">
          <TextBlock Text="{DynamicResource Common.Color}" Style="{StaticResource FilterLabel}"/>
          <CheckBox x:Name="ProfitColorToggle"
                    Content="{DynamicResource Common.ProfitBb}"
                    Foreground="{DynamicResource Brush.Text}"
                    VerticalAlignment="Center"
                    Checked="ProfitColorToggle_Changed"
                    Unchecked="ProfitColorToggle_Changed"/>
        </StackPanel>

        <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Center">
          <StackPanel Margin="0,0,8,0">
            <TextBlock Text="{DynamicResource Common.Position}" Style="{StaticResource FilterLabel}"/>
            <ComboBox x:Name="PositionFilter" Style="{StaticResource FilterCombo}" SelectionChanged="Filter_Changed"/>
          </StackPanel>

          <StackPanel Margin="0,0,8,0">
            <TextBlock Text="{DynamicResource Grid.Table}" Style="{StaticResource FilterLabel}"/>
            <ComboBox x:Name="FormatFilter" Style="{StaticResource FilterCombo}" SelectionChanged="Filter_Changed"/>
          </StackPanel>

          <StackPanel Margin="0,0,8,0">
            <TextBlock Text="{DynamicResource Common.Type}" Style="{StaticResource FilterLabel}"/>
            <ComboBox x:Name="MoneyTypeFilter" Style="{StaticResource FilterCombo}" SelectionChanged="Filter_Changed"/>
          </StackPanel>

          <StackPanel Margin="0,0,8,0">
            <TextBlock Text="{DynamicResource Common.From}" Style="{StaticResource FilterLabel}"/>
            <DatePicker x:Name="FromDateFilter" Style="{StaticResource FilterDate}" SelectedDateChanged="Filter_Changed"/>
          </StackPanel>

          <StackPanel>
            <TextBlock Text="{DynamicResource Common.To}" Style="{StaticResource FilterLabel}"/>
            <DatePicker x:Name="ToDateFilter" Style="{StaticResource FilterDate}" SelectedDateChanged="Filter_Changed"/>
          </StackPanel>
        </WrapPanel>
      </DockPanel>
    </Border>

    <Border Grid.Row="2"
            Background="{DynamicResource Brush.Inset}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="8">
      <Grid>
        <UniformGrid x:Name="HandsGrid"
                     Rows="13"
                     Columns="13"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch"/>
      </Grid>
    </Border>

    <Border Grid.Row="3"
            Background="{DynamicResource Brush.Card}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12"
            Margin="0,14,0,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="0.9*"/>
          <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <StackPanel>
          <TextBlock x:Name="SelectedHandText" Text="{DynamicResource Common.SelectCell}" FontSize="18" FontWeight="Bold"/>
          <TextBlock x:Name="SelectedStreetText" Text="PRE-FLOP" Foreground="{DynamicResource Brush.TextDim}" Margin="0,4,0,0"/>
        </StackPanel>

        <ItemsControl x:Name="ActionSummaryList" Grid.Column="1">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel HorizontalAlignment="Right"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Background="{Binding Color}"
                      CornerRadius="5"
                      Padding="12,9"
                      Margin="5,0,0,0"
                      MinWidth="120">
                <StackPanel>
                  <TextBlock Text="{Binding Label}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="Bold" TextAlignment="Center"/>
                  <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource Brush.SurfaceText}" TextAlignment="Center" FontSize="12"/>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </Border>

    <Border x:Name="ExactHandsPanel"
            Grid.Row="4"
            Background="{DynamicResource Brush.Card}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10"
            Margin="0,14,0,0"
            Visibility="Collapsed"
            MinHeight="0"
            MaxHeight="360">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="ExactHandsTitle"
                   Text="{DynamicResource Common.ExactHands}"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,8"/>

        <DockPanel Grid.Row="1" Margin="0,0,0,8">
          <WrapPanel DockPanel.Dock="Left">
            <TextBlock Text="{DynamicResource Common.Action}" Foreground="{DynamicResource Brush.TextDim}" VerticalAlignment="Center" Margin="0,0,8,6"/>
            <Button x:Name="ActionAllChip" Content="{DynamicResource Common.All}" Tag="ALL" Style="{StaticResource ExactFilterChip}" Click="ExactActionFilter_Click"/>
            <Button x:Name="ActionFoldChip" Content="Fold" Tag="Fold" Style="{StaticResource ExactFilterChip}" Click="ExactActionFilter_Click"/>
            <Button x:Name="ActionCheckChip" Content="Check" Tag="Check" Style="{StaticResource ExactFilterChip}" Click="ExactActionFilter_Click"/>
            <Button x:Name="ActionCallChip" Content="Call" Tag="Call" Style="{StaticResource ExactFilterChip}" Click="ExactActionFilter_Click"/>
            <Button x:Name="ActionBetChip" Content="Bet" Tag="Bet" Style="{StaticResource ExactFilterChip}" Click="ExactActionFilter_Click"/>
            <Button x:Name="ActionRaiseChip" Content="Raise" Tag="Raise" Style="{StaticResource ExactFilterChip}" Click="ExactActionFilter_Click"/>
            <Button x:Name="ActionThreeBetChip" Content="3Bet" Tag="3Bet" Style="{StaticResource ExactFilterChip}" Click="ExactActionFilter_Click"/>
            <Button x:Name="ActionFourBetChip" Content="4Bet+" Tag="4Bet+" Style="{StaticResource ExactFilterChip}" Click="ExactActionFilter_Click"/>
            <Button x:Name="ActionAllInChip" Content="All-in" Tag="All-in" Style="{StaticResource ExactFilterChip}" Click="ExactActionFilter_Click"/>
          </WrapPanel>

          <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
            <TextBlock Text="{DynamicResource Common.Result}" Foreground="{DynamicResource Brush.TextDim}" VerticalAlignment="Center" Margin="12,0,8,6"/>
            <Button x:Name="ResultAllChip" Content="{DynamicResource Common.AllMale}" Tag="ALL" Style="{StaticResource ExactFilterChip}" Click="ExactResultFilter_Click"/>
            <Button x:Name="ResultWinChip" Content="{DynamicResource Common.Won}" Tag="WIN" Style="{StaticResource ExactFilterChip}" Click="ExactResultFilter_Click"/>
            <Button x:Name="ResultLossChip" Content="{DynamicResource Common.Lost}" Tag="LOSS" Style="{StaticResource ExactFilterChip}" Click="ExactResultFilter_Click"/>
          </WrapPanel>
        </DockPanel>

        <DataGrid x:Name="ExactHandsGrid"
                  Grid.Row="2"
                  MouseLeftButtonUp="ExactHandsGrid_MouseLeftButtonUp"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  RowHeight="26"
                  Background="{DynamicResource Brush.Inset}"
                  RowBackground="{DynamicResource Brush.Inset}"
                  AlternatingRowBackground="{DynamicResource Brush.Panel}"
                  Foreground="{DynamicResource Brush.Text}"
                  BorderBrush="{DynamicResource Brush.Border}"
                  ColumnHeaderStyle="{StaticResource ExactHandsHeaderStyle}"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{DynamicResource Brush.Border}"
                  VerticalScrollBarVisibility="Auto">
          <DataGrid.Resources>
            <Style TargetType="DataGridCell">
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Padding" Value="6,2"/>
            </Style>
          </DataGrid.Resources>
          <DataGrid.Columns>
            <DataGridTextColumn Header="{DynamicResource Grid.Table}" Binding="{Binding TableName}" Width="2.2*"/>
            <DataGridTextColumn Header="{DynamicResource Common.DateTime}" Binding="{Binding HandDateTimeLabel}" Width="1.2*"/>
            <DataGridTextColumn Header="{DynamicResource Common.TableHand}" Binding="{Binding HandNumber}" Width="0.8*"/>
            <DataGridTemplateColumn Header="{DynamicResource Common.ExactHand}" Width="0.9*">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <ContentControl Content="{Binding ExactCardChips}"
                                  ContentTemplate="{StaticResource CardChipListTemplate}"
                                  HorizontalAlignment="Center"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="{DynamicResource Common.Position}" Binding="{Binding Position}" Width="0.7*"/>
            <DataGridTemplateColumn Header="Spot" Width="1.35*">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <ContentControl Content="{Binding SpotCardChips}"
                                  ContentTemplate="{StaticResource CardChipListTemplate}"
                                  HorizontalAlignment="Center"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="{DynamicResource Common.Action}" Binding="{Binding ActionLabel}" Width="1*"/>
            <DataGridTemplateColumn Header="{DynamicResource Common.Result}" Width="0.9*">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding NetTrendIcon}" FontWeight="Bold" Margin="0,0,5,0" Foreground="{Binding NetTrendBrush}"/>
                    <TextBlock Text="{Binding NetBbLabel}" Foreground="{DynamicResource Brush.Text}"/>
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
      </Grid>
    </Border>
  </Grid>
  </ScrollViewer>
</Window>




