<Window x:Class="Hud.App.Views.DataVillainsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Hud.App.Views"
        Title="{DynamicResource Common.DataVillainsTitle}"
        Height="620"
        Width="1660"
        MinHeight="460"
        MinWidth="1180"
        Background="{DynamicResource Brush.AppShell}"
        WindowStartupLocation="CenterOwner">

  <Window.Resources>
    <views:StatToBrushConverter x:Key="StatToBrush"/>
    <views:StatTextBrushConverter x:Key="StatTextBrush"/>
    <views:TotalHandsRowBrushConverter x:Key="TotalHandsRowBrush"/>
    <views:TotalHandsTextBrushConverter x:Key="TotalHandsTextBrush"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{DynamicResource Col.Accent}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="Black"/>

    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="HeaderStyle" TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="{DynamicResource Brush.Header}"/>
      <Setter Property="Foreground" Value="{StaticResource FgLight}"/>
      <Setter Property="TextElement.Foreground" Value="{StaticResource FgLight}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Padding" Value="4"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
      <Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>

    <Style x:Key="CellText" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{Binding TotalHands, Converter={StaticResource TotalHandsTextBrush}}"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Padding" Value="4,0"/>
    </Style>

    <Style x:Key="CenterCellText" TargetType="TextBlock" BasedOn="{StaticResource CellText}">
      <Setter Property="TextAlignment" Value="Center"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <Style x:Key="StatCellText" TargetType="TextBlock">
      <Setter Property="TextAlignment" Value="Center"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Padding" Value="1"/>
      <Setter Property="Margin" Value="4,5"/>
    </Style>

    <Style x:Key="SampleCellStyle" TargetType="DataGridCell">
      <Setter Property="Background" Value="{Binding TotalHands, Converter={StaticResource TotalHandsRowBrush}}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
      <Setter Property="BorderThickness" Value="0,0,1,1"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#118FD3F4"/>
          <Setter Property="Foreground" Value="Black"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <DataTemplate x:Key="FilterComboItemTemplate">
      <TextBlock Text="{Binding}" Foreground="{DynamicResource Brush.SurfaceText}"/>
    </DataTemplate>

    <Style x:Key="FilterLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextDim}"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Margin" Value="0,0,0,3"/>
    </Style>

    <Style x:Key="FilterTextBox" TargetType="TextBox">
      <Setter Property="Height" Value="28"/>
      <Setter Property="Foreground" Value="{DynamicResource Brush.SurfaceText}"/>
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.HeaderBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="7,3"/>
    </Style>

    <Style x:Key="FilterComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
      <Setter Property="Height" Value="28"/>
      <Setter Property="Foreground" Value="{DynamicResource Brush.SurfaceText}"/>
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.HeaderBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="7,3"/>
      <Setter Property="ItemTemplate" Value="{StaticResource FilterComboItemTemplate}"/>
    </Style>
  </Window.Resources>

  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Border Style="{StaticResource ProjectPanelBorder}"
            Padding="14"
            Margin="0,0,0,10">
      <StackPanel HorizontalAlignment="Center">
          <TextBlock Text="{DynamicResource Common.DataVillainsHeader}"
                   FontSize="24"
                   FontWeight="Bold"
                   TextAlignment="Center"
                   HorizontalAlignment="Center"/>
        <TextBlock x:Name="SummaryText"
                   Foreground="{DynamicResource Brush.TextDim}"
                   Margin="0,4,0,0"
                   TextAlignment="Center"/>
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Style="{StaticResource ProjectPanelBorder}"
            Padding="10"
            Margin="0,0,0,10">
      <WrapPanel>
        <StackPanel Width="150" Margin="0,0,10,6">
          <TextBlock Text="{DynamicResource Common.Search}" Style="{StaticResource FilterLabel}"/>
          <TextBox x:Name="SearchBox"
                   Style="{StaticResource FilterTextBox}"
                   TextChanged="Filter_Changed"/>
        </StackPanel>

        <StackPanel Width="125" Margin="0,0,10,6">
          <TextBlock Text="{DynamicResource Grid.Date}" Style="{StaticResource FilterLabel}"/>
          <ComboBox x:Name="DateFilter"
                    Style="{StaticResource FilterComboBox}"
                    SelectionChanged="Filter_Changed"/>
        </StackPanel>

        <StackPanel Width="125" Margin="0,0,10,6">
          <TextBlock Text="{DynamicResource Grid.Format}" Style="{StaticResource FilterLabel}"/>
          <ComboBox x:Name="FormatFilter"
                    Style="{StaticResource FilterComboBox}"
                    SelectionChanged="Filter_Changed"/>
        </StackPanel>

        <StackPanel Width="105" Margin="0,0,10,6">
          <TextBlock Text="{DynamicResource Common.Type}" Style="{StaticResource FilterLabel}"/>
          <ComboBox x:Name="MoneyTypeFilter"
                    Style="{StaticResource FilterComboBox}"
                    SelectionChanged="Filter_Changed"/>
        </StackPanel>

        <StackPanel Width="105" Margin="0,0,10,6">
          <TextBlock Text="{DynamicResource Global.MinHands}" Style="{StaticResource FilterLabel}"/>
          <ComboBox x:Name="HandsFilter"
                    Style="{StaticResource FilterComboBox}"
                    SelectionChanged="Filter_Changed"/>
        </StackPanel>

        <StackPanel Width="140" Margin="0,0,10,6">
          <TextBlock Text="{DynamicResource Common.Result}" Style="{StaticResource FilterLabel}"/>
          <ComboBox x:Name="ResultFilter"
                    Style="{StaticResource FilterComboBox}"
                    SelectionChanged="Filter_Changed"/>
        </StackPanel>

        <StackPanel Width="135" Margin="0,0,10,6">
          <TextBlock Text="{DynamicResource Common.SessionBb}" Style="{StaticResource FilterLabel}"/>
          <ComboBox x:Name="SessionBbFilter"
                    Style="{StaticResource FilterComboBox}"
                    SelectionChanged="Filter_Changed"/>
        </StackPanel>

        <StackPanel Width="130" Margin="0,0,10,6">
          <TextBlock Text="{DynamicResource Common.TotalBb}" Style="{StaticResource FilterLabel}"/>
          <ComboBox x:Name="TotalBbFilter"
                    Style="{StaticResource FilterComboBox}"
                    SelectionChanged="Filter_Changed"/>
        </StackPanel>

        <StackPanel Width="145" Margin="0,0,10,6">
          <TextBlock Text="{DynamicResource Common.Profile}" Style="{StaticResource FilterLabel}"/>
          <ComboBox x:Name="ProfileFilter"
                    Style="{StaticResource FilterComboBox}"
                    SelectionChanged="Filter_Changed"/>
        </StackPanel>

        <StackPanel Width="175" Margin="0,0,10,6">
          <TextBlock Text="{DynamicResource Common.Sort}" Style="{StaticResource FilterLabel}"/>
          <ComboBox x:Name="SortFilter"
                    Style="{StaticResource FilterComboBox}"
                    SelectionChanged="Filter_Changed"/>
        </StackPanel>
      </WrapPanel>
    </Border>

    <Border Grid.Row="2"
            Style="{StaticResource ProjectPanelBorder}"
            Padding="8">
      <DataGrid ItemsSource="{Binding Villains}"
                x:Name="VillainsGrid"
                SelectionMode="Single"
                SelectionUnit="FullRow"
                SelectionChanged="VillainsGrid_SelectionChanged"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserReorderColumns="False"
                CanUserResizeColumns="False"
                CanUserResizeRows="False"
                CanUserSortColumns="False"
                IsReadOnly="True"
                RowHeaderWidth="0"
                RowHeight="30"
                HeadersVisibility="Column"
                GridLinesVisibility="None"
                Background="{StaticResource BgDark}"
                RowBackground="{DynamicResource Brush.Inset}"
                AlternatingRowBackground="{DynamicResource Brush.Card}"
                BorderBrush="{StaticResource BorderDark}"
                BorderThickness="1"
                Foreground="{StaticResource FgLight}"
                ColumnHeaderStyle="{StaticResource HeaderStyle}"
                CellStyle="{StaticResource SampleCellStyle}"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto">
        <DataGrid.RowStyle>
          <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{Binding TotalHands, Converter={StaticResource TotalHandsRowBrush}}"/>
          </Style>
        </DataGrid.RowStyle>
        <DataGrid.Columns>
          <DataGridTextColumn Header="{DynamicResource Common.Villain}" Binding="{Binding Name}" Width="170" ElementStyle="{StaticResource CellText}"/>
          <DataGridTextColumn Header="{DynamicResource Common.RecentTable}" Binding="{Binding RecentTable}" Width="190" ElementStyle="{StaticResource CellText}"/>
          <DataGridTextColumn Header="{DynamicResource Common.DateTime}" Binding="{Binding LastSeenLabel}" Width="136" ElementStyle="{StaticResource CenterCellText}"/>
          <DataGridTextColumn Header="{DynamicResource Common.SessionVs}" Binding="{Binding SessionHandsVsHero}" Width="78" ElementStyle="{StaticResource CenterCellText}"/>
          <DataGridTextColumn Header="Total-Vs" Binding="{Binding TotalHandsVsHero}" Width="78" ElementStyle="{StaticResource CenterCellText}"/>
          <DataGridTextColumn Header="{DynamicResource Common.TotalHands}" Binding="{Binding TotalHands}" Width="92" ElementStyle="{StaticResource CenterCellText}"/>
          <DataGridTextColumn Header="{DynamicResource Common.Profile}" Binding="{Binding Profile}" Width="96" ElementStyle="{StaticResource CenterCellText}"/>

          <DataGridTemplateColumn Header="VPIP%" Width="72">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding VPIPPct, StringFormat={}{0:0.#}%}" Style="{StaticResource StatCellText}" Foreground="{Binding TotalHands, Converter={StaticResource StatTextBrush}}">
                  <TextBlock.Background>
                    <MultiBinding Converter="{StaticResource StatToBrush}">
                      <Binding Path="VPIPPct"/>
                      <Binding Path="TotalHands"/>
                      <Binding Path="Stake"/>
                      <Binding Source="VPIP"/>
                    </MultiBinding>
                  </TextBlock.Background>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="PFR%" Width="72">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding PFRPct, StringFormat={}{0:0.#}%}" Style="{StaticResource StatCellText}" Foreground="{Binding TotalHands, Converter={StaticResource StatTextBrush}}">
                  <TextBlock.Background>
                    <MultiBinding Converter="{StaticResource StatToBrush}">
                      <Binding Path="PFRPct"/>
                      <Binding Path="TotalHands"/>
                      <Binding Path="Stake"/>
                      <Binding Source="PFR"/>
                    </MultiBinding>
                  </TextBlock.Background>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="3Bet%" Width="72">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding ThreeBetPct, StringFormat={}{0:0.#}%}" Style="{StaticResource StatCellText}" Foreground="{Binding TotalHands, Converter={StaticResource StatTextBrush}}">
                  <TextBlock.Background>
                    <MultiBinding Converter="{StaticResource StatToBrush}">
                      <Binding Path="ThreeBetPct"/>
                      <Binding Path="TotalHands"/>
                      <Binding Path="Stake"/>
                      <Binding Source="THREEBET"/>
                    </MultiBinding>
                  </TextBlock.Background>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="AF" Width="64">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding AF, StringFormat={}{0:0.#}}" Style="{StaticResource StatCellText}" Foreground="{Binding TotalHands, Converter={StaticResource StatTextBrush}}">
                  <TextBlock.Background>
                    <MultiBinding Converter="{StaticResource StatToBrush}">
                      <Binding Path="AF"/>
                      <Binding Path="TotalHands"/>
                      <Binding Path="Stake"/>
                      <Binding Source="AF"/>
                    </MultiBinding>
                  </TextBlock.Background>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="AFq%" Width="72">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding AFqPct, StringFormat={}{0:0.#}%}" Style="{StaticResource StatCellText}" Foreground="{Binding TotalHands, Converter={StaticResource StatTextBrush}}">
                  <TextBlock.Background>
                    <MultiBinding Converter="{StaticResource StatToBrush}">
                      <Binding Path="AFqPct"/>
                      <Binding Path="TotalHands"/>
                      <Binding Path="Stake"/>
                      <Binding Source="AFQ"/>
                    </MultiBinding>
                  </TextBlock.Background>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="CBet%" Width="72">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding CBetFlopPct, StringFormat={}{0:0.#}%}" Style="{StaticResource StatCellText}" Foreground="{Binding TotalHands, Converter={StaticResource StatTextBrush}}">
                  <TextBlock.Background>
                    <MultiBinding Converter="{StaticResource StatToBrush}">
                      <Binding Path="CBetFlopPct"/>
                      <Binding Path="TotalHands"/>
                      <Binding Path="Stake"/>
                      <Binding Source="CBF"/>
                    </MultiBinding>
                  </TextBlock.Background>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="FvCB%" Width="76">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding FoldVsCBetFlopPct, StringFormat={}{0:0.#}%}" Style="{StaticResource StatCellText}" Foreground="{Binding TotalHands, Converter={StaticResource StatTextBrush}}">
                  <TextBlock.Background>
                    <MultiBinding Converter="{StaticResource StatToBrush}">
                      <Binding Path="FoldVsCBetFlopPct"/>
                      <Binding Path="TotalHands"/>
                      <Binding Path="Stake"/>
                      <Binding Source="FVCBF"/>
                    </MultiBinding>
                  </TextBlock.Background>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="WTSD%" Width="72">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding WTSDPct, StringFormat={}{0:0.#}%}" Style="{StaticResource StatCellText}" Foreground="{Binding TotalHands, Converter={StaticResource StatTextBrush}}">
                  <TextBlock.Background>
                    <MultiBinding Converter="{StaticResource StatToBrush}">
                      <Binding Path="WTSDPct"/>
                      <Binding Path="TotalHands"/>
                      <Binding Path="Stake"/>
                      <Binding Source="WTSD"/>
                    </MultiBinding>
                  </TextBlock.Background>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="W$SD%" Width="72">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding WSDPct, StringFormat={}{0:0.#}%}" Style="{StaticResource StatCellText}" Foreground="{Binding TotalHands, Converter={StaticResource StatTextBrush}}">
                  <TextBlock.Background>
                    <MultiBinding Converter="{StaticResource StatToBrush}">
                      <Binding Path="WSDPct"/>
                      <Binding Path="TotalHands"/>
                      <Binding Path="Stake"/>
                      <Binding Source="WSD"/>
                    </MultiBinding>
                  </TextBlock.Background>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="WWSF%" Width="72">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding WWSFPct, StringFormat={}{0:0.#}%}" Style="{StaticResource StatCellText}" Foreground="{Binding TotalHands, Converter={StaticResource StatTextBrush}}">
                  <TextBlock.Background>
                    <MultiBinding Converter="{StaticResource StatToBrush}">
                      <Binding Path="WWSFPct"/>
                      <Binding Path="TotalHands"/>
                      <Binding Path="Stake"/>
                      <Binding Source="WWSF"/>
                    </MultiBinding>
                  </TextBlock.Background>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="BB sesion" Width="96">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                  <TextBlock Text="{Binding SessionTrendIcon}" FontWeight="Bold" Margin="0,0,5,0" Foreground="{Binding SessionTrendBrush}"/>
                  <TextBlock Text="{Binding SessionNetBb, StringFormat={}{0:0.#} bb}" Foreground="{Binding TotalHands, Converter={StaticResource TotalHandsTextBrush}}"/>
                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="BB total" Width="92">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                  <TextBlock Text="{Binding TotalTrendIcon}" FontWeight="Bold" Margin="0,0,5,0" Foreground="{Binding TotalTrendBrush}"/>
                  <TextBlock Text="{Binding TotalNetBb, StringFormat={}{0:0.#} bb}" Foreground="{Binding TotalHands, Converter={StaticResource TotalHandsTextBrush}}"/>
                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>
  </Grid>
</Window>



