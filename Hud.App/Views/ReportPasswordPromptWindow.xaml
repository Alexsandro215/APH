<Window x:Class="Hud.App.Views.ReportPasswordPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="APH - Contrasena"
        Width="390"
        Height="190"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.AppShell}">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Text="Reporte protegido"
               FontSize="20"
               FontWeight="Bold"
               Foreground="{DynamicResource Brush.Text}"/>
    <TextBlock Grid.Row="1"
               Text="Escribe la contrasena actual de reportes para continuar."
               Foreground="{DynamicResource Brush.TextDim}"
               Margin="0,4,0,12"/>
    <PasswordBox Grid.Row="2"
                 x:Name="PasswordInput"
                 Height="32"
                 Padding="8,4"
                 KeyDown="PasswordInput_KeyDown"/>
    <TextBlock Grid.Row="3"
               x:Name="ErrorText"
               Foreground="{DynamicResource Brush.Negative}"
               Margin="0,8,0,0"/>
    <StackPanel Grid.Row="4"
                Orientation="Horizontal"
                HorizontalAlignment="Right">
      <Button Content="Cancelar"
              Width="92"
              Margin="0,0,8,0"
              Click="BtnCancel_Click"/>
      <Button Content="Aceptar"
              Width="92"
              Style="{StaticResource Btn.Primary}"
              Click="BtnOk_Click"/>
    </StackPanel>
  </Grid>
</Window>
