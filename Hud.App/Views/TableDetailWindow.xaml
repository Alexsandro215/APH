<Window x:Class="Hud.App.Views.TableDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Hud.App.Views"
        Title="{DynamicResource Common.TableAnalysisTitle}"
        Height="760"
        Width="1280"
        MinHeight="620"
        MinWidth="1040"
        Background="{DynamicResource Brush.Bg}">

  <Window.Resources>
    <views:StatToBrushConverter x:Key="StatToBrush"/>
    <views:StatTextBrushConverter x:Key="StatTextBrush"/>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="LabelText" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextDim}"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Margin" Value="0,0,0,3"/>
    </Style>

    <Style x:Key="ValueText" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource FgLight}"/>
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="InfoCell" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="10"/>
      <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <Style x:Key="HandListItem" TargetType="ListBoxItem">
      <Setter Property="Foreground" Value="{StaticResource FgLight}"/>
      <Setter Property="Background" Value="{Binding ResultBackground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="Padding" Value="8"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="{DynamicResource Brush.Inset}"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="ActionText" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource FgLight}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="Padding" Value="6,3"/>
      <Setter Property="Margin" Value="0,0,0,3"/>
      <Setter Property="Background" Value="{DynamicResource Brush.Inset}"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsHero}" Value="True">
          <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}"/>
          <Setter Property="FontWeight" Value="Bold"/>
          <Setter Property="Background" Value="{DynamicResource Brush.Inset}"/>
        </DataTrigger>
        <DataTrigger Binding="{Binding IsSystem}" Value="True">
          <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}"/>
          <Setter Property="FontWeight" Value="SemiBold"/>
          <Setter Property="Background" Value="{DynamicResource Brush.Inset}"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <ItemsPanelTemplate x:Key="InlineSegmentsPanel">
      <StackPanel Orientation="Horizontal"/>
    </ItemsPanelTemplate>

    <DataTemplate x:Key="TextSegmentTemplate">
      <TextBlock Text="{Binding Text}" Foreground="{Binding Foreground}" FontWeight="{Binding FontWeight}"/>
    </DataTemplate>

    <DataTemplate x:Key="ActionVisualPartTemplate">
      <Grid VerticalAlignment="Center">
        <TextBlock Text="{Binding Text}"
                   Foreground="{Binding Foreground}"
                   FontWeight="{Binding FontWeight}"
                   Visibility="{Binding IsText, Converter={StaticResource BoolToVisibility}}"/>
        <ContentControl Content="{Binding CardChips}"
                        ContentTemplate="{StaticResource CardChipListTemplate}"
                        Visibility="{Binding IsCards, Converter={StaticResource BoolToVisibility}}"
                        Margin="1,0"/>
      </Grid>
    </DataTemplate>

    <Style x:Key="StatCellText" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}"/>
      <Setter Property="TextAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Padding" Value="4,3"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
  </Window.Resources>

  <Grid Background="{DynamicResource Brush.Bg}" Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="1.95*"/>
      <RowDefinition Height="1.1*"/>
    </Grid.RowDefinitions>

    <Border Background="{DynamicResource Brush.Card}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10"
            Margin="0,0,0,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="2.2*"/>
          <ColumnDefinition Width="0.85*"/>
          <ColumnDefinition Width="0.75*"/>
          <ColumnDefinition Width="0.75*"/>
          <ColumnDefinition Width="0.9*"/>
          <ColumnDefinition Width="0.9*"/>
          <ColumnDefinition Width="0.75*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,12,0">
          <TextBlock Text="{DynamicResource Grid.Table}" Style="{StaticResource LabelText}"/>
          <TextBlock Text="{Binding TableName}" Style="{StaticResource ValueText}" FontSize="18"/>
        </StackPanel>
        <StackPanel Grid.Column="1">
          <TextBlock Text="{DynamicResource Grid.Format}" Style="{StaticResource LabelText}"/>
          <TextBlock Text="{Binding GameFormat}" Style="{StaticResource ValueText}"/>
        </StackPanel>
        <StackPanel Grid.Column="2">
          <TextBlock Text="{DynamicResource Grid.Date}" Style="{StaticResource LabelText}"/>
          <TextBlock Text="{Binding PlayedDate}" Style="{StaticResource ValueText}"/>
        </StackPanel>
        <StackPanel Grid.Column="3">
          <TextBlock Text="{DynamicResource Common.Hands}" Style="{StaticResource LabelText}"/>
          <TextBlock Text="{Binding HandsReceived}" Style="{StaticResource ValueText}"/>
        </StackPanel>
        <StackPanel Grid.Column="4">
        <TextBlock Text="{DynamicResource Grid.FinalBb}" Style="{StaticResource LabelText}"/>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="{Binding TrendIcon}" FontWeight="Bold" FontSize="16" Margin="0,0,6,0">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Foreground" Value="{DynamicResource Brush.Negative}"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsWin}" Value="True">
                      <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="{Binding NetBb, StringFormat={}{0:0.#} bb}" Style="{StaticResource ValueText}"/>
          </StackPanel>
        </StackPanel>
        <StackPanel Grid.Column="5">
          <TextBlock Text="{DynamicResource Common.Result}" Style="{StaticResource LabelText}"/>
          <TextBlock Text="{Binding NetAmountLabel}">
            <TextBlock.Style>
              <Style TargetType="TextBlock" BasedOn="{StaticResource ValueText}">
                <Setter Property="Foreground" Value="{DynamicResource Brush.Negative}"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsProfitable}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </StackPanel>
        <StackPanel Grid.Column="6">
          <TextBlock Text="{DynamicResource Common.Type}" Style="{StaticResource LabelText}"/>
          <TextBlock Text="{Binding MoneyTypeLabel}" Style="{StaticResource ValueText}"/>
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Background="{DynamicResource Brush.Card}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="6"
            Margin="0,0,0,10">
      <UniformGrid Columns="10" Rows="1">
        <TextBlock Text="{Binding VPIPPct, StringFormat=VPIP {0:0.#}%}" Style="{StaticResource StatCellText}" Margin="0,0,2,0">
          <TextBlock.Background>
            <MultiBinding Converter="{StaticResource StatToBrush}">
              <Binding Path="VPIPPct"/>
              <Binding Path="HandsReceived"/>
              <Binding Path="Stake"/>
              <Binding Source="VPIP"/>
            </MultiBinding>
          </TextBlock.Background>
        </TextBlock>
        <TextBlock Text="{Binding PFRPct, StringFormat=PFR {0:0.#}%}" Style="{StaticResource StatCellText}" Margin="0,0,2,0">
          <TextBlock.Background>
            <MultiBinding Converter="{StaticResource StatToBrush}">
              <Binding Path="PFRPct"/>
              <Binding Path="HandsReceived"/>
              <Binding Path="Stake"/>
              <Binding Source="PFR"/>
            </MultiBinding>
          </TextBlock.Background>
        </TextBlock>
        <TextBlock Text="{Binding ThreeBetPct, StringFormat=3Bet {0:0.#}%}" Style="{StaticResource StatCellText}" Margin="0,0,2,0">
          <TextBlock.Background>
            <MultiBinding Converter="{StaticResource StatToBrush}">
              <Binding Path="ThreeBetPct"/>
              <Binding Path="HandsReceived"/>
              <Binding Path="Stake"/>
              <Binding Source="THREEBET"/>
            </MultiBinding>
          </TextBlock.Background>
        </TextBlock>
        <TextBlock Text="{Binding AF, StringFormat=AF {0:0.#}}" Style="{StaticResource StatCellText}" Margin="0,0,2,0">
          <TextBlock.Background>
            <MultiBinding Converter="{StaticResource StatToBrush}">
              <Binding Path="AF"/>
              <Binding Path="HandsReceived"/>
              <Binding Path="Stake"/>
              <Binding Source="AF"/>
            </MultiBinding>
          </TextBlock.Background>
        </TextBlock>
        <TextBlock Text="{Binding AFqPct, StringFormat=AFq {0:0.#}%}" Style="{StaticResource StatCellText}" Margin="0,0,2,0">
          <TextBlock.Background>
            <MultiBinding Converter="{StaticResource StatToBrush}">
              <Binding Path="AFqPct"/>
              <Binding Path="HandsReceived"/>
              <Binding Path="Stake"/>
              <Binding Source="AFQ"/>
            </MultiBinding>
          </TextBlock.Background>
        </TextBlock>
        <TextBlock Text="{Binding CBetFlopPct, StringFormat=CBet {0:0.#}%}" Style="{StaticResource StatCellText}" Margin="0,0,2,0">
          <TextBlock.Background>
            <MultiBinding Converter="{StaticResource StatToBrush}">
              <Binding Path="CBetFlopPct"/>
              <Binding Path="HandsReceived"/>
              <Binding Path="Stake"/>
              <Binding Source="CBF"/>
            </MultiBinding>
          </TextBlock.Background>
        </TextBlock>
        <TextBlock Text="{Binding FoldVsCBetFlopPct, StringFormat=FvCB {0:0.#}%}" Style="{StaticResource StatCellText}" Margin="0,0,2,0">
          <TextBlock.Background>
            <MultiBinding Converter="{StaticResource StatToBrush}">
              <Binding Path="FoldVsCBetFlopPct"/>
              <Binding Path="HandsReceived"/>
              <Binding Path="Stake"/>
              <Binding Source="FVCBF"/>
            </MultiBinding>
          </TextBlock.Background>
        </TextBlock>
        <TextBlock Text="{Binding WTSDPct, StringFormat=WTSD {0:0.#}%}" Style="{StaticResource StatCellText}" Margin="0,0,2,0">
          <TextBlock.Background>
            <MultiBinding Converter="{StaticResource StatToBrush}">
              <Binding Path="WTSDPct"/>
              <Binding Path="HandsReceived"/>
              <Binding Path="Stake"/>
              <Binding Source="WTSD"/>
            </MultiBinding>
          </TextBlock.Background>
        </TextBlock>
        <TextBlock Text="{Binding WSDPct, StringFormat=W$SD {0:0.#}%}" Style="{StaticResource StatCellText}" Margin="0,0,2,0">
          <TextBlock.Background>
            <MultiBinding Converter="{StaticResource StatToBrush}">
              <Binding Path="WSDPct"/>
              <Binding Path="HandsReceived"/>
              <Binding Path="Stake"/>
              <Binding Source="WSD"/>
            </MultiBinding>
          </TextBlock.Background>
        </TextBlock>
        <TextBlock Text="{Binding WWSFPct, StringFormat=WWSF {0:0.#}%}" Style="{StaticResource StatCellText}">
          <TextBlock.Background>
            <MultiBinding Converter="{StaticResource StatToBrush}">
              <Binding Path="WWSFPct"/>
              <Binding Path="HandsReceived"/>
              <Binding Path="Stake"/>
              <Binding Source="WWSF"/>
            </MultiBinding>
          </TextBlock.Background>
        </TextBlock>
      </UniformGrid>
    </Border>

    <Grid Grid.Row="2" Margin="0,0,0,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1*"/>
        <ColumnDefinition Width="3*"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Background="{DynamicResource Brush.Card}"
              BorderBrush="{DynamicResource Brush.Border}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="10"
              Margin="0,0,12,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Text="{DynamicResource Common.HandsTitle}"
                     FontSize="16"
                     FontWeight="Bold"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,8"/>
          <ListBox x:Name="HandsList"
                   Grid.Row="1"
                   ItemsSource="{Binding Hands}"
                   SelectedItem="{Binding SelectedHand, Mode=TwoWay}"
                   ItemContainerStyle="{StaticResource HandListItem}"
                   Background="{StaticResource BgDark}"
                   BorderThickness="0"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <Viewbox Grid.ColumnSpan="2"
                           Width="38"
                           Height="38"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Opacity="0.9"
                           IsHitTestVisible="False"
                           Panel.ZIndex="0">
                    <Viewbox.Style>
                      <Style TargetType="Viewbox">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsHugeWin}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Viewbox.Style>
                    <Polygon Points="50,4 61,36 95,36 67,56 78,90 50,69 22,90 33,56 5,36 39,36"
                             Fill="#FFE25A"
                             Stroke="#E8D6A2"
                             StrokeThickness="5"/>
                  </Viewbox>

                  <StackPanel Panel.ZIndex="1">
                    <TextBlock Text="{Binding HandNumberLabel}" FontWeight="SemiBold" Foreground="{StaticResource FgLight}"/>
                    <ContentControl Content="{Binding CardChips}"
                                    ContentTemplate="{StaticResource CardChipListTemplate}"
                                    Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding PositionLabel}" Foreground="{DynamicResource Brush.Accent}" FontSize="11" Margin="0,2,0,0"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1" HorizontalAlignment="Right" Panel.ZIndex="1">
                    <TextBlock Text="{Binding NetBbLabel}" FontWeight="SemiBold" TextAlignment="Right">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Foreground" Value="{DynamicResource Brush.Negative}"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsProfitable}" Value="True">
                              <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding CumulativeBbLabel}" Foreground="{DynamicResource Brush.TextDim}" TextAlignment="Right"/>
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <Border Grid.Column="1"
              Background="{DynamicResource Brush.Card}"
              BorderBrush="{DynamicResource Brush.Border}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="10">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Text="{DynamicResource Common.ProfitChart}"
                     FontSize="16"
                     FontWeight="Bold"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,8"/>
          <Canvas x:Name="ProfitChart"
                  Grid.Row="1"
                  Background="{DynamicResource Brush.Inset}"
                  SizeChanged="ProfitChart_SizeChanged"
                  MouseMove="ProfitChart_MouseMove"
                  MouseLeave="ProfitChart_MouseLeave"
                  MouseLeftButtonDown="ProfitChart_MouseLeftButtonDown"/>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="3"
            Background="{DynamicResource Brush.Card}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Margin="0,0,0,8">
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
            <TextBlock Text="{Binding SelectedHand.HandNumberLabel}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource FgLight}"/>
            <TextBlock Text=" | " FontSize="16" FontWeight="Bold" Foreground="{StaticResource FgLight}"/>
            <ContentControl Content="{Binding SelectedHand.CardChips}"
                            ContentTemplate="{StaticResource CardChipListTemplate}"
                            VerticalAlignment="Center"/>
            <TextBlock Text="{Binding SelectedHandTitleSuffix}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource FgLight}"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <TextBlock Text="{Binding SelectedHand.ResultSummary}" FontWeight="Bold" Foreground="{DynamicResource Brush.Accent}" FontSize="14"/>
            <TextBlock Text=" | " FontWeight="Bold" Foreground="{DynamicResource Brush.TextDim}" Margin="5,0"/>
            <TextBlock Text="{Binding SelectedHand.MadeHand}" FontWeight="Bold" Foreground="{StaticResource FgLight}" FontSize="14"/>

            <StackPanel Orientation="Horizontal" Visibility="{Binding SelectedHand.HasVillainCards, Converter={StaticResource BoolToVisibility}}" Margin="15,0,0,0">
              <TextBlock Text=" vs " Foreground="{DynamicResource Brush.TextDim}" VerticalAlignment="Center"/>
              <TextBlock Text="{Binding SelectedHand.VillainName}" FontWeight="Bold" Foreground="{DynamicResource Brush.Accent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
              <ContentControl Content="{Binding SelectedHand.VillainCardChips}" ContentTemplate="{StaticResource CardChipListTemplate}" VerticalAlignment="Center"/>
              <TextBlock Text=" (" Foreground="{DynamicResource Brush.TextDim}" VerticalAlignment="Center"/>
              <TextBlock Text="{Binding SelectedHand.VillainCombination}" Foreground="{StaticResource FgLight}" VerticalAlignment="Center"/>
              <TextBlock Text=")" Foreground="{DynamicResource Brush.TextDim}" VerticalAlignment="Center"/>
            </StackPanel>
          </StackPanel>
        </Grid>
        <Grid Grid.Row="1">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <Border Grid.Column="0" Style="{StaticResource InfoCell}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <TextBlock Text="PRE-FLOP" Style="{StaticResource LabelText}" FontWeight="Bold"/>
              <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding SelectedHand.PreflopActions}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{Binding Background}" Padding="6,3" Margin="0,0,0,3">
                        <ItemsControl ItemsSource="{Binding VisualParts}"
                                      ItemsPanel="{StaticResource InlineSegmentsPanel}"
                                      ItemTemplate="{StaticResource ActionVisualPartTemplate}"/>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </Border>
          <Border Grid.Column="1" Style="{StaticResource InfoCell}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                <TextBlock Text="FLOP" Style="{StaticResource LabelText}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ContentControl Content="{Binding SelectedHand.FlopCardChips}" ContentTemplate="{StaticResource CardChipListTemplate}" VerticalAlignment="Center"/>
              </StackPanel>
              <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding SelectedHand.FlopActions}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{Binding Background}" Padding="6,3" Margin="0,0,0,3">
                        <ItemsControl ItemsSource="{Binding VisualParts}"
                                      ItemsPanel="{StaticResource InlineSegmentsPanel}"
                                      ItemTemplate="{StaticResource ActionVisualPartTemplate}"/>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </Border>
          <Border Grid.Column="2" Style="{StaticResource InfoCell}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                <TextBlock Text="TURN" Style="{StaticResource LabelText}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ContentControl Content="{Binding SelectedHand.TurnCardChips}" ContentTemplate="{StaticResource CardChipListTemplate}" VerticalAlignment="Center"/>
              </StackPanel>
              <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding SelectedHand.TurnActions}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{Binding Background}" Padding="6,3" Margin="0,0,0,3">
                        <ItemsControl ItemsSource="{Binding VisualParts}"
                                      ItemsPanel="{StaticResource InlineSegmentsPanel}"
                                      ItemTemplate="{StaticResource ActionVisualPartTemplate}"/>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </Border>
          <Border Grid.Column="3" Style="{StaticResource InfoCell}" Margin="0">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                <TextBlock Text="RIVER" Style="{StaticResource LabelText}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ContentControl Content="{Binding SelectedHand.RiverCardChips}" ContentTemplate="{StaticResource CardChipListTemplate}" VerticalAlignment="Center"/>
              </StackPanel>
              <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding SelectedHand.RiverActions}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{Binding Background}" Padding="6,3" Margin="0,0,0,3">
                        <ItemsControl ItemsSource="{Binding VisualParts}"
                                      ItemsPanel="{StaticResource InlineSegmentsPanel}"
                                      ItemTemplate="{StaticResource ActionVisualPartTemplate}"/>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </Border>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>




