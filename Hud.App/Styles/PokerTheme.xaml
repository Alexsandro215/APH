<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">



  <!-- Colores base -->
  <Color x:Key="Col.Bg">#0C1016</Color>
  <Color x:Key="Col.Panel">#0F141C</Color>
  <Color x:Key="Col.Card">#141B24</Color>
  <Color x:Key="Col.Border">#223040</Color>
  <Color x:Key="Col.Text">#E7EEF5</Color>
  <Color x:Key="Col.TextDim">#A4B8CB</Color>

  <!-- Acentos póker -->
  <Color x:Key="Col.Accent">#21C07A</Color>
  <Color x:Key="Col.Heart">#E24E5B</Color>
  <Color x:Key="Col.Diamond">#E3B341</Color>
  <Color x:Key="Col.Club">#1AA1D1</Color>


  <SolidColorBrush x:Key="BgDark"
      Color="#121418"/>
  <SolidColorBrush x:Key="PanelDark"
      Color="#1B1E24"/>
  <SolidColorBrush x:Key="BorderDark"
      Color="#2A2F36"/>
  <SolidColorBrush x:Key="FgLight"
      Color="#F2F4F8"/>
  <SolidColorBrush x:Key="FgDim"
      Color="#B7BDC7"/>
  <SolidColorBrush x:Key="FgAccent"
      Color="#69D1FF"/>

  <SolidColorBrush x:Key="HudBlueDark"
      Color="#0257A6"/>
  <SolidColorBrush x:Key="HudBlue"
      Color="#04B8AF"/>
  <SolidColorBrush x:Key="HudGreenSoft"
      Color="#4CB804"/>
  <SolidColorBrush x:Key="HudYellow"
      Color="#B8B504"/>
  <SolidColorBrush x:Key="HudOrange"
      Color="#C26B00"/>
  <SolidColorBrush x:Key="HudRedSoft"
      Color="#FF7373"/>
  <SolidColorBrush x:Key="HudRed"
      Color="#9C0000"/>

  <SolidColorBrush x:Key="HeroRow"
      Color="#1E3A5F"/>
  <SolidColorBrush x:Key="HeroRowSelected"
      Color="#2B5B95"/>
  <SolidColorBrush x:Key="HeroRowAccent"
      Color="#69D1FF"/>

  <SolidColorBrush x:Key="BtnBg"
      Color="#2D6CDF"/>
  <SolidColorBrush x:Key="BtnBgHover"
      Color="#2457B0"/>
  <SolidColorBrush x:Key="BtnFg"
      Color="#FFFFFF"/>


  <!-- Brushes -->
  <SolidColorBrush x:Key="Brush.Bg"
      Color="{StaticResource Col.Bg}"/>
  <SolidColorBrush x:Key="Brush.Panel"
      Color="{StaticResource Col.Panel}"/>
  <SolidColorBrush x:Key="Brush.Card"
      Color="{StaticResource Col.Card}"/>
  <SolidColorBrush x:Key="Brush.Border"
      Color="{StaticResource Col.Border}"/>
  <SolidColorBrush x:Key="Brush.Text"
      Color="{StaticResource Col.Text}"/>
  <SolidColorBrush x:Key="Brush.TextDim"
      Color="{StaticResource Col.TextDim}"/>
  <SolidColorBrush x:Key="Brush.Accent"
      Color="{StaticResource Col.Accent}"/>

  <FontFamily x:Key="Font.UI">Segoe UI</FontFamily>
  <FontFamily x:Key="Font.Symbol">Segoe UI Symbol</FontFamily>

  <!-- Base -->
  <Style TargetType="Window">
    <Setter Property="Background"
        Value="{StaticResource Brush.Bg}"/>
    <Setter Property="Foreground"
        Value="{StaticResource Brush.Text}"/>
    <Setter Property="FontFamily"
        Value="{StaticResource Font.UI}"/>
  </Style>

  <Style TargetType="TextBlock">
    <Setter Property="Foreground"
        Value="{StaticResource Brush.Text}"/>
    <Setter Property="TextWrapping"
        Value="Wrap"/>
  </Style>

  <Style TargetType="Separator">
    <Setter Property="Background"
        Value="{StaticResource Brush.Border}"/>
    <Setter Property="Height"
        Value="1"/>
    <Setter Property="Margin"
        Value="0,8,0,8"/>
  </Style>

  <!-- HERO -->
  <Style x:Key="HeroCard"
      TargetType="Border">
    <Setter Property="Background">
      <Setter.Value>
        <LinearGradientBrush StartPoint="0,0"
            EndPoint="1,1">
          <GradientStop Color="#101722"
              Offset="0"/>
          <GradientStop Color="#101722"
              Offset="0.55"/>
          <GradientStop Color="#12222A"
              Offset="1"/>
        </LinearGradientBrush>
      </Setter.Value>
    </Setter>
    <Setter Property="BorderBrush"
        Value="#2A3949"/>
    <Setter Property="BorderThickness"
        Value="1"/>
    <Setter Property="CornerRadius"
        Value="18"/>
    <Setter Property="Padding"
        Value="22"/>
    <Setter Property="Effect">
      <Setter.Value>
        <DropShadowEffect BlurRadius="18"
            ShadowDepth="0"
            Color="#60000000"/>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Botón carta -->
  <Style x:Key="CardButton"
      TargetType="Button">
    <Setter Property="Foreground"
        Value="{StaticResource Brush.Text}"/>
    <Setter Property="Background"
        Value="{StaticResource Brush.Card}"/>
    <Setter Property="BorderBrush"
        Value="{StaticResource Brush.Border}"/>
    <Setter Property="BorderThickness"
        Value="1"/>
    <Setter Property="Padding"
        Value="16"/>
    <Setter Property="FontSize"
        Value="16"/>
    <Setter Property="Cursor"
        Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bd"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="14"
              Padding="{TemplateBinding Padding}">
            <Grid>
              <ContentPresenter HorizontalAlignment="Center"
                  VerticalAlignment="Center"/>
              <Rectangle x:Name="glow"
                  RadiusX="14"
                  RadiusY="14"
                  Opacity="0">
                <Rectangle.Fill>
                  <RadialGradientBrush GradientOrigin="0.5,0.5"
                      Center="0.5,0.5"
                      RadiusX="0.8"
                      RadiusY="0.8">
                    <GradientStop Color="#4521C07A"
                        Offset="0"/>
                    <GradientStop Color="#0021C07A"
                        Offset="1"/>
                  </RadialGradientBrush>
                </Rectangle.Fill>
              </Rectangle>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver"
                Value="True">
              <Setter TargetName="bd"
                  Property="Background"
                  Value="#18222D"/>
              <Setter TargetName="bd"
                  Property="BorderBrush"
                  Value="#35506C"/>
              <Setter TargetName="glow"
                  Property="Opacity"
                  Value="1"/>
            </Trigger>
            <Trigger Property="IsPressed"
                Value="True">
              <Setter TargetName="bd"
                  Property="Background"
                  Value="#152029"/>
            </Trigger>
            <Trigger Property="IsEnabled"
                Value="False">
              <Setter Property="Opacity"
                  Value="0.55"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="CardButton.Secondary"
      BasedOn="{StaticResource CardButton}"
      TargetType="Button">
    <Setter Property="Background"
        Value="#121A22"/>
    <Setter Property="BorderBrush"
        Value="#2B3A49"/>
  </Style>

  <!-- === Botón primario para los slots (FALTABA) === -->
  <Style TargetType="Button"
      x:Key="Btn.Primary">
    <Setter Property="Foreground"
        Value="{StaticResource Brush.Text}"/>
    <Setter Property="Background"
        Value="{StaticResource Brush.Card}"/>
    <Setter Property="BorderBrush"
        Value="{StaticResource Brush.Border}"/>
    <Setter Property="BorderThickness"
        Value="1"/>
    <Setter Property="Padding"
        Value="10,8"/>
    <Setter Property="Cursor"
        Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="8"
              Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center"
                VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver"
                Value="True">
              <Setter Property="Background"
                  Value="#18222D"/>
              <Setter Property="BorderBrush"
                  Value="#35506C"/>
            </Trigger>
            <Trigger Property="IsPressed"
                Value="True">
              <Setter Property="Background"
                  Value="#152029"/>
            </Trigger>
            <Trigger Property="IsEnabled"
                Value="False">
              <Setter Property="Opacity"
                  Value="0.55"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
