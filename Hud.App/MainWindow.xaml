              <ColumnDefinition Width="2.2*"/>
              <ColumnDefinition Width="0.9*"/>
              <ColumnDefinition Width="1.1*"/>
              <ColumnDefinition Width="0.75*"/>
              <ColumnDefinition Width="0.75*"/>
              <ColumnDefinition Width="0.75*"/>
              <ColumnDefinition Width="0.75*"/>
              <ColumnDefinition Width="0.7*"/>
              <ColumnDefinition Width="0.75*"/>
              <ColumnDefinition Width="0.75*"/>
              <ColumnDefinition Width="0.85*"/>
              <ColumnDefinition Width="0.75*"/>
              <ColumnDefinition Width="0.75*"/>
              <ColumnDefinition Width="0.75*"/>
              <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{DynamicResource Grid.Table}" Style="{StaticResource GridHeaderText}"/>
            <TextBlock Grid.Column="1" Text="{DynamicResource Grid.Format}" Style="{StaticResource GridHeaderText}"/>
            <TextBlock Grid.Column="2" Text="{DynamicResource Grid.Date}" Style="{StaticResource GridHeaderText}"/>
            <TextBlock Grid.Column="3" Text="{DynamicResource Grid.Hands}" Style="{StaticResource GridHeaderText}"/>
            <TextBlock Grid.Column="4" Text="VPIP%" Style="{StaticResource GridHeaderText}"/>
            <TextBlock Grid.Column="5" Text="PFR%" Style="{StaticResource GridHeaderText}"/>
            <TextBlock Grid.Column="6" Text="3Bet%" Style="{StaticResource GridHeaderText}"/>
            <TextBlock Grid.Column="7" Text="AF" Style="{StaticResource GridHeaderText}"/>
            <TextBlock Grid.Column="8" Text="AFq%" Style="{StaticResource GridHeaderText}"/>
            <TextBlock Grid.Column="9" Text="CBet%" Style="{StaticResource GridHeaderText}"/>
            <TextBlock Grid.Column="10" Text="FvCB%" Style="{StaticResource GridHeaderText}"/>
            <TextBlock Grid.Column="11" Text="WTSD%" Style="{StaticResource GridHeaderText}"/>
            <TextBlock Grid.Column="12" Text="W$SD%" Style="{StaticResource GridHeaderText}"/>
            <TextBlock Grid.Column="13" Text="WWSF%" Style="{StaticResource GridHeaderText}"/>
            <TextBlock Grid.Column="14" Text="{DynamicResource Grid.FinalBb}" Style="{StaticResource GridHeaderText}"/>
          </Grid>

