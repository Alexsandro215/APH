                  <DataTemplate>
                    <TextBlock Text="{Binding PFRPct, StringFormat={}{0:0.#}%}" Style="{StaticResource StatGlowText}" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
