          <Grid x:Name="PerformanceSummaryPanel" Grid.Row="4" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.45*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="{DynamicResource Brush.Inset}"
                    BorderBrush="{DynamicResource Brush.HeaderBorder}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12"
                    Margin="0,0,10,0">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="105"/>
                </Grid.RowDefinitions>
                <Border Grid.RowSpan="2" Style="{StaticResource MiniCardBackGlow}"/>
                <DockPanel Margin="0,0,0,8">
                  <TextBlock Text="GANANCIAS ACUMULADAS" Style="{StaticResource SectionEyebrow}" DockPanel.Dock="Left"/>
                  <TextBlock x:Name="PerformanceTotalText" Text="0 bb" Foreground="{DynamicResource Brush.Text}" FontWeight="Bold" HorizontalAlignment="Right"/>
                </DockPanel>
                <Canvas x:Name="PerformanceChart"
                        Grid.Row="1"
                        ClipToBounds="True"
                        Background="#05090D"
                        SizeChanged="PerformanceChart_SizeChanged"/>
              </Grid>
            </Border>

            <Grid Grid.Column="1">
              <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>

              <Border Background="{DynamicResource Brush.Inset}"
                      BorderBrush="{DynamicResource Brush.HeaderBorder}"
                      BorderThickness="1"
                      CornerRadius="10"
                      Padding="12">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Border Grid.ColumnSpan="2" Style="{StaticResource MiniCardBackGlow}"/>
                  <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource Brush.Accent}" FontSize="22" VerticalAlignment="Center" Margin="0,0,12,0"/>
                  <StackPanel Grid.Column="1">
                    <TextBlock Text="MEJOR MESA ULTIMAS 10" Style="{StaticResource SectionEyebrow}"/>
                    <TextBlock Text="{Binding BestRecentTableSummary}" Foreground="{DynamicResource Brush.Text}" FontWeight="Bold" FontSize="15"/>
                    <TextBlock Text="{Binding BestRecentTableDetail}" Foreground="{DynamicResource Brush.TextDim}" FontSize="12"/>
                  </StackPanel>
                </Grid>
              </Border>

              <Border Grid.Row="2"
                      Background="{DynamicResource Brush.Inset}"
                      BorderBrush="{DynamicResource Brush.HeaderBorder}"
                      BorderThickness="1"
                      CornerRadius="10"
                      Padding="12">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Border Grid.ColumnSpan="2" Style="{StaticResource MiniCardBackGlow}"/>
                  <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource Brush.Negative}" FontSize="22" VerticalAlignment="Center" Margin="0,0,12,0"/>
                  <StackPanel Grid.Column="1">
                    <TextBlock Text="PEOR MESA ULTIMAS 10" Style="{StaticResource SectionEyebrow}"/>
                    <TextBlock Text="{Binding WorstRecentTableSummary}" Foreground="{DynamicResource Brush.Text}" FontWeight="Bold" FontSize="15"/>
                    <TextBlock Text="{Binding WorstRecentTableDetail}" Foreground="{DynamicResource Brush.TextDim}" FontSize="12"/>
                  </StackPanel>
                </Grid>
              </Border>
            </Grid>
          </Grid>
        </Grid>
      </Border>
      </Grid>

      <!-- Mesas recientes -->
      <Grid Grid.Row="1" Style="{StaticResource GlowPanelShell}" Margin="6,0,6,16">
      <Border Style="{StaticResource PanelBackGlow}"/>
      <Border Style="{StaticResource PanelCard}" Margin="0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <Grid x:Name="RecentTablesProHeader" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
              <Border Width="4" Height="34" CornerRadius="2" Background="{DynamicResource Brush.Club}" Margin="0,0,10,0"/>
              <StackPanel>
                <TextBlock Text="SESSION FLOW" Style="{StaticResource SectionEyebrow}"/>
                <TextBlock Text="{DynamicResource Main.RecentTables}" Style="{StaticResource SectionHeading}"/>
              </StackPanel>
            </StackPanel>
            <Border HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource HeroMetricPill}" Margin="0">
              <TextBlock Text="BB TRACKER" Foreground="{DynamicResource Brush.TextDim}" FontSize="12" FontWeight="SemiBold"/>
            </Border>
          </Grid>
          <TextBlock x:Name="RecentTablesLiteHeader"
                     Text="{DynamicResource Main.RecentTables}"
                     FontSize="18"
                     FontWeight="Bold"
                     TextAlignment="Center"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,8"
                     Visibility="Collapsed"/>

          <Grid Grid.Row="1" Height="26" Margin="0,0,18,0">
