<Window x:Class="Hud.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Hud.App.Views"
        Title="{DynamicResource App.Title}"
        Height="720" Width="1100"
        WindowStartupLocation="CenterScreen">

  <Window.Resources>
    <views:StatToBrushConverter x:Key="StatToBrush"/>
    <views:StatTextBrushConverter x:Key="StatTextBrush"/>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
  </Window.Resources>

  <!-- Fondo con patrón tenue de palos -->
  <Window.Background>
    <VisualBrush TileMode="Tile" Viewport="0,0,80,80" ViewportUnits="Absolute"
                 Viewbox="0,0,80,80" ViewboxUnits="Absolute" Opacity="0.04">
      <VisualBrush.Visual>
        <Grid>
          <TextBlock Text="&#x2660;" FontFamily="Segoe UI Symbol" Foreground="#FFFFFF" FontSize="28" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8"/>
          <TextBlock Text="&#x2665;" FontFamily="Segoe UI Symbol" Foreground="#FFFFFF" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8"/>
          <TextBlock Text="&#x2663;" FontFamily="Segoe UI Symbol" Foreground="#FFFFFF" FontSize="28" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="8"/>
          <TextBlock Text="&#x2666;" FontFamily="Segoe UI Symbol" Foreground="#FFFFFF" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="8"/>
        </Grid>
      </VisualBrush.Visual>
    </VisualBrush>
  </Window.Background>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- HERO -->
    <Border Style="{StaticResource HeroCard}" Margin="24,24,24,6">
      <DockPanel>
        <Border Width="52" Height="52" CornerRadius="12" Background="#11261A" BorderBrush="#214E38" BorderThickness="1" Margin="0,0,14,0">
          <Viewbox Stretch="Uniform">
            <TextBlock Text="&#x2660;" FontFamily="Segoe UI Symbol" Foreground="{StaticResource Brush.Accent}" FontWeight="Bold"/>
          </Viewbox>
        </Border>
        <StackPanel>
          <TextBlock Text="{DynamicResource App.Title}" FontSize="26" FontWeight="Bold"/>
          <TextBlock Text="{DynamicResource Main.Subtitle}" Foreground="{StaticResource Brush.TextDim}" Margin="0,2,0,0"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Acciones -->
    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  PanningMode="VerticalOnly">
    <Grid Margin="24,6,24,24">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Dashboard -->
      <Border Grid.Row="0" Background="{StaticResource Brush.Card}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="6,10,6,16">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <Grid Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
              <Button Style="{StaticResource Btn.Primary}"
                      Click="BtnHeroProfile_Click"
                      Width="44"
                      Height="44"
                      Padding="0"
                      Margin="0,0,8,0"
                      ToolTip="{DynamicResource Main.HeroProfileTip}">
                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Button>
              <Button Style="{StaticResource Btn.Primary}"
                      Click="BtnPickFolder_Click"
                      Width="44"
                      Height="44"
                      Padding="0"
                      Margin="0,0,8,0"
                      ToolTip="{DynamicResource Main.PickFolderTip}">
                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Button>
              <Button Style="{StaticResource Btn.Primary}"
                      Click="BtnSettings_Click"
                      Width="44"
                      Height="44"
                      Padding="0"
                      ToolTip="{DynamicResource Main.SettingsTip}">
                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Button>
            </StackPanel>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="56,0,56,0">
              <TextBlock Text="{DynamicResource Main.GlobalStats}" FontSize="20" FontWeight="Bold" TextAlignment="Center" HorizontalAlignment="Center"/>
              <TextBlock x:Name="DashboardInfoText" Text="{DynamicResource Main.SelectFolderHint}" Foreground="{StaticResource Brush.TextDim}" Margin="0,2,0,0"/>
            </StackPanel>
          </Grid>

          <Grid Grid.Row="1" Margin="0,0,0,0" Height="26">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2.4*"/>
              <ColumnDefinition Width="1*"/>
              <ColumnDefinition Width="1*"/>
              <ColumnDefinition Width="1*"/>
              <ColumnDefinition Width="1*"/>
              <ColumnDefinition Width="0.85*"/>
              <ColumnDefinition Width="1*"/>
              <ColumnDefinition Width="1*"/>
              <ColumnDefinition Width="1.15*"/>
              <ColumnDefinition Width="1*"/>
              <ColumnDefinition Width="1*"/>
              <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{DynamicResource Grid.Player}" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="4"/>
            <TextBlock Grid.Column="1" Text="{DynamicResource Grid.Hands}" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="4"/>
            <TextBlock Grid.Column="2" Text="VPIP%" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="4"/>
            <TextBlock Grid.Column="3" Text="PFR%" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="4"/>
            <TextBlock Grid.Column="4" Text="3Bet%" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="4"/>
            <TextBlock Grid.Column="5" Text="AF" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="4"/>
            <TextBlock Grid.Column="6" Text="AFq%" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="4"/>
            <TextBlock Grid.Column="7" Text="CBet%" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="4"/>
            <TextBlock Grid.Column="8" Text="FvCBet%" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="4"/>
            <TextBlock Grid.Column="9" Text="WTSD%" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="4"/>
            <TextBlock Grid.Column="10" Text="W$SD%" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="4"/>
            <TextBlock Grid.Column="11" Text="WWSF%" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="4"/>
          </Grid>

          <DataGrid x:Name="DashboardGrid"
                    Grid.Row="2"
                    ItemsSource="{Binding DashboardPlayers}"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserReorderColumns="False"
                    CanUserResizeColumns="False"
                    CanUserResizeRows="False"
                    CanUserSortColumns="False"
                    IsReadOnly="True"
                    HeadersVisibility="None"
                    RowHeaderWidth="0"
                    RowHeight="28"
                    MaxHeight="32"
                    VerticalScrollBarVisibility="Disabled"
                    GridLinesVisibility="None"
                    Background="{StaticResource BgDark}"
                    RowBackground="{StaticResource BgDark}"
                    AlternatingRowBackground="{StaticResource BgDark}"
                    BorderBrush="{StaticResource BorderDark}"
                    Foreground="{StaticResource FgLight}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Jugador" Binding="{Binding Name}" Width="2.4*" IsReadOnly="True"/>
              <DataGridTextColumn Header="#Manos" Binding="{Binding HandsReceived}" Width="1*" IsReadOnly="True">
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                    <Setter Property="TextAlignment" Value="Center"/>
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>

              <DataGridTemplateColumn Header="VPIP%" Width="1*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding VPIPPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="2" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="VPIPPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DashboardStake"/>
                          <Binding Source="VPIP"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="PFR%" Width="1*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding PFRPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="2" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="PFRPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DashboardStake"/>
                          <Binding Source="PFR"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="3Bet%" Width="1*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding ThreeBetPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="2" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="ThreeBetPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DashboardStake"/>
                          <Binding Source="THREEBET"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="AF" Width="0.85*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding AF, StringFormat={}{0:0.#}}" TextAlignment="Center" Padding="2" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="AF"/>
                          <Binding Path="HandsReceived"/>
                          <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DashboardStake"/>
                          <Binding Source="AF"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="AFq%" Width="1*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding AFqPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="2" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="AFqPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DashboardStake"/>
                          <Binding Source="AFQ"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="CBet%" Width="1*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding CBetFlopPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="2" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="CBetFlopPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DashboardStake"/>
                          <Binding Source="CBF"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="FvCBet%" Width="1.15*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding FoldVsCBetFlopPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="2" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="FoldVsCBetFlopPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DashboardStake"/>
                          <Binding Source="FVCBF"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="WTSD%" Width="1*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding WTSDPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="2" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="WTSDPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DashboardStake"/>
                          <Binding Source="WTSD"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="W$SD%" Width="1*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding WSDPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="2" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="WSDPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DashboardStake"/>
                          <Binding Source="WSD"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="WWSF%" Width="1*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding WWSFPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="2" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="WWSFPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DashboardStake"/>
                          <Binding Source="WWSF"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </Border>

      <!-- Mesas recientes -->
      <Border Grid.Row="1" Background="{StaticResource Brush.Card}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"                                                                                         CornerRadius="8" Padding="12" Margin="6,0,6,16">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <TextBlock Text="{DynamicResource Main.RecentTables}" FontSize="18" FontWeight="Bold" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,8"/>

          <Grid Grid.Row="1" Height="26" Margin="0,0,18,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.9*"/>
              <ColumnDefinition Width="0.85*"/>
              <ColumnDefinition Width="0.9*"/>
              <ColumnDefinition Width="0.65*"/>
              <ColumnDefinition Width="0.66*"/>
              <ColumnDefinition Width="0.66*"/>
              <ColumnDefinition Width="0.66*"/>
              <ColumnDefinition Width="0.58*"/>
              <ColumnDefinition Width="0.66*"/>
              <ColumnDefinition Width="0.66*"/>
              <ColumnDefinition Width="0.72*"/>
              <ColumnDefinition Width="0.66*"/>
              <ColumnDefinition Width="0.66*"/>
              <ColumnDefinition Width="0.66*"/>
              <ColumnDefinition Width="0.85*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{DynamicResource Grid.Table}" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="2"/>
            <TextBlock Grid.Column="1" Text="{DynamicResource Grid.Format}" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="2"/>
            <TextBlock Grid.Column="2" Text="{DynamicResource Grid.Date}" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="2"/>
            <TextBlock Grid.Column="3" Text="{DynamicResource Grid.Hands}" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="2"/>
            <TextBlock Grid.Column="4" Text="VPIP%" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="2"/>
            <TextBlock Grid.Column="5" Text="PFR%" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="2"/>
            <TextBlock Grid.Column="6" Text="3Bet%" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="2"/>
            <TextBlock Grid.Column="7" Text="AF" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="2"/>
            <TextBlock Grid.Column="8" Text="AFq%" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="2"/>
            <TextBlock Grid.Column="9" Text="CBet%" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="2"/>
            <TextBlock Grid.Column="10" Text="FvCB%" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="2"/>
            <TextBlock Grid.Column="11" Text="WTSD%" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="2"/>
            <TextBlock Grid.Column="12" Text="W$SD%" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="2"/>
            <TextBlock Grid.Column="13" Text="WWSF%" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="2"/>
            <TextBlock Grid.Column="14" Text="{DynamicResource Grid.FinalBb}" Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.SurfaceText}" FontWeight="SemiBold" TextAlignment="Center" Padding="2"/>
          </Grid>

          <DataGrid Grid.Row="2"
                    ItemsSource="{Binding RecentTables}"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserReorderColumns="False"
                    CanUserResizeColumns="False"
                    CanUserResizeRows="False"
                    CanUserSortColumns="False"
                    IsReadOnly="True"
                    HeadersVisibility="None"
                    RowHeaderWidth="0"
                    RowHeight="28"
                    MaxHeight="170"
                    GridLinesVisibility="None"
                    Background="{StaticResource BgDark}"
                    RowBackground="{StaticResource BgDark}"
                    AlternatingRowBackground="{StaticResource BgDark}"
                    BorderBrush="{StaticResource BorderDark}"
                    Foreground="{StaticResource FgLight}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="{DynamicResource Grid.Table}" Binding="{Binding TableName}" Width="1.9*"/>
              <DataGridTextColumn Header="Formato" Binding="{Binding GameFormat}" Width="0.85*"/>
              <DataGridTextColumn Header="Fecha" Binding="{Binding PlayedDate}" Width="0.9*"/>
              <DataGridTextColumn Header="#Manos" Binding="{Binding HandsReceived}" Width="0.65*">
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                    <Setter Property="TextAlignment" Value="Center"/>
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>

              <DataGridTemplateColumn Header="VPIP%" Width="0.66*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding VPIPPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="VPIPPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding Path="Stake"/>
                          <Binding Source="VPIP"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="PFR%" Width="0.66*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding PFRPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="PFRPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding Path="Stake"/>
                          <Binding Source="PFR"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="3Bet%" Width="0.66*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding ThreeBetPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="ThreeBetPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding Path="Stake"/>
                          <Binding Source="THREEBET"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="AF" Width="0.58*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding AF, StringFormat={}{0:0.#}}" TextAlignment="Center" Padding="1" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="AF"/>
                          <Binding Path="HandsReceived"/>
                          <Binding Path="Stake"/>
                          <Binding Source="AF"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="AFq%" Width="0.66*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding AFqPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="AFqPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding Path="Stake"/>
                          <Binding Source="AFQ"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="CBet%" Width="0.66*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding CBetFlopPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="CBetFlopPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding Path="Stake"/>
                          <Binding Source="CBF"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="FvCBet%" Width="0.72*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding FoldVsCBetFlopPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="FoldVsCBetFlopPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding Path="Stake"/>
                          <Binding Source="FVCBF"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="WTSD%" Width="0.66*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding WTSDPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="WTSDPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding Path="Stake"/>
                          <Binding Source="WTSD"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="W$SD%" Width="0.66*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding WSDPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="WSDPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding Path="Stake"/>
                          <Binding Source="WSD"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="WWSF%" Width="0.66*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding WWSFPct, StringFormat={}{0:0.#}%}" TextAlignment="Center" Padding="1" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="WWSFPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding Path="Stake"/>
                          <Binding Source="WWSF"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="Final bb" Width="0.85*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                      <TextBlock Text="{Binding TrendIcon}" FontWeight="Bold" Margin="0,0,5,0">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#E24E5B"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsWin}" Value="True">
                                <Setter Property="Foreground" Value="#21C07A"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                      <TextBlock Text="{Binding NetBb, StringFormat={}{0:0.#} bb}" Foreground="{StaticResource FgLight}"/>
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </Border>

      <!-- Tiempo real -->
      <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,0,0,18">
        <TextBlock Text="{DynamicResource Main.RealTime}" FontSize="18" FontWeight="SemiBold" Margin="4,0,0,10"/>
        <Button Style="{StaticResource CardButton.Secondary}" Margin="6" Click="BtnRT_Click" ToolTip="{DynamicResource Main.OpenRT}">
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBlock Text="&#xE916;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" FontSize="18"/>
            <TextBlock Text="{DynamicResource Main.OpenRT}" FontSize="18" FontWeight="SemiBold"/>
          </StackPanel>
        </Button>
        <TextBlock x:Name="InfoText" Text="{DynamicResource Main.Waiting}" Foreground="{StaticResource Brush.Accent}" Margin="12,8,0,0"/>
      </StackPanel>

      <StackPanel Grid.Row="3" Orientation="Vertical" Margin="0,0,0,0">
        <TextBlock Text="{DynamicResource Main.HistoryAnalysis}" FontSize="18" FontWeight="SemiBold" Margin="4,0,0,10"/>

        <UniformGrid Columns="4" Rows="1" Margin="0,0,0,6" HorizontalAlignment="Stretch">
          <Button Style="{StaticResource CardButton}" Margin="6" Click="BtnAll_Click">
            <StackPanel>
              <TextBlock Text="{DynamicResource Main.TablesAnalysis}" FontFamily="Segoe UI, Segoe MDL2 Assets" FontSize="18" FontWeight="SemiBold"/>
              <TextBlock Text="{DynamicResource Main.TablesAnalysisDesc}" Foreground="{StaticResource Brush.TextDim}" Margin="0,6,0,0"/>
            </StackPanel>
          </Button>

          <Button Style="{StaticResource CardButton}" Margin="6" Click="BtnOne_Click">
            <StackPanel>
              <TextBlock Text="{DynamicResource Main.MyTables}" FontFamily="Segoe UI, Segoe MDL2 Assets" FontSize="18" FontWeight="SemiBold"/>
              <TextBlock Text="{DynamicResource Main.MyTablesDesc}" Foreground="{StaticResource Brush.TextDim}" Margin="0,6,0,0"/>
            </StackPanel>
          </Button>

          <Button Style="{StaticResource CardButton}" Margin="6" Click="BtnBestWorst_Click">
            <StackPanel>
              <TextBlock Text="{DynamicResource Main.DataVillains}" FontFamily="Segoe UI, Segoe MDL2 Assets" FontSize="18" FontWeight="SemiBold"/>
              <TextBlock Text="{DynamicResource Main.DataVillainsDesc}" Foreground="{StaticResource Brush.TextDim}" Margin="0,6,0,0"/>
            </StackPanel>
          </Button>

          <Button Style="{StaticResource CardButton}" Margin="6" Click="BtnLeakFinder_Click">
            <StackPanel>
              <TextBlock Text="{DynamicResource Main.LeakFinder}" FontFamily="Segoe UI, Segoe MDL2 Assets" FontSize="18" FontWeight="SemiBold"/>
              <TextBlock Text="{DynamicResource Main.LeakFinderDesc}" Foreground="{StaticResource Brush.TextDim}" Margin="0,6,0,0"/>
            </StackPanel>
          </Button>
        </UniformGrid>
      </StackPanel>
    </Grid>
    </ScrollViewer>
   </Grid>
</Window>

