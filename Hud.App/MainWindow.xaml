                          <Binding Path="Stake"/>
                          <Binding Source="FVCBF"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="WTSD%" Width="0.75*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding WTSDPct, StringFormat={}{0:0.#}%}" Style="{StaticResource StatGlowText}" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="WTSDPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding Path="Stake"/>
                          <Binding Source="WTSD"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="W$SD%" Width="0.75*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding WSDPct, StringFormat={}{0:0.#}%}" Style="{StaticResource StatGlowText}" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="WSDPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding Path="Stake"/>
                          <Binding Source="WSD"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="WWSF%" Width="0.75*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding WWSFPct, StringFormat={}{0:0.#}%}" Style="{StaticResource StatGlowText}" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="WWSFPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding Path="Stake"/>
                          <Binding Source="WWSF"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="{DynamicResource Grid.FinalBb}" Width="1*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                      <TextBlock Text="{Binding TrendIcon}" FontWeight="Bold" Margin="0,0,5,0">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Negative}"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsWin}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                      <TextBlock Text="{Binding NetBb, StringFormat={}{0:0.#} bb}" Foreground="{DynamicResource Brush.Text}"/>
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </Border>
      </Grid>

    </Grid>
    </ScrollViewer>
   </Grid>
</Window>

