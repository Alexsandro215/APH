                    ItemsSource="{Binding RecentTables}"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserReorderColumns="False"
                    CanUserResizeColumns="False"
                    CanUserResizeRows="False"
                    CanUserSortColumns="False"
                    IsReadOnly="True"
                    HeadersVisibility="None"
                    RowHeaderWidth="0"
                    RowHeight="30"
                    MinHeight="305"
                    VerticalScrollBarVisibility="Disabled"
                    GridLinesVisibility="None"
                    Background="{DynamicResource Brush.Inset}"
                    RowBackground="{DynamicResource Brush.Inset}"
                    AlternatingRowBackground="{DynamicResource Brush.Inset}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    Foreground="{DynamicResource Brush.Text}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="{DynamicResource Grid.Table}" Binding="{Binding TableName}" Width="2.2*"/>
              <DataGridTextColumn Header="{DynamicResource Grid.Format}" Binding="{Binding GameFormat}" Width="0.9*"/>
              <DataGridTextColumn Header="{DynamicResource Grid.Date}" Binding="{Binding PlayedDate}" Width="1.1*"/>
              <DataGridTextColumn Header="#Manos" Binding="{Binding HandsReceived}" Width="0.75*">
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                    <Setter Property="TextAlignment" Value="Center"/>
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>

              <DataGridTemplateColumn Header="VPIP%" Width="0.75*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding VPIPPct, StringFormat={}{0:0.#}%}" Style="{StaticResource StatGlowText}" Foreground="{Binding HandsReceived, Converter={StaticResource StatTextBrush}}">
                      <TextBlock.Background>
                        <MultiBinding Converter="{StaticResource StatToBrush}">
                          <Binding Path="VPIPPct"/>
                          <Binding Path="HandsReceived"/>
                          <Binding Path="Stake"/>
                          <Binding Source="VPIP"/>
                        </MultiBinding>
                      </TextBlock.Background>
                    </TextBlock>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <DataGridTemplateColumn Header="PFR%" Width="0.75*">
